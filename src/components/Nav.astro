---
interface Props {
  variant?: 'dark' | 'light';
}

const { variant = 'dark' } = Astro.props;

const formationLinks = [
  {
    href: '/formations/avocats',
    label: 'Avocats et juristes',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  },
  {
    href: '/formations/consultants',
    label: 'Consultants',
    icon: '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
  },
  {
    href: '/formations/dirigeants',
    label: 'Dirigeants et managers',
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
  {
    href: '/formations/rh',
    label: 'Ressources humaines',
    icon: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
  },
  {
    href: '/formations/medecins',
    label: 'Médecins',
    icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
  },
];

const simpleNavLinks = [
  { href: '/bootcamp', label: 'Bootcamp IA' },
  { href: '/newsletter', label: 'Newsletter' },
  { href: '/blog', label: 'Blog' },
  { href: '/a-propos', label: 'À propos' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
const isLight = variant === 'light';
---

<nav aria-label="Navigation principale" class={isLight ? 'nav-light' : 'nav-dark'}>
  <div class="nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Cercle IA — Accueil">
      <img
        src={isLight ? '/images/cercle-ia-logo-dark.svg' : '/images/cercle-ia-logo.svg'}
        alt="Cercle IA"
        width="140"
        height="36"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Liens desktop -->
    <ul class="nav-links" role="list">
      <!-- Bootcamp -->
      <li>
        <a href="/bootcamp" aria-current={currentPath === '/bootcamp' ? 'page' : undefined}>
          Bootcamp IA
        </a>
      </li>

      <!-- Formations IA avec dropdown -->
      <li class="has-dropdown">
        <a
          href="/formations"
          class="dropdown-trigger"
          aria-haspopup="true"
          aria-current={currentPath.startsWith('/formations') ? 'page' : undefined}
        >
          Formations IA
          <svg class="chevron" width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
            <path d="M2 3.5l3.5 3.5 3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

        <div class="dropdown-panel" role="region" aria-label="Formations IA">
          <div class="dropdown-inner">

            <!-- Colonne gauche : Bootcamp -->
            <div class="dropdown-bootcamp">
              <div class="dropdown-bootcamp-tag">Bootcamp IA</div>
              <h3 class="dropdown-bootcamp-title">Maîtrisez l'IA générative dans votre métier</h3>
              <p class="dropdown-bootcamp-session">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                Prochaine session : Été 2026
              </p>
              <p class="dropdown-bootcamp-desc">
                3 sessions pour intégrer l'IA dans votre pratique, sans prérequis techniques.
              </p>
              <div class="dropdown-bootcamp-actions">
                <a href="#" data-open-modal="waitlist" class="dropdown-btn-primary">S'inscrire sur la liste d'attente</a>
                <a href="/bootcamp" class="dropdown-text-link">Voir le programme &rarr;</a>
              </div>
            </div>



            <!-- Colonne droite : Formations par métier -->
            <div class="dropdown-formations">
              <p class="dropdown-section-title">Formations IA par métier</p>
              <ul role="list" class="dropdown-formation-list">
                {formationLinks.map((f) => (
                  <li>
                    <a
                      href={f.href}
                      class="dropdown-formation-link"
                      aria-current={currentPath === f.href ? 'page' : undefined}
                    >
                      <span class="dropdown-formation-icon" aria-hidden="true">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
                      </span>
                      {f.label}
                    </a>
                  </li>
                ))}
              </ul>
              <div class="dropdown-contact-block">
                <p>Vous souhaitez une formation personnalisée ?</p>
                <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="dropdown-text-link">
                  Contactez-nous &rarr;
                </a>
              </div>
            </div>

          </div>

          <!-- Footer du dropdown -->
          <div class="dropdown-footer">
            <a href="/formations" class="dropdown-footer-link">Voir toutes les formations &rarr;</a>
          </div>
        </div>
      </li>

      <!-- Autres liens -->
      {simpleNavLinks.slice(1).map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={!link.external && currentPath === link.href ? 'page' : undefined}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA + hamburger -->
    <div class="nav-actions">
      <a href="https://app.lecercle.ai" class="nav-cta" target="_blank" rel="noopener noreferrer">
        Plateforme
      </a>

      <button
        class="nav-hamburger"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="hamburger-btn"
      >
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <line x1="3" y1="6" x2="19" y2="6" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
          <line x1="3" y1="11" x2="19" y2="11" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
          <line x1="3" y1="16" x2="19" y2="16" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Menu mobile -->
  <div class="nav-mobile" id="mobile-menu" hidden>
    <ul role="list">
      <li>
        <a href="/bootcamp" aria-current={currentPath === '/bootcamp' ? 'page' : undefined}>
          Bootcamp IA
        </a>
      </li>
      <li>
        <span class="mobile-section-label">Formations IA</span>
        <ul class="mobile-sub-list" role="list">
          {formationLinks.map((f) => (
            <li>
              <a href={f.href} aria-current={currentPath === f.href ? 'page' : undefined}>
                {f.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/formations">Voir toutes les formations &rarr;</a>
          </li>
        </ul>
      </li>
      {simpleNavLinks.slice(1).map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={!link.external && currentPath === link.href ? 'page' : undefined}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="https://app.lecercle.ai" class="nav-cta" target="_blank" rel="noopener noreferrer">
          Plateforme
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    if (menu) menu.hidden = expanded;
  });
</script>

<style>
  nav {
    height: var(--nav-height);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav.nav-dark {
    background: var(--color-dark-1);
    border-bottom: 1px solid var(--color-dark-border);
  }

  nav.nav-light {
    background: #F5F4EE;
    border-bottom: 1px solid rgba(6,23,23,0.08);
  }

  nav.nav-light .nav-links a {
    color: rgba(6,23,23,0.55);
  }

  nav.nav-light .nav-links a:hover,
  nav.nav-light .nav-links a[aria-current="page"] {
    color: #061717;
  }

  nav.nav-light .nav-cta {
    color: var(--color-accent-hover);
  }

  nav.nav-light .nav-mobile {
    background: #F5F4EE;
    border-top-color: rgba(6,23,23,0.08);
  }

  nav.nav-light .nav-mobile a {
    color: rgba(6,23,23,0.6);
  }

  nav.nav-light .nav-mobile a:hover {
    color: #061717;
    background: rgba(6,23,23,0.05);
  }

  nav.nav-light .nav-hamburger svg line {
    stroke: #061717;
  }

  /* ===== NAV INNER ===== */
  .nav-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 40px;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    flex: 1;
  }

  .nav-links > li {
    position: relative;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    padding: 6px 10px;
    border-radius: var(--radius-sm);
    transition: color var(--transition);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .nav-links a:hover,
  .nav-links a[aria-current="page"] {
    color: #ffffff;
  }

  .nav-links a[aria-current="page"] {
    font-weight: 500;
  }

  .chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .has-dropdown:hover .chevron,
  .has-dropdown:focus-within .chevron {
    transform: rotate(180deg);
  }

  /* ===== DROPDOWN PANEL ===== */
  .dropdown-panel {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-42%) translateY(-6px);
    width: 660px;
    background: rgba(6, 18, 18, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.5);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.18s ease, visibility 0.18s ease, transform 0.18s ease;
    z-index: 200;
  }

  .has-dropdown:hover .dropdown-panel,
  .has-dropdown:focus-within .dropdown-panel {
    opacity: 1;
    visibility: visible;
    pointer-events: all;
    transform: translateX(-42%) translateY(0);
  }

  .dropdown-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    padding: 20px;
  }

  /* Bootcamp col */
  .dropdown-bootcamp {
    background: rgba(247,171,110,0.04);
    border: 1px solid rgba(247,171,110,0.15);
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .dropdown-bootcamp-tag {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 20px;
    background: rgba(247,171,110,0.15);
    border: 1px solid rgba(247,171,110,0.3);
    color: var(--color-accent);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    width: fit-content;
    font-family: var(--font-body);
  }

  .dropdown-bootcamp-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .dropdown-bootcamp-session {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    font-family: var(--font-body);
    margin: 0;
  }

  .dropdown-bootcamp-desc {
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    line-height: 1.6;
    font-family: var(--font-body);
    margin: 0;
  }

  .dropdown-bootcamp-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 6px;
  }

  .dropdown-btn-primary {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    padding: 9px 16px !important;
    background: var(--color-accent) !important;
    color: var(--color-dark-1) !important;
    border-radius: 30px;
    font-size: 12px !important;
    font-weight: 600;
    text-decoration: none;
    transition: background var(--transition);
    white-space: nowrap;
    gap: 0 !important;
  }

  .dropdown-btn-primary:hover {
    background: var(--color-accent-hover) !important;
    color: var(--color-dark-1) !important;
  }

  .dropdown-text-link {
    font-size: 13px !important;
    font-weight: 500;
    color: var(--color-accent) !important;
    text-decoration: none;
    padding: 0 !important;
    gap: 0 !important;
    display: inline !important;
    transition: opacity var(--transition);
  }

  .dropdown-text-link:hover {
    opacity: 0.75;
    color: var(--color-accent) !important;
  }

  /* Formations col */
  .dropdown-formations {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 8px 4px 8px 8px;
  }

  .dropdown-section-title {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin: 0;
  }

  .dropdown-formation-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin: 0;
    padding: 0;
  }

  .dropdown-formation-link {
    display: flex !important;
    align-items: center;
    gap: 10px !important;
    padding: 7px 10px !important;
    border-radius: 8px;
    font-size: 14px !important;
    color: rgba(255,255,255,0.7) !important;
    text-decoration: none;
    transition: background var(--transition), color var(--transition);
    font-family: var(--font-body);
    font-weight: 400;
  }

  .dropdown-formation-link:hover,
  .dropdown-formation-link[aria-current="page"] {
    background: rgba(255,255,255,0.06);
    color: #ffffff !important;
  }

  .dropdown-formation-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: rgba(247,171,110,0.1);
    border: 1px solid rgba(247,171,110,0.15);
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .dropdown-contact-block {
    margin-top: 4px;
    padding-top: 14px;
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  .dropdown-contact-block p {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    margin: 0 0 4px;
    font-family: var(--font-body);
    line-height: 1.4;
  }

  /* Footer dropdown */
  .dropdown-footer {
    padding: 12px 28px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .dropdown-footer-link {
    display: block !important;
    font-size: 13px !important;
    color: rgba(255,255,255,0.4) !important;
    text-decoration: none;
    padding: 0 !important;
    gap: 0 !important;
    font-family: var(--font-body);
    transition: color var(--transition);
  }

  .dropdown-footer-link:hover {
    color: rgba(255,255,255,0.75) !important;
  }

  /* ===== NAV ACTIONS ===== */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-left: auto;
  }

  .nav-cta {
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--transition);
  }

  .nav-cta:hover {
    color: var(--color-accent-hover);
  }

  .nav-hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  /* ===== MOBILE MENU ===== */
  .nav-mobile {
    background: var(--color-dark-1);
    border-top: 1px solid var(--color-dark-border);
    padding: 16px 20px;
  }

  .nav-mobile > ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-mobile a {
    display: block;
    font-family: var(--font-body);
    font-size: 15px;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    padding: 10px 12px;
    border-radius: var(--radius-md);
    transition: color var(--transition), background var(--transition);
  }

  .nav-mobile a:hover,
  .nav-mobile a[aria-current="page"] {
    color: #ffffff;
    background: rgba(255,255,255,0.05);
  }

  .mobile-section-label {
    display: block;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    padding: 10px 12px 4px;
  }

  .mobile-sub-list {
    list-style: none;
    padding: 0;
    margin: 0 0 4px;
  }

  .mobile-sub-list a {
    font-size: 14px;
    padding: 8px 12px 8px 24px;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .nav-links { display: none; }
    .nav-hamburger { display: flex; }
    nav { height: auto; min-height: var(--nav-height); }
    .nav-inner { height: var(--nav-height); }
  }

  @media (max-width: 768px) {
    .nav-inner { padding: 0 20px; }
  }
</style>
