---
---

<!-- Modal liste d'attente Bootcamp IA -->
<div id="waitlist-modal" hidden role="dialog" aria-modal="true" aria-labelledby="waitlist-modal-title">
  <div class="modal-overlay" id="waitlist-modal-overlay">
    <div class="modal-card">

      <!-- Fermer -->
      <button class="modal-close" id="waitlist-modal-close" aria-label="Fermer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      <!-- État initial : formulaire -->
      <div id="waitlist-form-state">
        <div class="modal-header">
          <span aria-hidden="true">🚀</span> Bootcamp IA
        </div>
        <h2 class="modal-title" id="waitlist-modal-title">
          Inscription à la liste d'attente<br />pour la session d'été 2026
        </h2>
        <p class="modal-subtitle">
          Inscrivez-vous pour recevoir des informations sur les prochaines sessions
        </p>

        <form
          id="waitlist-form"
          name="waitlist"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          novalidate
        >
          <input type="hidden" name="form-name" value="waitlist" />
          <input type="hidden" name="bot-field" />

          <div class="form-grid">
            <input type="text" name="prenom" placeholder="Prénom" class="input-dark" required />
            <input type="text" name="nom" placeholder="Nom" class="input-dark" required />
            <input type="email" name="email" placeholder="Email" class="input-dark" required />
            <input type="tel" name="telephone" placeholder="Téléphone" class="input-dark" />
            <input type="text" name="entreprise" placeholder="Entreprise" class="input-dark" />
            <input type="text" name="fonction" placeholder="Fonction" class="input-dark" />
            <textarea
              name="source"
              placeholder="Comment avez-vous entendu parlé du programme ?"
              class="input-dark textarea-full"
              rows="3"
            ></textarea>
          </div>

          <div class="form-gdpr">
            <input type="checkbox" id="waitlist-gdpr" name="gdpr" required />
            <label for="waitlist-gdpr">
              En introduisant vos coordonnées dans ce formulaire, vous acceptez le traitement de vos données conformément à notre <a href="/politique-confidentialite">politique de confidentialité</a>.
            </label>
          </div>

          <p class="form-error" id="waitlist-error" hidden>Une erreur est survenue. Veuillez réessayer.</p>

          <button type="submit" class="modal-submit" id="waitlist-submit">
            S'inscrire
          </button>
        </form>
      </div>

      <!-- État succès -->
      <div id="waitlist-success-state" hidden>
        <div class="modal-success">
          <span class="modal-success-icon" aria-hidden="true">✓</span>
          <h2 class="modal-title">Vous êtes sur la liste !</h2>
          <p class="modal-subtitle">
            Nous vous contacterons en priorité à l'ouverture des inscriptions pour la session d'été 2026.
          </p>
          <button class="modal-submit" id="waitlist-success-close">Fermer</button>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('waitlist-modal');
  const overlay = document.getElementById('waitlist-modal-overlay');
  const closeBtn = document.getElementById('waitlist-modal-close');
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const errorMsg = document.getElementById('waitlist-error');
  const submitBtn = document.getElementById('waitlist-submit');
  const formState = document.getElementById('waitlist-form-state');
  const successState = document.getElementById('waitlist-success-state');
  const successClose = document.getElementById('waitlist-success-close');

  function openModal() {
    modal?.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeModal() {
    modal?.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  // Triggers sur tous les boutons waitlist
  document.querySelectorAll('[data-open-modal="waitlist"]').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      openModal();
    });
  });

  closeBtn?.addEventListener('click', closeModal);
  successClose?.addEventListener('click', closeModal);

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal?.hasAttribute('hidden')) closeModal();
  });

  // Soumission AJAX (Netlify Forms)
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    if (submitBtn) {
      submitBtn.textContent = 'Envoi en cours…';
      (submitBtn as HTMLButtonElement).disabled = true;
    }
    errorMsg?.setAttribute('hidden', '');

    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
      });
      if (res.ok) {
        formState?.setAttribute('hidden', '');
        successState?.removeAttribute('hidden');
      } else {
        throw new Error('Erreur réseau');
      }
    } catch {
      errorMsg?.removeAttribute('hidden');
      if (submitBtn) {
        submitBtn.textContent = 'S\'inscrire';
        (submitBtn as HTMLButtonElement).disabled = false;
      }
    }
  });
</script>

<style>
  #waitlist-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
  }

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    overflow-y: auto;
  }

  .modal-card {
    position: relative;
    background: #0b1e1e;
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 20px;
    padding: 48px 40px 40px;
    width: 100%;
    max-width: 640px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6);
  }

  .modal-close {
    position: absolute;
    top: 18px;
    right: 18px;
    background: none;
    border: none;
    color: rgba(255,255,255,0.35);
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s;
  }

  .modal-close:hover {
    color: rgba(255,255,255,0.8);
  }

  .modal-header {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    text-align: center;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .modal-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    letter-spacing: -0.02em;
    text-align: center;
    margin: 0 0 12px;
  }

  .modal-subtitle {
    font-family: var(--font-body);
    font-size: 14px;
    color: rgba(255,255,255,0.45);
    text-align: center;
    line-height: 1.6;
    margin: 0 0 28px;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 16px;
  }

  .textarea-full {
    grid-column: span 2;
    resize: vertical;
  }

  .form-gdpr {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 20px;
  }

  .form-gdpr input[type="checkbox"] {
    flex-shrink: 0;
    margin-top: 3px;
    accent-color: var(--color-accent);
    width: 16px;
    height: 16px;
    cursor: pointer;
  }

  .form-gdpr label {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    line-height: 1.6;
    cursor: pointer;
  }

  .form-gdpr label a {
    color: rgba(255,255,255,0.6);
    text-decoration: underline;
  }

  .form-error {
    font-family: var(--font-body);
    font-size: 13px;
    color: #f87171;
    margin-bottom: 12px;
    text-align: center;
  }

  .modal-submit {
    width: 100%;
    padding: 14px 24px;
    background: var(--color-accent);
    color: var(--color-dark-1);
    border: none;
    border-radius: 30px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }

  .modal-submit:hover:not(:disabled) {
    background: var(--color-accent-hover);
  }

  .modal-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .modal-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 24px 0 8px;
    text-align: center;
  }

  .modal-success-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(247,171,110,0.15);
    border: 1px solid rgba(247,171,110,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: var(--color-accent);
  }

  @media (max-width: 540px) {
    .modal-card {
      padding: 40px 24px 32px;
    }
    .modal-title {
      font-size: 22px;
    }
    .form-grid {
      grid-template-columns: 1fr;
    }
    .textarea-full {
      grid-column: span 1;
    }
  }
</style>
