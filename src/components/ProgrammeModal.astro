---
---

<!-- Modal réception du programme Bootcamp IA -->
<div id="programme-modal" hidden role="dialog" aria-modal="true" aria-labelledby="programme-modal-title">
  <div class="modal-overlay" id="programme-modal-overlay">
    <div class="modal-card">

      <!-- Fermer -->
      <button class="modal-close" id="programme-modal-close" aria-label="Fermer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      <!-- État initial : formulaire -->
      <div id="programme-form-state">
        <div class="modal-header">
          <span aria-hidden="true">📄</span> Bootcamp IA
        </div>
        <h2 class="modal-title" id="programme-modal-title"></h2>
        <p class="modal-subtitle" id="programme-modal-subtitle"></p>

        <form
          id="programme-form"
          name="programme"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          novalidate
        >
          <input type="hidden" name="form-name" value="programme" />
          <input type="hidden" name="bot-field" />
          <input type="hidden" name="lang" id="programme-lang" value="fr" />

          <div class="form-grid">
            <input type="text" id="programme-prenom" name="prenom" class="input-dark" required />
            <input type="text" id="programme-nom" name="nom" class="input-dark" />
            <input type="email" id="programme-email" name="email" class="input-dark" required />
            <input type="tel" id="programme-telephone" name="telephone" class="input-dark" />
            <input type="text" id="programme-entreprise" name="entreprise" class="input-dark" />
            <input type="text" id="programme-fonction" name="fonction" class="input-dark" />
          </div>

          <div class="form-gdpr">
            <input type="checkbox" id="programme-gdpr" name="gdpr" required />
            <label for="programme-gdpr" id="programme-gdpr-label"></label>
          </div>

          <p class="form-error" id="programme-error" hidden></p>

          <button type="submit" class="modal-submit" id="programme-submit"></button>
        </form>
      </div>

      <!-- État succès -->
      <div id="programme-success-state" hidden>
        <div class="modal-success">
          <span class="modal-success-icon" aria-hidden="true">✓</span>
          <h2 class="modal-title" id="programme-success-title"></h2>
          <p class="modal-subtitle" id="programme-success-subtitle"></p>
          <button class="modal-submit" id="programme-success-close"></button>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  const isEN = window.location.pathname.startsWith('/en');

  const tx = {
    title:    isEN ? 'Receive the full programme' : 'Recevoir le programme complet',
    subtitle: isEN
      ? 'Receive the detailed Bootcamp IA programme directly by email.'
      : 'Recevez le programme détaillé du Bootcamp IA directement par email.',
    fields: {
      prenom:    isEN ? 'First name' : 'Prénom',
      nom:       isEN ? 'Last name' : 'Nom',
      email:     'Email',
      telephone: isEN ? 'Phone' : 'Téléphone',
      entreprise: isEN ? 'Company' : 'Entreprise',
      fonction:  isEN ? 'Job title' : 'Fonction',
    },
    gdpr: isEN
      ? 'By submitting this form, you agree to the processing of your data in accordance with our <a href="/en/politique-confidentialite" style="color:rgba(255,255,255,0.6);text-decoration:underline;">privacy policy</a>.'
      : 'En introduisant vos coordonnées dans ce formulaire, vous acceptez le traitement de vos données conformément à notre <a href="/politique-confidentialite" style="color:rgba(255,255,255,0.6);text-decoration:underline;">politique de confidentialité</a>.',
    error:   isEN ? 'An error occurred. Please try again.' : 'Une erreur est survenue. Veuillez réessayer.',
    submit:  isEN ? 'Receive the programme' : 'Recevoir le programme',
    sending: isEN ? 'Sending…' : 'Envoi en cours…',
    successTitle:    isEN ? 'Programme sent!' : 'Programme envoyé !',
    successSubtitle: isEN
      ? 'You\'ll receive the full Bootcamp IA programme in your inbox.'
      : 'Vous allez recevoir le programme complet du Bootcamp IA dans votre boîte mail.',
    close: isEN ? 'Close' : 'Fermer',
  };

  function setText(id: string, val: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  }
  function setHTML(id: string, val: string) {
    const el = document.getElementById(id);
    if (el) el.innerHTML = val;
  }
  function setPlaceholder(id: string, val: string) {
    const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
    if (el) el.placeholder = val;
  }

  // Populate text
  setText('programme-modal-title', tx.title);
  setText('programme-modal-subtitle', tx.subtitle);
  setPlaceholder('programme-prenom', tx.fields.prenom);
  setPlaceholder('programme-nom', tx.fields.nom);
  setPlaceholder('programme-email', tx.fields.email);
  setPlaceholder('programme-telephone', tx.fields.telephone);
  setPlaceholder('programme-entreprise', tx.fields.entreprise);
  setPlaceholder('programme-fonction', tx.fields.fonction);
  setHTML('programme-gdpr-label', tx.gdpr);
  setText('programme-error', tx.error);
  setText('programme-submit', tx.submit);
  setText('programme-success-title', tx.successTitle);
  setText('programme-success-subtitle', tx.successSubtitle);
  setText('programme-success-close', tx.close);

  // Set lang field
  const langInput = document.getElementById('programme-lang') as HTMLInputElement | null;
  if (langInput) langInput.value = isEN ? 'en' : 'fr';

  // Update aria-label on close button
  const closeBtn = document.getElementById('programme-modal-close');
  if (closeBtn) closeBtn.setAttribute('aria-label', isEN ? 'Close' : 'Fermer');

  // ── Modal logic ──────────────────────────────────────────────────────────────

  const modal = document.getElementById('programme-modal');
  const overlay = document.getElementById('programme-modal-overlay');
  const form = document.getElementById('programme-form') as HTMLFormElement | null;
  const errorMsg = document.getElementById('programme-error');
  const submitBtn = document.getElementById('programme-submit');
  const formState = document.getElementById('programme-form-state');
  const successState = document.getElementById('programme-success-state');
  const successClose = document.getElementById('programme-success-close');

  function openModal() {
    modal?.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeModal() {
    modal?.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-open-modal="programme"]').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      openModal();
    });
  });

  closeBtn?.addEventListener('click', closeModal);
  successClose?.addEventListener('click', closeModal);

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal?.hasAttribute('hidden')) closeModal();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    if (submitBtn) {
      submitBtn.textContent = tx.sending;
      (submitBtn as HTMLButtonElement).disabled = true;
    }
    errorMsg?.setAttribute('hidden', '');

    try {
      const res = await fetch(window.location.pathname, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
      });
      if (res.ok) {
        formState?.setAttribute('hidden', '');
        successState?.removeAttribute('hidden');
      } else {
        throw new Error('network error');
      }
    } catch {
      errorMsg?.removeAttribute('hidden');
      if (submitBtn) {
        submitBtn.textContent = tx.submit;
        (submitBtn as HTMLButtonElement).disabled = false;
      }
    }
  });
</script>

<style>
  #programme-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
  }

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    overflow-y: auto;
  }

  .modal-card {
    position: relative;
    background: #0b1e1e;
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 20px;
    padding: 48px 40px 40px;
    width: 100%;
    max-width: 640px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6);
  }

  .modal-close {
    position: absolute;
    top: 18px;
    right: 18px;
    background: none;
    border: none;
    color: rgba(255,255,255,0.35);
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s;
  }

  .modal-close:hover {
    color: rgba(255,255,255,0.8);
  }

  .modal-header {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    text-align: center;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .modal-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    letter-spacing: -0.02em;
    text-align: center;
    margin: 0 0 12px;
  }

  .modal-subtitle {
    font-family: var(--font-body);
    font-size: 14px;
    color: rgba(255,255,255,0.45);
    text-align: center;
    line-height: 1.6;
    margin: 0 0 28px;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 16px;
  }

  .form-gdpr {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 20px;
  }

  .form-gdpr input[type="checkbox"] {
    flex-shrink: 0;
    margin-top: 3px;
    accent-color: var(--color-accent);
    width: 16px;
    height: 16px;
    cursor: pointer;
  }

  .form-gdpr label {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    line-height: 1.6;
    cursor: pointer;
  }

  .form-gdpr label a {
    color: rgba(255,255,255,0.6);
    text-decoration: underline;
  }

  .form-error {
    font-family: var(--font-body);
    font-size: 13px;
    color: #f87171;
    margin-bottom: 12px;
    text-align: center;
  }

  .modal-submit {
    width: 100%;
    padding: 14px 24px;
    background: var(--color-accent);
    color: var(--color-dark-1);
    border: none;
    border-radius: 30px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }

  .modal-submit:hover:not(:disabled) {
    background: var(--color-accent-hover);
  }

  .modal-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .modal-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 24px 0 8px;
    text-align: center;
  }

  .modal-success-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(247,171,110,0.15);
    border: 1px solid rgba(247,171,110,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: var(--color-accent);
  }

  @media (max-width: 540px) {
    .modal-card {
      padding: 40px 24px 32px;
    }
    .modal-title {
      font-size: 22px;
    }
    .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
