---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WaitlistModal from '../components/WaitlistModal.astro';
import ProgrammeModal from '../components/ProgrammeModal.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  lcpImage?: string;
  schema?: object;
  robots?: string;
  canonical?: string;
  navVariant?: 'dark' | 'light';
  /** Explicit alternate URL for hreflang. Pass `false` to suppress hreflang on pages with no translation. */
  hreflangAlternate?: string | false;
}

const {
  title,
  description,
  ogImage = '/og/default.jpg',
  ogImageAlt = 'Cercle IA — Formations IA pour professionnels',
  ogType = 'website',
  lcpImage,
  schema,
  robots = 'index,follow',
  canonical,
  navVariant = 'dark',
  hreflangAlternate,
} = Astro.props;

const pathname = Astro.url.pathname;
const isEN = pathname.startsWith('/en/') || pathname === '/en';
const pageLang = isEN ? 'en' : 'fr';
const ogLocale = isEN ? 'en_US' : 'fr_BE';
const ogLocaleAlt = isEN ? 'fr_BE' : 'en_US';

const canonicalURL = canonical ?? new URL(pathname, Astro.site).href;
const ogImageURL = new URL(ogImage, Astro.site).href;

// Auto-compute alternate URL; pages with different slugs across languages pass hreflangAlternate explicitly
let alternateHref: string | null = null;
if (hreflangAlternate === false) {
  alternateHref = null;
} else if (typeof hreflangAlternate === 'string') {
  alternateHref = new URL(hreflangAlternate, Astro.site).href;
} else {
  const frPath = isEN ? (pathname.replace(/^\/en/, '') || '/') : pathname;
  const enPath = isEN ? pathname : ('/en' + (pathname === '/' ? '' : pathname));
  alternateHref = new URL(isEN ? frPath : enPath, Astro.site).href;
}

const hreflangFR = isEN ? alternateHref : canonicalURL;
const hreflangEN = isEN ? canonicalURL : alternateHref;
---

<!doctype html>
<html lang={pageLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="dns-prefetch"
      href="https://fonts.googleapis.com"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- LCP image preload -->
    {lcpImage && (
      <link rel="preload" as="image" href={lcpImage} fetchpriority="high" />
    )}

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Hreflang -->
    {alternateHref && (
      <>
        <link rel="alternate" hreflang="fr" href={hreflangFR!} />
        <link rel="alternate" hreflang="en" href={hreflangEN!} />
        <link rel="alternate" hreflang="x-default" href={hreflangFR!} />
      </>
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="720" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:site_name" content="Cercle IA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Schema.org JSON-LD -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- Meta domain verification (validation uniquement, pas de tracking) -->
    <meta name="facebook-domain-verification" content="jcxtfzidk45tovq8435a38w5brb0lu" />

    <!-- Analytics — chargement conditionnel selon consentement RGPD -->
    <script is:inline>
    (function () {
      var KEY = 'cercleia_consent';
      var loaded = { analytics: false, marketing: false };

      function getConsent() {
        try { return JSON.parse(localStorage.getItem(KEY) || 'null'); } catch { return null; }
      }

      function addScript(src, extra) {
        var el = document.createElement('script');
        el.src = src;
        el.async = true;
        if (extra) for (var k in extra) el.setAttribute(k, extra[k]);
        document.head.appendChild(el);
      }

      function loadAnalytics() {
        if (loaded.analytics) return;
        loaded.analytics = true;

        // Plausible Analytics
        window.plausible = window.plausible || function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
        addScript(
          'https://plausible.151.80.20.211.sslip.io/js/script.file-downloads.hash.outbound-links.pageview-props.revenue.tagged-events.js',
          { 'data-domain': 'lecercle.ai' }
        );

        // Google Tag Manager
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        addScript('https://sst.lecercle.ai/gtm.js?id=GTM-N3MQNF83');
      }

      function loadMarketing() {
        if (loaded.marketing) return;
        loaded.marketing = true;

        // VBOUT
        window._vbset = window._vbset || [];
        window._vbset.push(['_account', 'VBT-68187-14968']);
        window._vbset.push(['_domain', 'https://lecercle.ai']);
        addScript('https://www.vbt.io/tracker?_account=VBT-68187-14968&_domain=https://lecercle.ai');
      }

      function applyConsent(consent) {
        if (!consent) return;
        if (consent.analytics) loadAnalytics();
        if (consent.marketing) loadMarketing();
      }

      applyConsent(getConsent());

      window.addEventListener('cercleia:consent', function (e) {
        applyConsent(e.detail);
      });
    })();
    </script>

    <!-- Stackbit Visual Editor content reload -->
    <script is:inline>
      window.addEventListener('stackbitObjectsChanged', function () {
        window.location.reload();
      });
    </script>
  </head>
  <body>
    <Nav variant={navVariant} />
    <main>
      <slot />
    </main>
    <Footer />
    <WaitlistModal />
    <ProgrammeModal />
    <CookieBanner />
  </body>
</html>
