---
import { Image } from 'astro:assets';
import tarikPhoto from '../assets/tarik-hennen.png';
import BaseLayout from './BaseLayout.astro';
import { articleSchema, breadcrumb } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date | undefined;
  category?: string | undefined;
  tags?: string[] | undefined;
  image?: string | undefined;
  imageAlt?: string | undefined;
  slug: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags,
  image,
  imageAlt,
  slug,
  headings = [],
} = Astro.props;

const formattedDate = new Intl.DateTimeFormat('fr-BE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(updatedDate ?? pubDate));

const datePrefix = updatedDate ? 'Mise à jour : ' : 'Publié le ';

const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3);

const schemas = [
  breadcrumb([
    { name: 'Blog', href: '/blog' },
    { name: title, href: `/blog/${slug}` },
  ]),
  articleSchema({
    title,
    description,
    url: `/blog/${slug}`,
    datePublished: new Date(pubDate).toISOString(),
    dateModified: updatedDate ? new Date(updatedDate).toISOString() : undefined,
    image: image ?? undefined,
  }),
];
---

<BaseLayout
  title={`${title} — Cercle IA`}
  description={description}
  ogImage={image ?? '/og/blog.jpg'}
  ogImageAlt={imageAlt ?? title}
  ogType="article"
  lcpImage={image ?? undefined}
  schema={schemas}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 72px 0 80px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -80px; right: -60px; width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.05) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">

      <!-- Breadcrumb -->
      <nav aria-label="Fil d'Ariane" style="margin-bottom: 32px; display: flex; align-items: center; gap: 8px; font-size: 13px; flex-wrap: wrap;">
        <a href="/" class="breadcrumb-link">Accueil</a>
        <span style="color: rgba(255,255,255,0.2);" aria-hidden="true">/</span>
        <a href="/blog" class="breadcrumb-link">Blog</a>
        <span style="color: rgba(255,255,255,0.2);" aria-hidden="true">/</span>
        <span style="color: rgba(255,255,255,0.5);">{title}</span>
      </nav>

      <div class={image ? "article-hero-grid" : ""} style={!image ? "max-width: 800px;" : ""}>

        <div>
          <!-- Badge catégorie -->
          {category && (
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 24px; flex-wrap: wrap;">
              <span class="tag">{category}</span>
            </div>
          )}

          <h1 style="font-family: var(--font-display); font-size: clamp(28px, 4vw, 50px); font-weight: 700; color: #ffffff; line-height: 1.1; letter-spacing: -0.025em; margin-bottom: 20px;">
            {title}
          </h1>

          <p style="font-size: 17px; color: rgba(255,255,255,0.5); line-height: 1.8; margin-bottom: 32px; max-width: 680px;">
            {description}
          </p>

          <!-- Meta auteur / date / tags -->
          <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.08);">
            <div style="display: flex; align-items: center; gap: 10px;">
              <Image
                src={tarikPhoto}
                alt="Tarik Hennen"
                width={36}
                height={36}
                loading="eager"
                style="border-radius: 50%; border: 1.5px solid rgba(247,171,110,0.4); object-fit: cover; flex-shrink: 0;"
              />
              <div>
                <p style="font-size: 14px; font-weight: 600; color: rgba(255,255,255,0.8); margin-bottom: 1px; line-height: 1;">Tarik Hennen</p>
                <p style="font-size: 12px; color: rgba(255,255,255,0.35); line-height: 1;">{datePrefix}{formattedDate}</p>
              </div>
            </div>

            {tags && tags.length > 0 && (
              <>
                <span style="width: 1px; height: 28px; background: rgba(255,255,255,0.1);" aria-hidden="true"></span>
                <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                  {tags.slice(0, 4).map((tag) => (
                    <span class="tag-outline" style="font-size: 10px; padding: 3px 8px;">{tag}</span>
                  ))}
                </div>
              </>
            )}
          </div>
        </div>

        {image && (
          <div class="article-hero-img">
            <img
              src={image}
              alt={imageAlt ?? title}
              width={748}
              height={420}
              loading="eager"
              style="width: 100%; height: auto; display: block; border-radius: var(--radius-lg);"
            />
          </div>
        )}

      </div>
    </div>
  </section>

  <!-- ========== CONTENU ========== -->
  <section style="background: var(--color-light-1); padding: 64px 0 88px;">
    <div class="container">
      <div class="article-layout">

        <!-- Sidebar table des matières -->
        {tocItems.length >= 3 && (
          <aside class="article-toc" aria-label="Dans cet article">
            <div class="toc-inner">
              <p style="font-size: 11px; font-weight: 600; color: rgba(6,24,23,0.4); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 14px;">Dans cet article</p>
              <nav>
                <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 2px;">
                  {tocItems.map((item) => (
                    <li style={`padding-left: ${item.depth === 3 ? '12px' : '0'};`}>
                      <a
                        href={`#${item.slug}`}
                        class="toc-link"
                        style={`font-size: ${item.depth === 2 ? '13px' : '12px'}; font-weight: ${item.depth === 2 ? '500' : '400'};`}
                      >
                        {item.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </aside>
        )}

        <!-- Corps de l'article -->
        <article class="article-prose">

          <slot />

          <!-- Footer tags -->
          {tags && tags.length > 0 && (
            <div style="margin-top: 48px; padding-top: 32px; border-top: 1px solid rgba(6,24,23,0.08); display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
              <span style="font-size: 12px; font-weight: 600; color: rgba(6,24,23,0.4); text-transform: uppercase; letter-spacing: 0.06em;">Tags</span>
              {tags.map((tag) => (
                <span style="background: rgba(6,24,23,0.06); border: 1px solid rgba(6,24,23,0.1); border-radius: var(--radius-pill); padding: 4px 12px; font-size: 12px; color: var(--color-text-muted);">{tag}</span>
              ))}
            </div>
          )}

        </article>

      </div>
    </div>
  </section>

  <!-- ========== BIOGRAPHIE AUTEUR ========== -->
  <section style="background: var(--color-dark-2); padding: 56px 0;">
    <div class="container" style="max-width: 860px;">
      <div class="card-white" style="display: flex; gap: 24px; align-items: flex-start;">
        <Image
          src={tarikPhoto}
          alt="Tarik Hennen"
          width={72}
          height={72}
          loading="lazy"
          style="border-radius: 50%; border: 2px solid rgba(247,171,110,0.3); object-fit: cover; flex-shrink: 0;"
        />
        <div>
          <p style="font-size: 11px; font-weight: 600; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px;">À propos de l'auteur</p>
          <p style="font-family: var(--font-display); font-size: 18px; font-weight: 700; color: var(--color-text-on-light); margin-bottom: 10px;">Tarik Hennen</p>
          <p style="font-size: 14px; color: var(--color-text-subtle); line-height: 1.75; margin-bottom: 18px;">
            Ancien avocat devenu entrepreneur, consultant en stratégie et marketing numérique. Fondateur du Cercle IA, il accompagne les professionnels du droit, du conseil et de la santé dans leur montée en compétence IA.
          </p>
          <a href="/a-propos" class="btn-outline-dark btn-sm">Voir le profil &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section style="background: var(--color-dark-1); padding: 80px 0;">
    <div class="container" style="text-align: center; max-width: 640px;">
      <span class="section-eyebrow">Cercle IA</span>
      <h2 class="section-title" style="margin-bottom: 16px;">Vous souhaitez en savoir plus ?</h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin-bottom: 32px;">
        Contactez-nous pour en discuter ou retrouvez tous nos articles sur le blog.
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href="/contact" class="btn-primary">Nous contacter &rarr;</a>
        <a href="/blog" class="btn-outline">Retour au blog</a>
      </div>
    </div>
  </section>

</BaseLayout>
