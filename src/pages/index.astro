---
import BaseLayout from '../layouts/BaseLayout.astro';
import { homepageGraph } from '../lib/schema';
import content from '../content/pages/fr/index.json';

const schema = homepageGraph();

const { meta, hero, features, usps, trainer, testimonials, resources, ctaFinal } = content;

const partnerLogos = [
  { src: '/images/logos/uclouvain.png', alt: 'UCLouvain' },
  { src: '/images/logos/ephec.png', alt: 'EPHEC' },
  { src: '/images/logos/ihecs.png', alt: 'IHECS' },
  { src: '/images/logos/akt-cci.png', alt: 'AKT CCI Liège' },
  { src: '/images/logos/wallonia.png', alt: 'Wallonia.be' },
  { src: '/images/logos/brussels-study-center.png', alt: 'Brussels Study Center' },
];
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  schema={schema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 96px 0 112px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.06) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      <div class="hero-inner">

        <!-- Contenu gauche -->
        <div>
          <div class="eyebrow-badge" style="margin-bottom: 28px; display: inline-flex;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
            {hero.eyebrow}
          </div>

          <h1 class="hero-title">
            {hero.title}<br />
            <span style="color: rgba(255,255,255,0.55);">{hero.titleMuted}</span>
          </h1>

          <p style="font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.75; max-width: 560px; margin-bottom: 36px;">
            {hero.description}
          </p>

          <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
            <a href={hero.ctaPrimaryHref} class="btn-primary">{hero.ctaPrimary}</a>
            <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline">{hero.ctaSecondary}</a>
          </div>
        </div>

        <!-- Visuel droit — diagramme flux formation -->
        <div class="hero-diagram-outer" style="padding-top: 36px;">
        <div class="hero-diagram-inner" style="position: relative; height: 440px;" aria-hidden="true">

          <!-- Lignes de connexion SVG -->
          <svg style="position: absolute; inset: 0; width: 100%; height: 100%;" viewBox="0 0 340 440" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <radialGradient id="fGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#F7AB6E" stop-opacity="0.1"/>
                <stop offset="100%" stop-color="#F7AB6E" stop-opacity="0"/>
              </radialGradient>
            </defs>

            <!-- Ambient glow -->
            <circle cx="168" cy="220" r="72" fill="url(#fGlow)"/>

            <!-- Pulse rings emanating from center node -->
            <circle cx="200" cy="220" r="4" fill="none" stroke="rgba(247,171,110,0.55)" stroke-width="1.5">
              <animate attributeName="r" values="4;32" dur="2.6s" repeatCount="indefinite" begin="0s"/>
              <animate attributeName="stroke-opacity" values="0.55;0" dur="2.6s" repeatCount="indefinite" begin="0s"/>
              <animate attributeName="stroke-width" values="1.5;0.3" dur="2.6s" repeatCount="indefinite" begin="0s"/>
            </circle>
            <circle cx="200" cy="220" r="4" fill="none" stroke="rgba(247,171,110,0.35)" stroke-width="1.5">
              <animate attributeName="r" values="4;32" dur="2.6s" repeatCount="indefinite" begin="1.3s"/>
              <animate attributeName="stroke-opacity" values="0.35;0" dur="2.6s" repeatCount="indefinite" begin="1.3s"/>
              <animate attributeName="stroke-width" values="1.5;0.3" dur="2.6s" repeatCount="indefinite" begin="1.3s"/>
            </circle>

            <!-- Left connector line -->
            <line x1="70" y1="220" x2="136" y2="220" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"/>

            <!-- Particles entering from left -->
            <circle r="2" fill="rgba(255,255,255,0.75)">
              <animateMotion path="M70,220 L136,220" dur="1.6s" repeatCount="indefinite" begin="0s"/>
              <animate attributeName="opacity" values="0;0.8;0.8;0" keyTimes="0;0.15;0.8;1" dur="1.6s" repeatCount="indefinite" begin="0s"/>
            </circle>
            <circle r="2" fill="rgba(255,255,255,0.75)">
              <animateMotion path="M70,220 L136,220" dur="1.6s" repeatCount="indefinite" begin="0.8s"/>
              <animate attributeName="opacity" values="0;0.8;0.8;0" keyTimes="0;0.15;0.8;1" dur="1.6s" repeatCount="indefinite" begin="0.8s"/>
            </circle>

            <!-- Right paths (glow layers) -->
            <path d="M200,220 C250,220 250,64 284,64"   stroke="#4B8EF7" stroke-width="5" stroke-opacity="0.1"/>
            <path d="M200,220 C238,220 238,143 284,143"  stroke="#F7AB6E" stroke-width="5" stroke-opacity="0.1"/>
            <path d="M200,220 L284,222"                   stroke="#5CB89A" stroke-width="5" stroke-opacity="0.1"/>
            <path d="M200,220 C238,220 238,301 284,301"  stroke="#22D3EE" stroke-width="5" stroke-opacity="0.1"/>
            <path d="M200,220 C250,220 250,380 284,380"  stroke="#A78BFA" stroke-width="5" stroke-opacity="0.1"/>

            <!-- Right paths (visible) -->
            <path d="M200,220 C250,220 250,64 284,64"   stroke="#4B8EF7" stroke-width="1.5"/>
            <path d="M200,220 C238,220 238,143 284,143"  stroke="#F7AB6E" stroke-width="1.5"/>
            <path d="M200,220 L284,222"                   stroke="#5CB89A" stroke-width="1.5"/>
            <path d="M200,220 C238,220 238,301 284,301"  stroke="#22D3EE" stroke-width="1.5"/>
            <path d="M200,220 C250,220 250,380 284,380"  stroke="#A78BFA" stroke-width="1.5"/>

            <!-- Center node -->
            <circle cx="200" cy="220" r="3.5" fill="rgba(255,255,255,0.2)"/>

            <!-- Output dots -->
            <circle cx="284" cy="64"  r="2.5" fill="#4B8EF7" fill-opacity="0.75"/>
            <circle cx="284" cy="143" r="2.5" fill="#F7AB6E" fill-opacity="0.75"/>
            <circle cx="284" cy="222" r="2.5" fill="#5CB89A" fill-opacity="0.75"/>
            <circle cx="284" cy="301" r="2.5" fill="#22D3EE" fill-opacity="0.75"/>
            <circle cx="284" cy="380" r="2.5" fill="#A78BFA" fill-opacity="0.75"/>

            <!-- Particles flowing outward on right paths -->
            <circle r="2.2" fill="#4B8EF7">
              <animateMotion path="M200,220 C250,220 250,64 284,64" dur="2.2s" repeatCount="indefinite" begin="0.2s"/>
              <animate attributeName="opacity" values="0;0.9;0.9;0" keyTimes="0;0.1;0.85;1" dur="2.2s" repeatCount="indefinite" begin="0.2s"/>
            </circle>
            <circle r="2.2" fill="#F7AB6E">
              <animateMotion path="M200,220 C238,220 238,143 284,143" dur="2s" repeatCount="indefinite" begin="0.8s"/>
              <animate attributeName="opacity" values="0;0.9;0.9;0" keyTimes="0;0.1;0.85;1" dur="2s" repeatCount="indefinite" begin="0.8s"/>
            </circle>
            <circle r="2.2" fill="#5CB89A">
              <animateMotion path="M200,220 L284,222" dur="1.4s" repeatCount="indefinite" begin="1.5s"/>
              <animate attributeName="opacity" values="0;0.9;0.9;0" keyTimes="0;0.1;0.85;1" dur="1.4s" repeatCount="indefinite" begin="1.5s"/>
            </circle>
            <circle r="2.2" fill="#22D3EE">
              <animateMotion path="M200,220 C238,220 238,301 284,301" dur="2s" repeatCount="indefinite" begin="0.5s"/>
              <animate attributeName="opacity" values="0;0.9;0.9;0" keyTimes="0;0.1;0.85;1" dur="2s" repeatCount="indefinite" begin="0.5s"/>
            </circle>
            <circle r="2.2" fill="#A78BFA">
              <animateMotion path="M200,220 C250,220 250,380 284,380" dur="2.2s" repeatCount="indefinite" begin="1.1s"/>
              <animate attributeName="opacity" values="0;0.9;0.9;0" keyTimes="0;0.1;0.85;1" dur="2.2s" repeatCount="indefinite" begin="1.1s"/>
            </circle>
          </svg>

          <!-- Nœud gauche — Pilule professions -->
          <div style="position: absolute; left: 0; top: 92px; border-radius: 48px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); display: flex; flex-direction: column; justify-content: space-evenly; align-items: center; padding: 10px 10px; box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.08);">
            <!-- Avocat -->
            <div style="display: flex; flex-direction: column; align-items: center; gap: 3px;">
              <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                  <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                </svg>
              </div>
              <p style="font-size: 8px; font-weight: 500; color: rgba(255,255,255,0.4); font-family: var(--font-body);">{hero.diagram.professions[0]}</p>
            </div>
            <!-- Médecin -->
            <div style="display: flex; flex-direction: column; align-items: center; gap: 3px;">
              <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/>
                  <path d="M12 8v4m0 4h.01"/>
                </svg>
              </div>
              <p style="font-size: 8px; font-weight: 500; color: rgba(255,255,255,0.4); font-family: var(--font-body);">{hero.diagram.professions[1]}</p>
            </div>
            <!-- Dirigeant -->
            <div style="display: flex; flex-direction: column; align-items: center; gap: 3px;">
              <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                  <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                </svg>
              </div>
              <p style="font-size: 8px; font-weight: 500; color: rgba(255,255,255,0.4); font-family: var(--font-body);">{hero.diagram.professions[2]}</p>
            </div>
            <!-- Consultant -->
            <div style="display: flex; flex-direction: column; align-items: center; gap: 3px;">
              <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="20" x2="18" y2="10"/>
                  <line x1="12" y1="20" x2="12" y2="4"/>
                  <line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
              </div>
              <p style="font-size: 8px; font-weight: 500; color: rgba(255,255,255,0.4); font-family: var(--font-body);">{hero.diagram.professions[3]}</p>
            </div>
            <!-- RH -->
            <div style="display: flex; flex-direction: column; align-items: center; gap: 3px;">
              <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
              </div>
              <p style="font-size: 8px; font-weight: 500; color: rgba(255,255,255,0.4); font-family: var(--font-body);">{hero.diagram.professions[4]}</p>
            </div>
          </div>

          <!-- Nœud central — Formation -->
          <div style="position: absolute; left: 136px; top: 188px; display: flex; flex-direction: column; align-items: center; gap: 7px;">
            <div style="width: 64px; height: 64px; border-radius: 16px; background: rgba(247,171,110,0.1); border: 1px solid rgba(247,171,110,0.28); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); display: flex; align-items: center; justify-content: center; box-shadow: 0 0 0 8px rgba(247,171,110,0.04), 0 8px 32px rgba(0,0,0,0.3);">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 10v6"/>
                <path d="M2 10l10-5 10 5-10 5z"/>
                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </div>
            <p style="font-size: 9px; font-weight: 600; color: rgba(247,171,110,0.6); font-family: var(--font-body); letter-spacing: 0.06em; text-transform: uppercase; white-space: nowrap;">{hero.diagram.centralLabel}</p>
          </div>

          <!-- Nœud sortie 1 — Outils (bleu) -->
          <div style="position: absolute; left: 284px; top: 40px; display: flex; flex-direction: column; align-items: center; gap: 6px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(75,142,247,0.1); border: 1px solid rgba(75,142,247,0.25); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(75,142,247,0.1);">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4B8EF7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 2 7 12 12 22 7 12 2"/>
                <polyline points="2 17 12 22 22 17"/>
                <polyline points="2 12 12 17 22 12"/>
              </svg>
            </div>
            <p style="font-size: 9px; font-weight: 500; color: rgba(255,255,255,0.35); font-family: var(--font-body);">{hero.diagram.outputs[0]}</p>
          </div>

          <!-- Nœud sortie 2 — Prompts (orange) -->
          <div style="position: absolute; left: 284px; top: 119px; display: flex; flex-direction: column; align-items: center; gap: 6px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(247,171,110,0.1); border: 1px solid rgba(247,171,110,0.25); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(247,171,110,0.1);">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#F7AB6E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="4 17 10 11 4 5"/>
                <line x1="12" y1="19" x2="20" y2="19"/>
              </svg>
            </div>
            <p style="font-size: 9px; font-weight: 500; color: rgba(255,255,255,0.35); font-family: var(--font-body);">{hero.diagram.outputs[1]}</p>
          </div>

          <!-- Nœud sortie 3 — Méthodes (vert) -->
          <div style="position: absolute; left: 284px; top: 198px; display: flex; flex-direction: column; align-items: center; gap: 6px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(92,184,154,0.1); border: 1px solid rgba(92,184,154,0.25); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(92,184,154,0.1);">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#5CB89A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7" rx="1"/>
                <rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="14" y="14" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/>
              </svg>
            </div>
            <p style="font-size: 9px; font-weight: 500; color: rgba(255,255,255,0.35); font-family: var(--font-body);">{hero.diagram.outputs[2]}</p>
          </div>

          <!-- Nœud sortie 4 — Éthique (teal) -->
          <div style="position: absolute; left: 284px; top: 277px; display: flex; flex-direction: column; align-items: center; gap: 6px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(34,211,238,0.1); border: 1px solid rgba(34,211,238,0.25); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(34,211,238,0.08);">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#22D3EE" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </div>
            <p style="font-size: 9px; font-weight: 500; color: rgba(255,255,255,0.35); font-family: var(--font-body);">{hero.diagram.outputs[3]}</p>
          </div>

          <!-- Nœud sortie 5 — Confiance (violet) -->
          <div style="position: absolute; left: 284px; top: 356px; display: flex; flex-direction: column; align-items: center; gap: 6px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(167,139,250,0.1); border: 1px solid rgba(167,139,250,0.25); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(167,139,250,0.1);">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <polyline points="9 12 11 14 15 10"/>
              </svg>
            </div>
            <p style="font-size: 9px; font-weight: 500; color: rgba(255,255,255,0.35); font-family: var(--font-body);">{hero.diagram.outputs[4]}</p>
          </div>

        </div>
        </div>

      </div>

      <!-- Logos partenaires (pleine largeur sous le grid) -->
      <div class="hero-logos">
        <span class="logos-label">{hero.logosLabel}</span>
        <div class="logos-marquee">
          <div class="logos-track">
            {partnerLogos.map((logo) => (
              <div class="logo-img-wrap">
                <img src={logo.src} alt={logo.alt} width="120" height="32" loading="eager" decoding="async" />
              </div>
            ))}
            {partnerLogos.map((logo) => (
              <div class="logo-img-wrap" aria-hidden="true">
                <img src={logo.src} alt="" width="120" height="32" loading="lazy" decoding="async" />
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ========== FEATURES ========== -->
  <section id="benefices" style="background: var(--color-light-1); padding: 96px 0;">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">{features.eyebrow}</span>
          <h2 class="section-title" style="color: var(--color-text-on-light);">{features.title}</h2>
        </div>
      </div>
      <div class="grid-3">
        {features.cards.map((f) => (
          <div class="card-white" style="display: flex; flex-direction: column;">
            <div class="icon-circle-glass" style="margin-bottom: 20px;">
              <span style="font-size: 18px; color: var(--color-accent);">{f.icon}</span>
            </div>
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== POURQUOI ========== -->
  <section id="pourquoi" style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <span class="section-eyebrow" style="display: block; margin-bottom: 40px;">{usps.eyebrow}</span>
      <div class="usps-grid">
        {usps.items.map((u) => (
          <div class="glass-card" style="display: flex; flex-direction: column;">
            <span class="usp-number">{u.n}</span>
            <h3 class="usp-title">{u.title}</h3>
            <p class="usp-desc">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== FORMATEUR ========== -->
  <section id="formateur" style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">
      <div class="grid-2" style="gap: 80px; align-items: start;">
        <div>
          <span class="section-eyebrow">{trainer.eyebrow}</span>
          <h2 style="font-family: var(--font-display); font-size: clamp(40px, 5vw, 64px); font-weight: 700; color: #ffffff; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 24px; margin-top: 4px;">{trainer.name}</h2>
          <div style="width: 36px; height: 2px; background: var(--color-accent); margin-bottom: 24px;"></div>
          <p style="font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.8; margin-bottom: 16px; max-width: 420px;">{trainer.bio}</p>
          <p style="font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.8; max-width: 420px; margin-bottom: 32px;">{trainer.quote}</p>
          <a href={trainer.ctaHref} class="btn-text-link">{trainer.cta} &rarr;</a>
        </div>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          {trainer.stats.map((s) => (
            <div class="glass-card" style="padding: 20px 24px; display: flex; align-items: center; gap: 20px;">
              <span class="stat-number" style="flex-shrink: 0;">{s.number}</span>
              <p class="stat-label" style="margin-top: 0;">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TÉMOIGNAGES ========== -->
  <section id="temoignages" style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">{testimonials.eyebrow}</span>
          <h2 class="section-title">{testimonials.title}</h2>
        </div>
      </div>
      <div class="grid-3" style="gap: 16px; align-items: start;">
        {testimonials.items.map((t) => (
          <div class="glass-card" style="display: flex; flex-direction: column; padding: 28px 28px 24px;">
            <!-- Guillemet décoratif -->
            <span style="font-family: var(--font-display); font-size: 48px; line-height: 1; color: var(--color-accent); opacity: 0.7; margin-bottom: 8px; display: block;">&ldquo;</span>
            <!-- Pull quote -->
            <p style="font-family: var(--font-display); font-size: 17px; font-weight: 700; color: #ffffff; line-height: 1.4; letter-spacing: -0.01em; margin-bottom: 12px; flex: 1;">{t.pull}</p>
            <!-- Corps optionnel -->
            {t.body && (
              <p style="font-family: var(--font-body); font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.7; margin-bottom: 0;">{t.body}</p>
            )}
            <!-- Attribution -->
            <div style="display: flex; align-items: center; gap: 10px; margin-top: 20px; padding-top: 18px; border-top: 1px solid rgba(255,255,255,0.07);">
              <div class="testimonial-avatar">{t.initials}</div>
              <div>
                <p style="font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.8); line-height: 1.3;">{t.name}</p>
                <p style="font-size: 11px; color: rgba(255,255,255,0.35); margin-top: 2px;">{t.role}, {t.org}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== RESSOURCES ========== -->
  <section id="ressources" style="background: var(--color-light-1); padding: 96px 0;">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">{resources.eyebrow}</span>
          <h2 class="section-title" style="color: var(--color-text-on-light);">{resources.title}</h2>
        </div>
      </div>
      <div class="grid-3">
        {resources.items.map((r) => (
          <div class="card-white" style="display: flex; flex-direction: column; gap: 12px; min-height: 200px;">
            <h3 class="ressource-title">{r.title}</h3>
            <p class="ressource-desc">{r.desc}</p>
            <a href={r.href} class="btn-text-link" style="margin-top: auto; font-size: 14px;">{r.cta} &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section id="contact-cta" class="grain-bg" style="background-color: var(--color-dark-2); padding: 96px 0;">
    <div class="container" style="text-align: center; max-width: 680px;">
      <div class="eyebrow-badge" style="margin-bottom: 28px; display: inline-flex;">
        <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
        {ctaFinal.badge}
      </div>
      <h2 style="font-family: var(--font-display); font-size: clamp(28px, 4vw, 44px); font-weight: 500; color: #ffffff; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 16px;">
        {ctaFinal.title}
      </h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.4); line-height: 1.7; margin-bottom: 36px;">
        {ctaFinal.description}
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href={ctaFinal.ctaPrimaryHref} class="btn-primary">{ctaFinal.ctaPrimary}</a>
        <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" target="_blank" rel="noopener noreferrer" class="btn-outline">{ctaFinal.ctaSecondary}</a>
      </div>
    </div>
  </section>

</BaseLayout>
