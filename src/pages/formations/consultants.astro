---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumb, courseSchema, faqSchema } from '../../lib/schema';

const bc = breadcrumb([
  { name: 'Formations IA', href: '/formations' },
  { name: 'Formation IA pour consultants', href: '/formations/consultants' },
]);

const course = courseSchema({
  name: 'Formation IA pour consultants',
  description: 'Accélérez vos livrables et automatisez la recherche sectorielle avec l\'IA. Formation pratique pour consultants, chefs de projet et analystes.',
  url: '/formations/consultants',
});

const faq = faqSchema([
  {
    question: 'La formation est-elle adaptée à mon secteur spécifique ?',
    answer: 'La formation couvre les méthodes transverses au conseil. Les exercices pratiques sont adaptés à votre secteur lors de la session. Nous organisons régulièrement des sessions dédiées à des secteurs spécifiques.',
  },
  {
    question: 'Ai-je besoin de compétences techniques ?',
    answer: 'Non. La formation s\'adresse aux consultants et analystes, pas aux développeurs. Tout est orienté usage métier avec des cas concrets de conseil.',
  },
  {
    question: 'Comment se déroulent les sessions ?',
    answer: 'Sessions en ligne ou en présentiel, en intra-cabinet ou en petit groupe. Exercices pratiques sur des cas réels de conseil tout au long de la formation.',
  },
  {
    question: 'Quelle est la différence avec le bootcamp IA ?',
    answer: 'Le bootcamp est généraliste (tous secteurs). La formation consultants est spécifiquement calibrée sur les tâches et livrables du conseil : recherche, analyse, rédaction de rapports et présentations.',
  },
]);

const schema = {
  '@context': 'https://schema.org',
  '@graph': [course, bc, faq],
};

const problemSolutionRows = [
  {
    problem: 'La recherche sectorielle et documentaire prend un temps disproportionné par rapport à la valeur créée.',
    solutionTitle: 'Synthèses sectorielles en quelques minutes',
    solutionDesc: 'Structurez votre recherche avec des prompts adaptés et obtenez des synthèses exploitables que vous validez avec votre expertise.',
  },
  {
    problem: 'Produire un premier livrable structuré prend des heures, même quand le fond est clair.',
    solutionTitle: 'Premiers drafts de qualité en 20 minutes',
    solutionDesc: 'Passez de la note de cadrage au rapport client avec l\'IA comme assistant de rédaction, en gardant le contrôle éditorial.',
  },
  {
    problem: 'Les benchmarks et analyses concurrentielles sont longs à construire manuellement.',
    solutionTitle: 'Analyses structurées et reproductibles',
    solutionDesc: 'Automatisez la collecte et la structuration de l\'information pour produire des analyses concurrentielles plus rapidement et plus systématiquement.',
  },
];

const modules = [
  {
    num: '01',
    title: 'Outils et méthodes pour le conseil',
    items: [
      'Panorama des outils IA pertinents pour les consultants',
      'Choisir le bon modèle selon la tâche',
      'Construire un environnement de travail IA efficace',
      'Gérer la confidentialité des données client',
    ],
  },
  {
    num: '02',
    title: 'Recherche et analyse sectorielle',
    items: [
      'Structurer une recherche documentaire avec l\'IA',
      'Synthétiser des rapports et études en quelques minutes',
      'Construire des benchmarks concurrentiels automatisés',
      'Veille sectorielle assistée et résumés personnalisés',
    ],
  },
  {
    num: '03',
    title: 'Rédaction de livrables et présentations',
    items: [
      'De la note de cadrage au rapport client avec l\'IA',
      'Structurer et rédiger des slides de présentation',
      'Templates de livrables adaptés à votre pratique',
      'Révision et contrôle qualité des outputs',
    ],
  },
];

const faqs = [
  {
    q: 'La formation est-elle adaptée à mon secteur spécifique ?',
    a: 'La formation couvre les méthodes transverses au conseil. Les exercices pratiques sont adaptés à votre secteur lors de la session. Nous organisons régulièrement des sessions dédiées à des secteurs spécifiques.',
  },
  {
    q: 'Ai-je besoin de compétences techniques ?',
    a: 'Non. La formation s\'adresse aux consultants et analystes, pas aux développeurs. Tout est orienté usage métier avec des cas concrets de conseil.',
  },
  {
    q: 'Comment se déroulent les sessions ?',
    a: 'Sessions en ligne ou en présentiel, en intra-cabinet ou en petit groupe. Exercices pratiques sur des cas réels de conseil tout au long de la formation.',
  },
  {
    q: 'Quelle est la différence avec le bootcamp IA ?',
    a: 'Le bootcamp est généraliste (tous secteurs). La formation consultants est spécifiquement calibrée sur les tâches et livrables du conseil : recherche, analyse, rédaction de rapports et présentations.',
  },
];
---

<BaseLayout
  title="Formation IA pour consultants — Cercle IA"
  description="Accélérez vos livrables et automatisez la recherche sectorielle avec l'IA. Formation pratique pour consultants et analystes, applicable dès la première mission."
  ogImage="/og/formations-consultants.jpg"
  ogImageAlt="Formation IA pour consultants — Cercle IA"
  schema={schema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 96px 0 112px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.06) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      <div class="hero-inner">

        <div>
          <div class="eyebrow-badge" style="margin-bottom: 28px; display: inline-flex;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
            Formation IA · Conseil
          </div>

          <h1 class="hero-title">
            Accélérez vos livrables<br />
            <span style="color: rgba(255,255,255,0.55);">sans sacrifier votre expertise.</span>
          </h1>

          <p style="font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.75; max-width: 560px; margin-bottom: 36px;">
            Recherche, analyse, rédaction de livrables — apprenez à utiliser l'IA pour aller plus vite sur les tâches à faible valeur ajoutée et vous concentrer sur ce qui fait votre différence.
          </p>

          <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 32px;">
            <a href="/contact?sujet=formation-consultants" class="btn-primary">Obtenir une formation sur mesure &rarr;</a>
            <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline">Planifier un appel</a>
          </div>

          <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
            <span style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.2); letter-spacing: 0.08em; text-transform: uppercase; margin-right: 4px; white-space: nowrap;">Pour</span>
            {['Consultants', 'Chefs de projet', 'Analystes', 'Freelances'].map((p) => (
              <span class="tag-outline" style="font-size: 10px; padding: 3px 10px;">{p}</span>
            ))}
          </div>
        </div>

        <div style="padding-top: 36px;">
          <div style="background: rgba(255,255,255,0.05); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.09); border-radius: var(--radius-xl); padding: 36px 32px;">
            <h2 style="font-family: var(--font-display); font-size: 26px; font-weight: 700; color: #ffffff; line-height: 1.2; letter-spacing: -0.015em; margin-bottom: 28px;">Détails de la formation</h2>
            <div style="display: flex; flex-direction: column; gap: 20px;">
              {[
                {
                  label: 'Durée adaptée à vos besoins',
                  icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
                },
                {
                  label: 'En ligne',
                  icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
                },
                {
                  label: 'Français',
                  icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
                },
                {
                  label: 'Applicable dès la première mission',
                  icon: '<polyline points="20 6 9 17 4 12"/>',
                },
              ].map((item) => (
                <div style="display: flex; align-items: center; gap: 16px;">
                  <div style="width: 40px; height: 40px; border-radius: 50%; background: rgba(247,171,110,0.12); border: 1px solid rgba(247,171,110,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
                  </div>
                  <p style="font-size: 15px; font-weight: 500; color: rgba(255,255,255,0.8); font-family: var(--font-body);">{item.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== PROBLÈME / SOLUTION ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">

      <div style="max-width: 720px; margin-bottom: 56px;">
        <span class="section-eyebrow">Pourquoi cette formation</span>
        <h2 class="section-title">Les frictions du consultant face à l'IA</h2>
        <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin-top: 20px;">
          Le conseil est un métier de synthèse et de livraison. L'IA peut transformer votre productivité — à condition de maîtriser les bonnes méthodes pour chaque type de tâche.
        </p>
      </div>

      <div style="background: var(--color-light-1); border-radius: calc(var(--radius-lg) + 4px); padding: 4px; box-shadow: 0 4px 32px rgba(0,0,0,0.3);">
      <div style="border: 1px solid rgba(6,24,23,0.1); border-radius: var(--radius-lg); overflow: hidden; display: grid; grid-template-columns: 1fr 1fr;">

        <div style="padding: 16px 28px; background: rgba(6,24,23,0.04); border-right: 1px solid rgba(6,24,23,0.08); border-bottom: 1px solid rgba(6,24,23,0.08);">
          <p style="font-size: 11px; font-weight: 600; color: rgba(6,24,23,0.4); letter-spacing: 0.1em; text-transform: uppercase;">Le problème</p>
        </div>
        <div style="padding: 16px 28px; background: rgba(247,171,110,0.1); border-bottom: 1px solid rgba(247,171,110,0.15);">
          <p style="font-size: 11px; font-weight: 600; color: var(--color-accent-hover); letter-spacing: 0.1em; text-transform: uppercase;">Ce que vous allez gagner</p>
        </div>

        {problemSolutionRows.map((row, i) => (
          <>
            <div style={`padding: 28px; background: rgba(6,24,23,0.02); border-right: 1px solid rgba(6,24,23,0.08); display: flex; gap: 14px; align-items: flex-start;${i < problemSolutionRows.length - 1 ? ' border-bottom: 1px solid rgba(6,24,23,0.06);' : ''}`}>
              <span style="width: 18px; height: 18px; border-radius: 50%; border: 1px solid rgba(6,24,23,0.2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 3px;">
                <span style="width: 5px; height: 5px; border-radius: 50%; background: rgba(6,24,23,0.3); display: block;"></span>
              </span>
              <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">{row.problem}</p>
            </div>
            <div style={`padding: 28px; background: rgba(247,171,110,0.05); display: flex; gap: 14px; align-items: flex-start;${i < problemSolutionRows.length - 1 ? ' border-bottom: 1px solid rgba(247,171,110,0.1);' : ''}`}>
              <span style="width: 18px; height: 18px; border-radius: 50%; background: rgba(247,171,110,0.25); border: 1px solid rgba(247,171,110,0.5); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 3px;">
                <span style="color: var(--color-accent-hover); font-size: 10px; font-weight: 700; line-height: 1;">✓</span>
              </span>
              <div>
                <p style="font-size: 15px; font-weight: 600; color: var(--color-text-on-light); line-height: 1.4; margin-bottom: 6px;">{row.solutionTitle}</p>
                <p style="font-size: 13px; color: var(--color-text-subtle); line-height: 1.75;">{row.solutionDesc}</p>
              </div>
            </div>
          </>
        ))}

      </div>
      </div>

    </div>
  </section>

  <!-- ========== PROGRAMME ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">

      <div style="max-width: 720px; margin-bottom: 48px;">
        <span class="section-eyebrow">Contenu de la formation</span>
        <h2 class="section-title">Ce que couvre la formation</h2>
      </div>

      <div class="grid-3" style="gap: 20px;">
        {modules.map((m) => (
          <div class="glass-card" style="display: flex; flex-direction: column; gap: 16px;">
            <span class="usp-number">{m.num}</span>
            <h3 class="usp-title">{m.title}</h3>
            <div style="display: flex; flex-direction: column; gap: 9px;">
              {m.items.map((item) => (
                <div style="display: flex; gap: 10px; align-items: flex-start;">
                  <span style="color: var(--color-accent); font-size: 12px; flex-shrink: 0; margin-top: 2px;">▸</span>
                  <p style="font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5;">{item}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ========== PRIX ========== -->
  <section id="inscription" style="background: var(--color-light-1); padding: 96px 0;">
    <div class="container">
      <div class="grid-2" style="gap: 56px; align-items: start;">

        <div>
          <span class="section-eyebrow">Format &amp; investissement</span>
          <h2 class="section-title" style="color: var(--color-text-on-light);">Tarification sur mesure</h2>
          <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.8; margin-top: 16px; margin-bottom: 32px;">
            Les tarifs sont adaptés selon la durée, le nombre de participants et vos besoins spécifiques. Nous vous aidons à choisir la formule adaptée à votre cabinet ou votre structure.
          </p>
          <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <a href="/contact?sujet=formation-consultants" class="btn-primary">Obtenir une formation sur mesure</a>
            <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline-dark">Planifier un appel</a>
          </div>
        </div>

        <div class="card-white">
          <p style="font-size: 11px; font-weight: 600; color: rgba(6,24,23,0.35); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Tarification sur mesure</p>
          <p style="font-family: var(--font-display); font-size: 26px; font-weight: 700; color: var(--color-text-on-light); line-height: 1.2; margin-bottom: 8px;">Adaptée à votre organisation</p>
          <p style="font-size: 13px; color: rgba(6,24,23,0.45); margin-bottom: 24px;">Tarifs selon la durée, le nombre de participants et le format choisi.</p>
          <div style="display: flex; flex-direction: column; gap: 10px;">
            {[
              'Modules adaptés à votre pratique',
              'Templates de livrables consultants',
              'Bibliothèque de prompts métier',
              'Module confidentialité données client',
              'Attestation de formation',
            ].map((item) => (
              <div style="display: flex; gap: 10px; align-items: center;">
                <span style="color: var(--color-accent); font-weight: 700; font-size: 14px; flex-shrink: 0;">✓</span>
                <p style="font-size: 14px; color: var(--color-text-subtle);">{item}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <div style="max-width: 760px; margin: 0 auto;">
        <span class="section-eyebrow">Questions fréquentes</span>
        <h2 class="section-title" style="margin-bottom: 48px;">Ce que se demandent les consultants avant de s'inscrire</h2>
        <div style="display: flex; flex-direction: column; gap: 16px;">
          {faqs.map((item) => (
            <div class="glass-card" style="padding: 0;">
              <details style="display: block;">
                <summary style="padding: 24px 28px; cursor: pointer; font-size: 15px; font-weight: 600; color: #ffffff; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 16px;">{item.q}</summary>
                <div style="padding: 0 28px 24px;">
                  <p style="font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.75;">{item.a}</p>
                </div>
              </details>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container" style="text-align: center; max-width: 680px;">
      <span class="section-eyebrow">Prêt à passer à la vitesse supérieure ?</span>
      <h2 class="section-title">Rejoignez les consultants qui livrent plus vite avec l'IA</h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin: 20px 0 32px;">
        Formation individuelle ou pour votre cabinet de conseil. Dès la première session, vous avez des méthodes applicables.
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href="/contact?sujet=formation-consultants" class="btn-primary">Obtenir une formation sur mesure &rarr;</a>
        <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline">Planifier un appel</a>
      </div>
    </div>
  </section>

</BaseLayout>
