---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumb, courseItemListSchema } from '../../lib/schema';
import content from '../../content/pages/fr/formations-index.json';

const { meta, hero, formationsGrid, bootcamp, surMesure, pourQui, testimonials, ctaFinal } = content;

// Mapping iconKey → SVG path (les paths restent dans le template)
const iconPaths: Record<string, string> = {
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  chart: '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
  users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  hr: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/><line x1="12" y1="11" x2="12" y2="21"/>',
  pulse: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
};

// Mapping iconKey → SVG path pour la info box du hero
const infoBoxIconPaths: string[] = [
  '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
];

const bc = breadcrumb([{ name: 'Formations IA', href: '/formations' }]);

const itemList = courseItemListSchema({
  name: meta.title,
  description: meta.description,
  items: formationsGrid.formations.map((f) => ({ name: f.title, description: f.desc, url: f.href })),
});

const schema = {
  '@context': 'https://schema.org',
  '@graph': [bc, itemList],
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  schema={schema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 96px 0 112px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.06) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      <div class="hero-inner">

        <!-- Contenu gauche -->
        <div>
          <div class="eyebrow-badge" style="margin-bottom: 28px; display: inline-flex;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
            {hero.eyebrow}
          </div>

          <h1 class="hero-title">
            {hero.title}<br />
            <span style="color: rgba(255,255,255,0.55);">{hero.titleMuted}</span>
          </h1>

          <p style="font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.75; max-width: 560px; margin-bottom: 36px;">
            {hero.description}
          </p>

          <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 32px;">
            <a href="#formations" class="btn-primary">{hero.ctaPrimary} &rarr;</a>
            <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline">{hero.ctaSecondary}</a>
          </div>
        </div>

        <!-- Box info à droite -->
        <div style="padding-top: 36px;">
          <div style="background: rgba(255,255,255,0.05); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.09); border-radius: var(--radius-xl); padding: 36px 32px;">
            <h2 style="font-family: var(--font-display); font-size: 26px; font-weight: 700; color: #ffffff; line-height: 1.2; letter-spacing: -0.015em; margin-bottom: 28px;">{hero.infoBox.title}</h2>
            <div style="display: flex; flex-direction: column; gap: 20px;">
              {hero.infoBox.items.map((label, i) => (
                <div style="display: flex; align-items: center; gap: 16px;">
                  <div style="width: 40px; height: 40px; border-radius: 50%; background: rgba(247,171,110,0.12); border: 1px solid rgba(247,171,110,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={infoBoxIconPaths[i]} />
                  </div>
                  <p style="font-size: 15px; font-weight: 500; color: rgba(255,255,255,0.8); font-family: var(--font-body);">{label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== GRILLE DES FORMATIONS ========== -->
  <section id="formations" style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">

      <div class="section-header">
        <div>
          <span class="section-eyebrow">{formationsGrid.eyebrow}</span>
          <h2 class="section-title">{formationsGrid.title}</h2>
        </div>
      </div>

      <div class="grid-3" style="gap: 20px;">
        {formationsGrid.formations.map((f) => (
          <div class="glass-card" style="display: flex; flex-direction: column; gap: 20px;">
            <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;">
              <span class="tag" style="flex-shrink: 0;">{f.tag}</span>
              <div style="width: 40px; height: 40px; border-radius: 50%; background: rgba(247,171,110,0.1); border: 1px solid rgba(247,171,110,0.2); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[f.iconKey]} />
              </div>
            </div>
            <div style="flex: 1; display: flex; flex-direction: column; gap: 10px;">
              <h3 style="font-family: var(--font-display); font-size: 19px; font-weight: 700; color: #ffffff; line-height: 1.3;">{f.title}</h3>
              <p style="font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.7;">{f.desc}</p>
            </div>
            <div style="padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.07);">
              <a href={f.href} style="font-size: 13px; font-weight: 600; color: var(--color-accent); text-decoration: none;">{f.cta} &rarr;</a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ========== BOOTCAMP ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">

      <div style="max-width: 680px; margin-bottom: 48px;">
        <span class="section-eyebrow">{bootcamp.eyebrow}</span>
        <h2 class="section-title">{bootcamp.title}</h2>
        <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin-top: 16px;">
          {bootcamp.description}
        </p>
      </div>

      <div class="glass-card" style="border-color: rgba(247,171,110,0.2); background: rgba(247,171,110,0.03); max-width: 860px;">
        <div style="display: grid; grid-template-columns: 1fr 280px; gap: 48px; align-items: center;">

          <div>
            <span class="tag" style="margin-bottom: 20px; display: inline-block;">{bootcamp.card.tag}</span>
            <h3 style="font-family: var(--font-display); font-size: 26px; font-weight: 700; color: #ffffff; line-height: 1.2; margin-bottom: 12px;">{bootcamp.card.title}</h3>
            <p style="font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.75; margin-bottom: 28px;">
              {bootcamp.card.description}
            </p>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
              <a href="#" data-open-modal="waitlist" class="btn-primary">{bootcamp.card.ctaWaitlist} &rarr;</a>
              <a href={bootcamp.card.ctaDetailHref} class="btn-outline">{bootcamp.card.ctaDetail}</a>
            </div>
          </div>

          <div style="display: flex; flex-direction: column; gap: 14px;">
            {bootcamp.card.details.map((item) => (
              <div style="display: flex; gap: 10px; align-items: center;">
                <span style="color: var(--color-accent); font-weight: 700; font-size: 12px; flex-shrink: 0;">&#9658;</span>
                <p style="font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.4;">{item}</p>
              </div>
            ))}
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ========== STATS + FORMAT ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">

      <div class="grid-2" style="gap: 80px; align-items: start;">

        <!-- Texte gauche -->
        <div>
          <span class="section-eyebrow">{surMesure.eyebrow}</span>
          <h2 class="section-title">{surMesure.title}</h2>
          <p style="font-size: 15px; color: rgba(255,255,255,0.5); line-height: 1.85; margin-top: 20px; margin-bottom: 32px;">
            {surMesure.description}
          </p>
          <a href={surMesure.ctaHref} class="btn-primary">{surMesure.cta} &rarr;</a>
        </div>

        <!-- Points clés droite -->
        <div style="display: flex; flex-direction: column; gap: 12px;">
          {surMesure.points.map((s) => (
            <div class="glass-card" style="padding: 20px 24px; display: flex; align-items: flex-start; gap: 16px;">
              <span style="color: var(--color-accent); font-size: 18px; flex-shrink: 0; margin-top: 2px;">&#9672;</span>
              <div>
                <p style="font-size: 15px; font-weight: 600; color: rgba(255,255,255,0.85); line-height: 1.3;">{s.title}</p>
                <p style="font-size: 13px; color: rgba(255,255,255,0.4); margin-top: 4px; line-height: 1.5;">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ========== POUR QUI ========== -->
  <section style="background: var(--color-light-1); padding: 96px 0;">
    <div class="container">

      <div style="max-width: 680px; margin-bottom: 56px;">
        <span class="section-eyebrow">{pourQui.eyebrow}</span>
        <h2 class="section-title" style="color: var(--color-text-on-light);">{pourQui.title}</h2>
      </div>

      <div class="grid-3" style="gap: 24px; margin-bottom: 48px;">
        {pourQui.profiles.map((p) => (
          <div class="card-white">
            <h3 style="font-family: var(--font-display); font-size: 20px; font-weight: 700; color: var(--color-text-on-light); margin-bottom: 12px;">{p.title}</h3>
            <p style="font-size: 14px; color: var(--color-text-subtle); line-height: 1.75;">{p.desc}</p>
          </div>
        ))}
      </div>

      <p style="text-align: center; font-size: 15px; color: var(--color-text-subtle); font-style: italic;">{pourQui.footnote}</p>

    </div>
  </section>

  <!-- ========== TEMOIGNAGES ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">{testimonials.eyebrow}</span>
          <h2 class="section-title">{testimonials.title}</h2>
        </div>
      </div>
      <div class="grid-3" style="gap: 16px; align-items: start;">
        {testimonials.items.map((t) => (
          <div class="glass-card" style="display: flex; flex-direction: column; padding: 28px 28px 24px;">
            <span style="font-family: var(--font-display); font-size: 48px; line-height: 1; color: var(--color-accent); opacity: 0.7; margin-bottom: 8px; display: block;">&ldquo;</span>
            <p style="font-family: var(--font-display); font-size: 17px; font-weight: 700; color: #ffffff; line-height: 1.4; letter-spacing: -0.01em; margin-bottom: 12px; flex: 1;">{t.pull}</p>
            {t.body && (
              <p style="font-family: var(--font-body); font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.7; margin-bottom: 0;">{t.body}</p>
            )}
            <div style="display: flex; align-items: center; gap: 10px; margin-top: 20px; padding-top: 18px; border-top: 1px solid rgba(255,255,255,0.07);">
              <div class="testimonial-avatar">{t.initials}</div>
              <div>
                <p style="font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.8); line-height: 1.3;">{t.name}</p>
                <p style="font-size: 11px; color: rgba(255,255,255,0.35); margin-top: 2px;">{t.role}, {t.org}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container" style="text-align: center; max-width: 680px;">
      <span class="section-eyebrow">{ctaFinal.eyebrow}</span>
      <h2 class="section-title">{ctaFinal.title}</h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin: 20px 0 32px;">
        {ctaFinal.description}
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-primary">{ctaFinal.ctaPrimary} &rarr;</a>
        <a href={ctaFinal.ctaSecondaryHref} class="btn-outline">{ctaFinal.ctaSecondary}</a>
      </div>
    </div>
  </section>

</BaseLayout>
