---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumb, courseSchema, faqSchema } from '../../lib/schema';
import content from '../../content/pages/fr/formations-medecins.json';

const bc = breadcrumb([
  { name: 'Formations IA', href: '/formations' },
  { name: 'Formation IA pour médecins', href: '/formations/medecins' },
]);

const course = courseSchema({
  name: 'Formation IA pour médecins',
  description: 'Formation IA transversale pour médecins : documentation clinique, veille scientifique, communication patient et gestion du cabinet. En présentiel, en ligne ou hybride, à partir de 2 heures.',
  url: '/formations/medecins',
});

const faq = faqSchema(
  content.faq.items.map((item) => ({ question: item.q, answer: item.a }))
);

const schema = {
  '@context': 'https://schema.org',
  '@graph': [course, bc, faq],
};
---

<BaseLayout
  title={content.meta.title}
  description={content.meta.description}
  ogImage={content.meta.ogImage}
  ogImageAlt={content.meta.ogImageAlt}
  schema={schema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 96px 0 112px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.06) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      <div class="hero-inner">

        <div>
          <div class="eyebrow-badge" style="margin-bottom: 28px; display: inline-flex;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
            {content.hero.eyebrow}
          </div>

          <h1 class="hero-title">
            {content.hero.title}<br />
            <span style="color: rgba(255,255,255,0.55);">{content.hero.titleMuted}</span>
          </h1>

          <p style="font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.75; max-width: 560px; margin-bottom: 36px;">
            {content.hero.description}
          </p>

          <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 32px;">
            <a href="/formations/sur-mesure" class="btn-primary">{content.hero.ctaPrimary} &rarr;</a>
            <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline">{content.hero.ctaSecondary}</a>
          </div>

          <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
            <span style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.2); letter-spacing: 0.08em; text-transform: uppercase; margin-right: 4px; white-space: nowrap;">Pour</span>
            {content.hero.audienceTags.map((p) => (
              <span class="tag-outline" style="font-size: 10px; padding: 3px 10px;">{p}</span>
            ))}
          </div>
        </div>

        <div style="padding-top: 36px;">
          <div style="background: rgba(255,255,255,0.05); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.09); border-radius: var(--radius-xl); padding: 36px 32px;">
            <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: #ffffff; line-height: 1.2; letter-spacing: -0.015em; margin-bottom: 20px;">{content.hero.infoBox.heading}</h2>
            <table style="width: 100%; border-collapse: collapse;">
              <tbody>
                {content.hero.infoBox.rows.map((row, i) => (
                  <tr style={i < content.hero.infoBox.rows.length - 1 ? 'border-bottom: 1px solid rgba(255,255,255,0.07);' : ''}>
                    <td style="padding: 12px 0; padding-right: 16px; font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.35); letter-spacing: 0.07em; text-transform: uppercase; white-space: nowrap; vertical-align: top;">{row.label}</td>
                    <td style="padding: 12px 0; font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.8); line-height: 1.4;">{row.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== SITUATIONS IDENTIFIÉES ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">

      <div style="max-width: 720px; margin-bottom: 56px;">
        <span class="section-eyebrow">{content.situations.eyebrow}</span>
        <h2 class="section-title">{content.situations.title}</h2>
      </div>

      <div class="grid-2" style="gap: 20px;">
        {content.situations.items.map((text) => (
          <div class="glass-card" style="display: flex; gap: 14px; align-items: flex-start;">
            <span style="width: 20px; height: 20px; border-radius: 50%; background: rgba(247,171,110,0.15); border: 1px solid rgba(247,171,110,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;">
              <span style="color: var(--color-accent); font-size: 10px; font-weight: 700; line-height: 1;">&#10003;</span>
            </span>
            <p style="font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.75;">{text}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ========== POSITIONNEMENT ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">

      <div style="max-width: 760px; margin: 0 auto 56px; text-align: center;">
        <span class="section-eyebrow">{content.pillars.eyebrow}</span>
        <h2 class="section-title">{content.pillars.title}</h2>
        <p style="font-size: 17px; color: rgba(255,255,255,0.5); line-height: 1.85; margin-top: 20px;">
          {content.pillars.subtitle}
        </p>
      </div>

      <div class="grid-2" style="gap: 20px;">
        {content.pillars.items.map((p) => (
          <div class="glass-card" style="display: flex; flex-direction: column; gap: 14px;">
            <span class="usp-number">{p.num}</span>
            <h3 class="usp-title">{p.title}</h3>
            <p style="font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.75;">{p.desc}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ========== CAS D'USAGE ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">

      <div style="max-width: 720px; margin-bottom: 48px;">
        <span class="section-eyebrow">{content.modules.eyebrow}</span>
        <h2 class="section-title">{content.modules.title}</h2>
      </div>

      <div class="grid-3" style="gap: 20px;">
        {content.modules.items.map((m) => (
          <div class="glass-card" style="display: flex; flex-direction: column; gap: 16px;">
            <span class="usp-number">{m.num}</span>
            <h3 class="usp-title">{m.title}</h3>
            <div style="display: flex; flex-direction: column; gap: 9px;">
              {m.items.map((item) => (
                <div style="display: flex; gap: 10px; align-items: flex-start;">
                  <span style="color: var(--color-accent); font-size: 12px; flex-shrink: 0; margin-top: 2px;">&#9658;</span>
                  <p style="font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5;">{item}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ========== FORMAT & TARIFICATION ========== -->
  <section style="background: var(--color-light-1); padding: 96px 0;">
    <div class="container">
      <div class="grid-2" style="gap: 56px; align-items: start;">

        <div>
          <span class="section-eyebrow">{content.pricing.eyebrow}</span>
          <h2 class="section-title" style="color: var(--color-text-on-light);">{content.pricing.title}</h2>
          <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.8; margin-top: 16px; margin-bottom: 32px;">
            {content.pricing.description}
          </p>
          <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <a href="/formations/sur-mesure" class="btn-primary">{content.pricing.ctaPrimary}</a>
            <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline-dark">{content.pricing.ctaSecondary}</a>
          </div>
        </div>

        <div class="card-white">
          <p style="font-size: 11px; font-weight: 600; color: rgba(6,24,23,0.35); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">{content.pricing.card.label}</p>
          <p style="font-family: var(--font-display); font-size: 26px; font-weight: 700; color: var(--color-text-on-light); line-height: 1.2; margin-bottom: 8px;">{content.pricing.card.heading}</p>
          <p style="font-size: 13px; color: rgba(6,24,23,0.45); margin-bottom: 24px;">{content.pricing.card.subtitle}</p>
          <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px;">
            {content.pricing.card.includes.map((item) => (
              <div style="display: flex; gap: 10px; align-items: center;">
                <span style="color: var(--color-accent); font-weight: 700; font-size: 14px; flex-shrink: 0;">&#10003;</span>
                <p style="font-size: 14px; color: var(--color-text-subtle);">{item}</p>
              </div>
            ))}
          </div>
          <a href={content.pricing.card.ctaCardHref} class="btn-primary" style="display: inline-block;">{content.pricing.card.ctaCard}</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <div style="max-width: 760px; margin: 0 auto;">
        <span class="section-eyebrow">{content.faq.eyebrow}</span>
        <h2 class="section-title" style="margin-bottom: 48px;">{content.faq.title}</h2>
        <div style="display: flex; flex-direction: column; gap: 16px;">
          {content.faq.items.map((item) => (
            <div class="glass-card" style="padding: 0;">
              <details style="display: block;">
                <summary style="padding: 24px 28px; cursor: pointer; font-size: 15px; font-weight: 600; color: #ffffff; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 16px;">{item.q}</summary>
                <div style="padding: 0 28px 24px;">
                  <p style="font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.75;">{item.a}</p>
                </div>
              </details>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container" style="text-align: center; max-width: 680px;">
      <span class="section-eyebrow">{content.ctaFinal.eyebrow}</span>
      <h2 class="section-title">{content.ctaFinal.title}</h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin: 20px 0 32px;">
        {content.ctaFinal.description}
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href="/formations/sur-mesure" class="btn-primary">{content.ctaFinal.ctaPrimary} &rarr;</a>
        <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline">{content.ctaFinal.ctaSecondary}</a>
      </div>
    </div>
  </section>

</BaseLayout>
