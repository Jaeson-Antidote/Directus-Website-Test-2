---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumb } from '../../lib/schema';
import content from '../../content/pages/fr/formations-sur-mesure.json';

const bc = breadcrumb([
  { name: 'Formations', href: '/formations' },
  { name: 'Formation sur mesure', href: '/formations/sur-mesure' },
]);

const schema = {
  '@context': 'https://schema.org',
  '@graph': [bc],
};
---

<BaseLayout
  title={content.meta.title}
  description={content.meta.description}
  ogImage={content.meta.ogImage}
  ogImageAlt={content.meta.ogImageAlt}
  schema={schema}
>

  <section style="background: var(--color-dark-1); min-height: 100vh; padding: 80px 0 96px;">
    <div class="container" style="max-width: 720px;">

      <!-- En-tête compact -->
      <div style="text-align: center; margin-bottom: 48px;">
        <div class="eyebrow-badge" style="display: inline-flex; margin-bottom: 20px;">
          <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
          {content.header.eyebrow}
        </div>

        <h1 style="font-family: var(--font-display); font-size: clamp(28px, 3.5vw, 44px); font-weight: 700; color: #ffffff; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 16px;">
          {content.header.title}<br />
          <span style="color: var(--color-accent);">{content.header.titleAccent}</span>
        </h1>

        <p style="font-size: 17px; color: rgba(255,255,255,0.55); line-height: 1.7; max-width: 520px; margin: 0 auto;">
          {content.header.description}
        </p>
      </div>

      <!-- Formulaire -->
      <div class="glass-card" style="padding: 48px; border-radius: 20px;">
        <!-- État succès -->
        <div id="surMesure-success" hidden style="display: flex; flex-direction: column; align-items: center; gap: 16px; padding: 40px 0; text-align: center;">
          <span style="width: 56px; height: 56px; border-radius: 50%; background: rgba(247,171,110,0.15); border: 1px solid rgba(247,171,110,0.3); display: flex; align-items: center; justify-content: center; font-size: 24px; color: var(--color-accent);">&#10003;</span>
          <h3 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: #ffffff; margin: 0;">Demande envoyée !</h3>
          <p style="font-size: 15px; color: rgba(255,255,255,0.55); margin: 0;">Nous vous recontacterons dans les 48h pour discuter de votre projet.</p>
        </div>

        <form
          id="surMesure-form"
          name="formation-sur-mesure"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          style="display: flex; flex-direction: column; gap: 20px;"
        >
          <input type="hidden" name="form-name" value="formation-sur-mesure" />
          <input type="hidden" name="bot-field" />

          <!-- Prénom / Nom -->
          <div class="grid-2" style="gap: 16px;">
            <div>
              <label for="prenom" class="form-label">{content.form.fields.prenom.label}</label>
              <input id="prenom" type="text" name="prenom" placeholder={content.form.fields.prenom.placeholder} required class="input-dark" />
            </div>
            <div>
              <label for="nom" class="form-label">{content.form.fields.nom.label}</label>
              <input id="nom" type="text" name="nom" placeholder={content.form.fields.nom.placeholder} class="input-dark" />
            </div>
          </div>

          <!-- Email / Téléphone -->
          <div class="grid-2" style="gap: 16px;">
            <div>
              <label for="email" class="form-label">{content.form.fields.email.label}</label>
              <input id="email" type="email" name="email" placeholder={content.form.fields.email.placeholder} required class="input-dark" />
            </div>
            <div>
              <label for="telephone" class="form-label">{content.form.fields.telephone.label}</label>
              <input id="telephone" type="tel" name="telephone" placeholder={content.form.fields.telephone.placeholder} class="input-dark" />
            </div>
          </div>

          <!-- Métier / Entreprise -->
          <div class="grid-2" style="gap: 16px;">
            <div>
              <label for="metier" class="form-label">{content.form.fields.metier.label}</label>
              <select id="metier" name="metier" required class="input-dark">
                <option value="" disabled selected>Sélectionner</option>
                {content.form.metierOptions.map((m) => <option value={m}>{m}</option>)}
              </select>
            </div>
            <div>
              <label for="entreprise" class="form-label">{content.form.fields.entreprise.label}</label>
              <input id="entreprise" type="text" name="entreprise" placeholder={content.form.fields.entreprise.placeholder} class="input-dark" />
            </div>
          </div>

          <!-- Nombre d'employés / Fonction -->
          <div class="grid-2" style="gap: 16px;">
            <div>
              <label for="taille" class="form-label">{content.form.fields.taille.label}</label>
              <select id="taille" name="taille" class="input-dark">
                <option value="" disabled selected>Sélectionner</option>
                {content.form.tailleOptions.map((t) => <option value={t}>{t}</option>)}
              </select>
            </div>
            <div>
              <label for="fonction" class="form-label">{content.form.fields.fonction.label}</label>
              <input id="fonction" type="text" name="fonction" placeholder={content.form.fields.fonction.placeholder} class="input-dark" />
            </div>
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="form-label">{content.form.fields.message.label}</label>
            <textarea
              id="message"
              name="message"
              placeholder={content.form.fields.message.placeholder}
              rows="5"
              class="input-dark"
              style="resize: vertical;"
            ></textarea>
          </div>

          <!-- RGPD -->
          <label style="display: flex; align-items: flex-start; gap: 12px; cursor: pointer;">
            <input type="checkbox" name="rgpd" required />
            <span style="font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.6;">
              {content.form.rgpdText}
              <a href="/politique-confidentialite" style="color: rgba(255,255,255,0.65); text-decoration: underline;">{content.form.rgpdLinkText}</a>.
            </span>
          </label>

          <!-- Submit -->
          <p id="surMesure-error" hidden style="font-size: 13px; color: #f87171; text-align: center; margin: 0;">Une erreur est survenue. Veuillez réessayer.</p>

          <div style="margin-top: 8px;">
            <button type="submit" id="surMesure-submit" class="btn-primary" style="width: 100%; justify-content: center; font-size: 17px; padding: 18px 32px;">
              {content.form.submitLabel} &rarr;
            </button>
          </div>
        </form>
      </div>

      <!-- Réassurance -->
      <div style="display: flex; gap: 32px; justify-content: center; margin-top: 40px; flex-wrap: wrap;">
        {content.reassurances.map((r) => (
          <div style="font-size: 14px; color: rgba(255,255,255,0.5);">&#10003; {r}</div>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  const form = document.getElementById('surMesure-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('surMesure-submit') as HTMLButtonElement | null;
  const errorMsg = document.getElementById('surMesure-error');
  const successState = document.getElementById('surMesure-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    if (submitBtn) {
      submitBtn.textContent = 'Envoi en cours…';
      submitBtn.disabled = true;
    }
    errorMsg?.setAttribute('hidden', '');

    try {
      const res = await fetch(window.location.pathname, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
      });
      if (res.ok) {
        form.setAttribute('hidden', '');
        successState?.removeAttribute('hidden');
      } else {
        throw new Error('Erreur réseau');
      }
    } catch {
      errorMsg?.removeAttribute('hidden');
      if (submitBtn) {
        submitBtn.textContent = 'Envoyer →';
        submitBtn.disabled = false;
      }
    }
  });
</script>
