---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumb } from '../lib/schema';
import content from '../content/pages/fr/contact.json';

const bc = breadcrumb([{ name: 'Contact', href: '/contact' }]);

const schema = {
  '@context': 'https://schema.org',
  '@graph': [bc],
};
---

<BaseLayout
  title={content.meta.title}
  description={content.meta.description}
  ogImage={content.meta.ogImage}
  ogImageAlt={content.meta.ogImageAlt}
  schema={schema}
>

  <!-- HERO -->
  <section class="hero-gradient grain-bg" style="padding: 80px 0 64px;">
    <div class="container" style="max-width: 720px; text-align: center;">
      <div class="eyebrow-badge" style="display: inline-flex; margin-bottom: 20px;">
        <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
        {content.hero.eyebrow}
      </div>
      <h1 style="font-family: var(--font-display); font-size: clamp(32px, 4vw, 52px); font-weight: 700; color: #ffffff; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 20px;">
        {content.hero.title}
      </h1>
      <p style="font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.75; max-width: 520px; margin: 0 auto;">
        {content.hero.description}
      </p>
    </div>
  </section>

  <!-- SECTION: Formulaire + Infos -->
  <section style="background: var(--color-dark-1); padding: 80px 0 96px;">
    <div class="container">
      <div class="grid-2" style="gap: 56px; align-items: start;">

        <!-- Formulaire -->
        <div>
          <h2 style="font-family: var(--font-display); font-size: 28px; font-weight: 700; color: #ffffff; margin-bottom: 32px;">{content.form.title}</h2>
          <div class="glass-card" style="padding: 40px;">
            <form
              name="contact"
              method="POST"
              data-netlify="true"
              style="display: flex; flex-direction: column; gap: 20px;"
            >
              <input type="hidden" name="form-name" value="contact" />

              <div class="grid-2" style="gap: 16px;">
                <div>
                  <label for="prenom" class="form-label">{content.form.fields.prenom.label}</label>
                  <input id="prenom" type="text" name="prenom" placeholder={content.form.fields.prenom.placeholder} class="input-dark" />
                </div>
                <div>
                  <label for="nom" class="form-label">{content.form.fields.nom.label}</label>
                  <input id="nom" type="text" name="nom" placeholder={content.form.fields.nom.placeholder} class="input-dark" />
                </div>
              </div>

              <div>
                <label for="email" class="form-label">{content.form.fields.email.label}</label>
                <input id="email" type="email" name="email" placeholder={content.form.fields.email.placeholder} required class="input-dark" />
              </div>

              <div>
                <label for="organisation" class="form-label">{content.form.fields.organisation.label}</label>
                <input id="organisation" type="text" name="organisation" placeholder={content.form.fields.organisation.placeholder} class="input-dark" />
              </div>

              <div>
                <label for="message" class="form-label">{content.form.fields.message.label}</label>
                <textarea
                  id="message"
                  name="message"
                  placeholder={content.form.fields.message.placeholder}
                  rows="5"
                  required
                  class="input-dark"
                  style="resize: vertical;"
                ></textarea>
              </div>

              <div style="margin-top: 8px;">
                <button type="submit" class="btn-primary" style="width: 100%; justify-content: center; font-size: 17px; padding: 18px 32px;">
                  {content.form.submitLabel} &rarr;
                </button>
              </div>
            </form>
          </div>
        </div>

        <!-- Infos -->
        <div style="display: flex; flex-direction: column; gap: 20px; padding-top: 72px;">
          <div class="glass-card">
            <p style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.3); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px;">{content.infos.adresse.label}</p>
            <p style="font-size: 15px; color: rgba(255,255,255,0.75); line-height: 1.6;">{content.infos.adresse.value}</p>
          </div>

          <div class="glass-card">
            <p style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.3); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px;">{content.infos.pourQui.label}</p>
            <div style="display: flex; flex-direction: column; gap: 8px;">
              {content.infos.pourQui.items.map((item) => (
                <div style="display: flex; gap: 10px; align-items: flex-start;">
                  <span style="color: var(--color-accent); font-size: 12px; flex-shrink: 0; margin-top: 2px;">&#9658;</span>
                  <p style="font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.5;">{item}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="glass-card">
            <p style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.3); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px;">{content.infos.legal.label}</p>
            <p style="font-size: 14px; color: rgba(255,255,255,0.5);">{content.infos.legal.value}</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SECTION: Pas encore prêt ? -->
  <section style="background: var(--color-light-1); padding: 80px 0;">
    <div class="container">
      <div style="max-width: 720px; margin-bottom: 40px;">
        <h2 class="section-title" style="color: var(--color-text-on-light);">{content.pasEncorePret.title}</h2>
      </div>
      <div class="grid-3" style="gap: 20px;">
        {content.pasEncorePret.cards.map((card) => (
          <a href={card.href} class="card-white" style="display: block; text-decoration: none;">
            <p style="font-family: var(--font-display); font-size: 18px; font-weight: 700; color: var(--color-text-on-light);">{card.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
