---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumb } from '../lib/schema';
import content from '../content/pages/fr/ressources-ia.json';

const schema = breadcrumb([{ name: 'Outils IA', href: '/ressources-ia' }]);
---

<BaseLayout
  title={content.meta.title}
  description={content.meta.description}
  ogImage={content.meta.ogImage}
  ogImageAlt={content.meta.ogImageAlt}
  schema={schema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 56px 0 48px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.05) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>
    <div class="container">
      <div class="eyebrow-badge" style="margin-bottom: 20px; display: inline-flex;">
        <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
        {content.hero.eyebrow}
      </div>
      <h1 class="hero-title" style="max-width: 640px; margin: 0;">
        {content.hero.title}
      </h1>
    </div>
  </section>

  <!-- ========== ANNUAIRE ========== -->
  <section style="background: var(--color-light-1); padding: 48px 0 80px;">
    <div class="container">
      <script is:inline src="https://spread.name/js/widget.js"></script>
      <div data-ss-widget data-id="vg3566y"></div>
    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container" style="text-align: center; max-width: 680px;">
      <span class="section-eyebrow">{content.ctaFinal.eyebrow}</span>
      <h2 class="section-title">{content.ctaFinal.title}</h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin: 20px 0 32px;">
        Les outils donnent les moyens. Les formations vous donnent la méthode, les cas d'usage et le suivi pour vraiment intégrer l'IA dans votre pratique.
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href={content.ctaFinal.ctaPrimaryHref} class="btn-primary">{content.ctaFinal.ctaPrimary} &rarr;</a>
        <a href={content.ctaFinal.ctaSecondaryHref} class="btn-outline">{content.ctaFinal.ctaSecondary}</a>
      </div>
    </div>
  </section>

</BaseLayout>
