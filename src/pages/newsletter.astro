---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumb } from '../lib/schema';
import { getCollection } from 'astro:content';

const schema = breadcrumb([{ name: 'Newsletter', href: '/newsletter' }]);

const allEditions = (await getCollection('newsletter', ({ data }) => !data.draft))
  .sort((a, b) => {
    const dateA = new Date(a.data.updatedDate ?? a.data.pubDate).getTime();
    const dateB = new Date(b.data.updatedDate ?? b.data.pubDate).getTime();
    return dateB - dateA;
  });

const newsletterImages = import.meta.glob<{ default: ImageMetadata }>('../assets/newsletter/*', { eager: true });
---

<BaseLayout
  title="Newsletter IA — Cercle IA"
  description="Analyses, tendances et ressources pratiques sur l'IA professionnelle. Tous les 15 jours, pour les professionnels qui veulent garder une longueur d'avance."
  ogImage="/og/newsletter.jpg"
  ogImageAlt="Newsletter IA — Cercle IA"
  schema={schema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 64px 0 72px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.05) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      <div class="hero-inner" style="align-items: center;">

        <!-- Gauche : texte + stats -->
        <div>
          <div class="eyebrow-badge" style="margin-bottom: 20px; display: inline-flex;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
            Newsletter Cercle IA
          </div>

          <h1 style="font-family: var(--font-display); font-size: clamp(28px, 4vw, 42px); font-weight: 700; color: #ffffff; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 16px;">
            L'IA entre de bonnes mains.<br />
            <span style="color: rgba(255,255,255,0.5);">Les vôtres.</span>
          </h1>

          <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.75; max-width: 500px; margin-bottom: 32px;">
            Tous les 15 jours, une analyse actionnable : tendances filtrées, outils testés, cas d'usage concrets. Pour les professionnels qui veulent comprendre avant d'adopter.
          </p>

          <!-- Stats -->
          <div style="display: flex; gap: 32px; flex-wrap: wrap;">
            {[
              { number: '1000+', label: 'Abonnés' },
              { number: '2×', label: 'Par mois' },
              { number: '100%', label: 'Gratuit' },
            ].map((s) => (
              <div>
                <p style="font-family: var(--font-display); font-size: 26px; font-weight: 700; color: var(--color-accent); line-height: 1;">{s.number}</p>
                <p style="font-size: 12px; color: rgba(255,255,255,0.35); margin-top: 4px; font-family: var(--font-body);">{s.label}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Droite : card LinkedIn style -->
        <div style="padding-top: 0; display: flex; justify-content: center;">
          <div style="background: #ffffff; border-radius: 16px; padding: 28px; width: 100%; max-width: 360px; box-shadow: 0 8px 40px rgba(0,0,0,0.25);">

            <!-- Logo + label -->
            <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px;">
              <div style="width: 64px; height: 64px; border-radius: 10px; background: #061717; display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden;">
                <img
                  src="/images/cercle-ia-logo.svg"
                  alt="Cercle IA"
                  width="44"
                  height="12"
                  loading="eager"
                  decoding="async"
                />
              </div>
              <div>
                <div style="display: flex; align-items: center; gap: 5px; margin-bottom: 3px;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(0,0,0,0.4)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2z"/><path d="M4 6H2v16c0 1.1.9 2 2 2h16v-2H4V6z"/><line x1="10" y1="9" x2="18" y2="9"/><line x1="10" y1="13" x2="18" y2="13"/><line x1="10" y1="17" x2="14" y2="17"/>
                  </svg>
                  <span style="font-size: 11px; font-weight: 600; color: rgba(0,0,0,0.45); letter-spacing: 0.07em; text-transform: uppercase; font-family: var(--font-body);">Newsletter</span>
                </div>
                <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: #0d1e1e; line-height: 1; margin: 0;">Cercle IA</h2>
              </div>
            </div>

            <p style="font-size: 13px; color: rgba(0,0,0,0.55); line-height: 1.65; margin-bottom: 20px; font-family: var(--font-body);">
              Une newsletter pour anticiper les révolutions de l'IA plutôt que de les subir. Analyses, études de cas et outils.
            </p>

            <a
              href="https://www.linkedin.com/newsletters/cercle-ia-7353754146262401025/"
              target="_blank"
              rel="noopener noreferrer"
              style="display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 12px 20px; background: #0A66C2; color: #ffffff; border-radius: 30px; font-family: var(--font-body); font-size: 14px; font-weight: 600; text-decoration: none; transition: background 0.15s;"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              S'abonner sur LinkedIn
            </a>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== ARCHIVES ========== -->
  <section id="archives" style="background: var(--color-light-1); padding: 80px 0 96px;">
    <div class="container">

      <div style="margin-bottom: 48px;">
        <span class="section-eyebrow">Toutes les éditions</span>
        <h2 class="section-title" style="color: var(--color-text-on-light);">Archives de la newsletter</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7; margin-top: 12px;">
          Chaque édition est disponible en lecture libre.
        </p>
      </div>

      {allEditions.length > 0 ? (
        <div class="blog-grid">
          {allEditions.map((ed) => {
            const displayDate = ed.data.updatedDate ?? ed.data.pubDate;
            const dateLabel = ed.data.updatedDate ? 'Mis à jour ' : '';
            const date = dateLabel + new Intl.DateTimeFormat('fr-BE', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(displayDate));
            const imgFile = ed.data.image?.split('/').pop();
            const imageMetadata = imgFile ? newsletterImages[`../assets/newsletter/${imgFile}`]?.default : undefined;
            return (
              <a href={`/newsletter/${ed.id}`} class="newsletter-card" style="text-decoration: none; display: flex; flex-direction: column;">

                {imageMetadata ? (
                  <div class="newsletter-card-img">
                    <Image
                      src={imageMetadata}
                      alt={ed.data.imageAlt ?? ed.data.title}
                      width={960}
                      height={540}
                      style="width: 100%; height: 100%; object-fit: cover; display: block;"
                    />
                  </div>
                ) : (
                  <div class="newsletter-card-img newsletter-card-img--placeholder" aria-hidden="true"></div>
                )}

                <div class="blog-card-body">
                  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap;">
                    {ed.data.edition && (
                      <span class="tag" style="font-size: 10px; padding: 3px 10px;">#{ed.data.edition}</span>
                    )}
                    <span style="font-size: 12px; color: var(--color-text-subtle);">{date}</span>
                  </div>
                  <h3 style="font-family: var(--font-display); font-size: 19px; font-weight: 700; color: var(--color-text-on-light); line-height: 1.35; margin-bottom: 16px; flex: 1;">{ed.data.title}</h3>
                  <div style="display: flex; justify-content: flex-end;">
                    <span style="font-size: 13px; font-weight: 600; color: var(--color-accent); white-space: nowrap;">Lire &rarr;</span>
                  </div>
                </div>

              </a>
            );
          })}
        </div>
      ) : (
        <div class="card-white" style="max-width: 480px; text-align: center; padding: 48px 40px; margin: 0 auto;">
          <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7; margin-bottom: 24px;">Les premières éditions seront publiées très prochainement. Abonnez-vous pour être notifié.</p>
          <a href="https://www.linkedin.com/newsletters/cercle-ia-7353754146262401025/" target="_blank" rel="noopener noreferrer" class="btn-primary">S'abonner sur LinkedIn &rarr;</a>
        </div>
      )}

    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section style="background: var(--color-dark-1); padding: 80px 0;">
    <div class="container" style="text-align: center; max-width: 600px;">
      <h2 class="section-title">Rejoignez 1000+ professionnels</h2>
      <p style="font-size: 15px; color: rgba(255,255,255,0.5); line-height: 1.85; margin: 16px 0 28px;">
        La newsletter Cercle IA arrive dans votre boîte LinkedIn tous les 15 jours.
      </p>
      <a
        href="https://www.linkedin.com/newsletters/cercle-ia-7353754146262401025/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        S'abonner gratuitement &rarr;
      </a>
    </div>
  </section>

</BaseLayout>
