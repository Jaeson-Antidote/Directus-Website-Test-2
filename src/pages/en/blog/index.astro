---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { breadcrumb, articleItemListSchema } from '../../../lib/schema';
import { getCollection } from 'astro:content';

const bc = breadcrumb([{ name: 'Blog', href: '/en/blog' }]);

const allArticles = (await getCollection('blogEn', ({ data }) => !data.draft))
  .sort((a, b) => {
    const dateA = new Date(a.data.updatedDate ?? a.data.pubDate).getTime();
    const dateB = new Date(b.data.updatedDate ?? b.data.pubDate).getTime();
    return dateB - dateA;
  });

const blogImages = import.meta.glob<{ default: ImageMetadata }>('../../../assets/blog/*', { eager: true });

const itemList = articleItemListSchema({
  name: 'AI blog for professionals — Cercle IA',
  description: 'Analysis, guides, and practical resources on professional AI.',
  items: allArticles.map((a) => ({ url: `/en/blog/${a.id}` })),
});

const schema = {
  '@context': 'https://schema.org',
  '@graph': [bc, itemList],
};
---

<BaseLayout
  title="AI blog for professionals — Cercle IA"
  description="Analysis, guides, and practical resources on artificial intelligence for professionals. By Cercle IA."
  ogImage="/og/blog.jpg"
  ogImageAlt="AI blog — Analysis and resources — Cercle IA"
  schema={schema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 72px 0 64px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.06) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      <div style="max-width: 680px;">
        <div class="eyebrow-badge" style="margin-bottom: 24px; display: inline-flex;">
          <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
          Cercle IA blog
        </div>

        <h1 class="hero-title">
          Analysis and resources<br />
          <span style="color: rgba(255,255,255,0.55);">on professional AI.</span>
        </h1>

        <p style="font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.75; max-width: 560px; margin: 0;">
          Insights, practical guides, and real-world experience for professionals who want to understand AI before adopting it.
        </p>
      </div>
    </div>
  </section>

  <!-- ========== ARTICLES ========== -->
  <section style="background: var(--color-dark-1); padding: 56px 0 88px;">
    <div class="container">

      {allArticles.length > 0 ? (
        <div class="blog-grid">
          {allArticles.map((article) => {
            const displayDate = article.data.updatedDate ?? article.data.pubDate;
            const dateLabel = article.data.updatedDate ? 'Updated ' : '';
            const date = dateLabel + new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(displayDate));
            const imgFile = article.data.image?.split('/').pop();
            const imageMetadata = imgFile ? blogImages[`../../../assets/blog/${imgFile}`]?.default : undefined;
            return (
              <a href={`/en/blog/${article.id}`} class="blog-card" style="text-decoration: none; display: flex; flex-direction: column;">
                {imageMetadata ? (
                  <div class="blog-card-img">
                    <Image
                      src={imageMetadata}
                      alt={article.data.imageAlt ?? article.data.title}
                      width={748}
                      height={420}
                      style="width: 100%; height: 100%; object-fit: cover; display: block;"
                    />
                  </div>
                ) : (
                  <div class="blog-card-img blog-card-img--placeholder" aria-hidden="true"></div>
                )}

                <div class="blog-card-body">
                  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap;">
                    {article.data.category && (
                      <span class="tag" style="font-size: 10px; padding: 3px 10px;">{article.data.category}</span>
                    )}
                    <span style="font-size: 12px; color: rgba(255,255,255,0.3);">{date}</span>
                  </div>

                  <h2 style="font-family: var(--font-display); font-size: 19px; font-weight: 700; color: #ffffff; line-height: 1.35; margin-bottom: 16px; flex: 1;">{article.data.title}</h2>

                  <div style="display: flex; justify-content: flex-end;">
                    <span style="font-size: 13px; font-weight: 600; color: var(--color-accent); white-space: nowrap;">Read &rarr;</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="glass-card" style="max-width: 560px; margin: 0 auto; padding: 48px 40px; text-align: center;">
          <div style="width: 56px; height: 56px; border-radius: 50%; background: rgba(247,171,110,0.12); border: 1px solid rgba(247,171,110,0.3); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </div>
          <h3 style="font-family: var(--font-display); font-size: 24px; font-weight: 700; color: #ffffff; margin-bottom: 12px;">The first articles are on their way</h3>
          <p style="font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.75; margin-bottom: 28px;">
            In the meantime, the newsletter covers the most important AI topics every two weeks.
          </p>
          <a href="https://www.linkedin.com/newsletters/cercle-ia-7353754146262401025/" target="_blank" rel="noopener noreferrer" class="btn-primary">Subscribe to the newsletter &rarr;</a>
        </div>
      )}

    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section style="background: var(--color-dark-1); padding: 80px 0; border-top: 1px solid rgba(255,255,255,0.05);">
    <div class="container" style="text-align: center; max-width: 680px;">
      <span class="section-eyebrow">Don't miss an article</span>
      <h2 class="section-title">Subscribe to the newsletter</h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin: 20px 0 32px;">
        Every new analysis, guide, or resource is published first in the Cercle IA newsletter.
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href="https://www.linkedin.com/newsletters/cercle-ia-7353754146262401025/" target="_blank" rel="noopener noreferrer" class="btn-primary">Subscribe to the newsletter &rarr;</a>
        <a href="/en/formations" class="btn-outline">Explore training programmes</a>
      </div>
    </div>
  </section>

</BaseLayout>
