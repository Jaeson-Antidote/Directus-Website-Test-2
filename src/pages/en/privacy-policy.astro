---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumb } from '../../lib/schema';

const schema = breadcrumb([{ name: 'Privacy policy', href: '/en/privacy-policy' }]);
---

<BaseLayout
  title="Privacy policy — Cercle IA"
  description="How we collect, use and protect your personal data. GDPR-compliant privacy policy from Cercle IA."
  ogImage="/og/default.jpg"
  ogImageAlt="Privacy policy — Cercle IA"
  schema={schema}
  robots="index,follow"
  hreflangAlternate="/politique-confidentialite"
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 64px 0 72px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.06) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container" style="max-width: 720px;">
      <div class="eyebrow-badge" style="margin-bottom: 24px; display: inline-flex;">
        <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
        Data protection
      </div>

      <h1 class="hero-title">Privacy policy</h1>

      <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.75; margin-top: 16px; max-width: 560px;">
        In accordance with the GDPR and the Belgian Act of 30 July 2018, here is how we process your personal data.
      </p>
    </div>
  </section>

  <!-- ========== CONTENT ========== -->
  <section style="background: var(--color-light-1); padding: 80px 0;">
    <div class="container" style="max-width: 720px;">

      <!-- 1. Parties and scope -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 16px;">1. Parties and scope</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 12px;">
          The website <strong>https://lecercle.ai/</strong> is published by <strong>Antidote SRL</strong>, registered office at Volontaires 19, 1160 Auderghem, registered in the Brussels Register of Legal Entities under number 0773.969.928.
        </p>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 12px;">
          Responsible publisher: Tarik Hennen, Director.<br />
          The domain name https://lecercle.ai/ is managed by GoDaddy.com, LLC.<br />
          The website is hosted by Netlify.
        </p>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85;">
          Antidote SRL has established this Privacy Policy to inform Users, in full transparency, of the way in which personal data is collected and processed. The term "User" refers to any natural or legal person who visits or interacts with the Site.
        </p>
      </div>

      <!-- 2. Processing of personal data -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 16px;">2. Processing of personal data</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 12px;">
          Use of the Site may involve the communication of personal data. Antidote processes such data as Data Controller, via:
        </p>
        <ul style="list-style: disc; padding-left: 20px; display: flex; flex-direction: column; gap: 8px; margin-top: 12px;">
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">Forms (contact, application, appointment booking)</li>
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">Email or postal correspondence</li>
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">The use of cookies</li>
        </ul>
      </div>

      <!-- 3. Purposes of processing -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 16px;">3. Purposes of processing</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 12px;">
          In accordance with article 13 of the Regulation, the purposes of processing are as follows:
        </p>
        <ul style="list-style: disc; padding-left: 20px; display: flex; flex-direction: column; gap: 8px; margin-top: 12px;">
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">Providing you with advice and services in digital strategy and marketing</li>
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">Developing our activities and new product or service offerings</li>
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">Improving service quality</li>
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">Personalising our services based on your preferences</li>
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">Adapting our website and content based on your interests</li>
        </ul>
      </div>

      <!-- 4. Personal data that may be processed -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 16px;">4. Personal data that may be processed</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 12px;">
          By accessing the Site, the User consents to Antidote collecting and processing the following data:
        </p>
        <ul style="list-style: disc; padding-left: 20px; display: flex; flex-direction: column; gap: 8px; margin-top: 12px;">
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">Name, first name, address, gender, nationality, photograph</li>
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">Contact details: phone number, email address</li>
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">Social media profiles</li>
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">Banking details</li>
        </ul>
      </div>

      <!-- 5. Consent -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 16px;">5. Consent</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 12px;">
          By accessing the Site, the User declares having read and freely, specifically, informed and unambiguously agreed to the processing of their data. Consent is given by the positive act of the User ticking the box that links to this Privacy Policy.
        </p>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85;">
          The User has the right to withdraw their consent at any time. Withdrawal of consent does not affect the lawfulness of processing carried out prior to the withdrawal.
        </p>
      </div>

      <!-- 6. Retention period -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 16px;">6. Data retention period</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 12px;">
          In accordance with article 13(2) of the Regulation, Antidote retains personal data only for as long as reasonably necessary for the purposes for which it is processed. This period is in all cases less than:
        </p>
        <ul style="list-style: disc; padding-left: 20px; display: flex; flex-direction: column; gap: 8px; margin-top: 12px;">
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">5 years for our clients (after the end of the commercial relationship, from the date of our last invoice or last significant contact)</li>
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">12 months for prospects (from the date of our last significant contact)</li>
        </ul>
      </div>

      <!-- 7. Data recipients -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 16px;">7. Data recipients and disclosure to third parties</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85;">
          Personal data may be transmitted to Antidote's staff, employees, subcontractors or suppliers who offer adequate security guarantees and who collaborate with Antidote in the marketing of products or the provision of services. In all cases, recipients comply with the content of this Privacy Policy and process such data solely for the purposes set out herein, in a confidential and secure manner.
        </p>
      </div>

      <!-- 8. User rights -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 20px;">8. User rights</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 16px;">
          At any time, the User may exercise their rights by sending a message to: <a href="mailto:th@antidote-digital.com" style="color: var(--color-accent);">th@antidote-digital.com</a>, or by post to: 19 Avenue des Volontaires, 1160 Auderghem, enclosing a copy of their identity document.
        </p>

        <h3 style="font-size: 16px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 8px; margin-top: 16px;">a. Right of access</h3>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 16px;">
          In accordance with article 15 of the Regulation, the User has the right to obtain access to their personal data, the purposes of processing, the categories of data concerned, recipients, the envisaged retention period and the existence of any automated decision-making. A copy of the data will be communicated within one month of receipt of the request.
        </p>

        <h3 style="font-size: 16px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 8px; margin-top: 16px;">b. Right to rectification</h3>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 16px;">
          In accordance with article 16 of the Regulation, incorrect, inaccurate or irrelevant data may be corrected or erased at any time. Antidote notifies each recipient of any rectification carried out.
        </p>

        <h3 style="font-size: 16px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 8px; margin-top: 16px;">c. Right to erasure</h3>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 16px;">
          The User has the right to obtain erasure of their personal data in the cases listed in article 17 of the Regulation, except where processing is necessary for the exercise of freedom of expression, for compliance with a legal obligation, or for the establishment or exercise of legal claims.
        </p>

        <h3 style="font-size: 16px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 8px; margin-top: 16px;">d. Right to restriction of processing</h3>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 16px;">
          The User has the right to obtain restriction of processing of their data in the cases provided for in article 19 of the Regulation.
        </p>

        <h3 style="font-size: 16px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 8px; margin-top: 16px;">e. Right to data portability</h3>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 16px;">
          In accordance with article 20 of the Regulation, the User has the right to receive their data in a structured, commonly used and machine-readable format, and to transmit it to another data controller where technically feasible.
        </p>

        <h3 style="font-size: 16px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 8px; margin-top: 16px;">f. Right to object and automated decision-making</h3>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 16px;">
          The User has the right at any time to object to the processing of their personal data, including for prospecting purposes. In accordance with article 21 of the Regulation, Antidote will cease processing such data unless there are compelling legitimate grounds that override the User's interests.
        </p>

        <h3 style="font-size: 16px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 8px; margin-top: 16px;">g. Right to lodge a complaint</h3>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85;">
          The User has the right to lodge a complaint with the Belgian Data Protection Authority:<br />
          Rue de la Presse 35, 1000 Brussels<br />
          Tel. +32 2 274 48 00 &mdash; Email: <a href="mailto:contact@apd-gba.be" style="color: var(--color-accent);">contact@apd-gba.be</a><br />
          <a href="https://www.autoriteprotectiondonnees.be" target="_blank" rel="noopener noreferrer" style="color: var(--color-accent);">autoriteprotectiondonnees.be</a>
        </p>
      </div>

      <!-- 9. Cookies -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 20px;">9. Cookies</h2>

        <h3 style="font-size: 16px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 8px;">a. General principles</h3>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 16px;">
          A "Cookie" is a file deposited temporarily or permanently on the User's hard drive when browsing the Site. Cookies allow the server to recognise the User's computer and may also be installed by third parties with whom Antidote collaborates.
        </p>

        <h3 style="font-size: 16px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 8px;">b. Types of cookies and purposes</h3>
        <ul style="list-style: disc; padding-left: 20px; display: flex; flex-direction: column; gap: 8px; margin-top: 8px; margin-bottom: 16px;">
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;"><strong>Technical cookies:</strong> necessary for the operation of the Site, facilitating User navigation</li>
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;"><strong>Statistical and audience measurement cookies:</strong> allow User recognition, count the number of visitors and enable bug detection</li>
          <li style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;"><strong>Functional cookies:</strong> facilitate use of the Site by remembering certain choices (username, language)</li>
        </ul>

        <h3 style="font-size: 16px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 8px;">c. Retention period</h3>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 16px;">
          Cookies are retained for the time necessary to achieve their purpose, and for a maximum of 1 year.
        </p>

        <h3 style="font-size: 16px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 8px;">d. Cookie management</h3>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85;">
          The User can manage or delete cookies by changing their browser settings. If certain cookies are disabled, the Site may not function optimally.
        </p>
      </div>

      <!-- 10. Limitation of controller liability -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 16px;">10. Limitation of controller liability</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85; margin-bottom: 12px;">
          The Site may contain links to other websites owned by third parties not affiliated with Antidote. The content of those sites and their compliance with the Regulation are not Antidote's responsibility.
        </p>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85;">
          This Site is not designed for persons under the age of 18. Under no circumstances will personal data be processed by the Data Controller if the User indicates that they are under the age of 16.
        </p>
      </div>

      <!-- 11. Security -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 16px;">11. Security</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85;">
          The Data Controller implements organisational and technical measures to ensure an appropriate level of security. These measures are determined by reference to implementation costs relative to the nature, context and purposes of processing. Antidote uses standard encryption technologies when transferring or collecting data on the Site.
        </p>
      </div>

      <!-- 12. Amendments -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 16px;">12. Amendments to this privacy policy</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85;">
          Antidote reserves the right to amend this Privacy Policy in order to comply with legal obligations. Users are encouraged to consult this page regularly. Any amendments will be posted on the Site or sent by email.
        </p>
      </div>

      <!-- 13. Governing law -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 16px;">13. Governing law and jurisdiction</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85;">
          This Privacy Policy is governed exclusively by Belgian law. Any dispute shall be brought before the courts of the judicial district in which Antidote's registered office is located.
        </p>
      </div>

      <!-- 14. Contact -->
      <div class="card-white" style="margin-bottom: 24px; padding: 32px 36px;">
        <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--color-text-on-light); margin-bottom: 16px;">14. Contact</h2>
        <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.85;">
          For any question or complaint relating to this Privacy Policy, the User may contact the Data Controller:<br />
          Tarik Hennen: <a href="mailto:th@antidote-digital.com" style="color: var(--color-accent);">th@antidote-digital.com</a><br />
          19 Avenue des Volontaires, 1160 Auderghem
        </p>
      </div>

    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section style="background: var(--color-dark-1); padding: 80px 0; text-align: center;">
    <div class="container" style="max-width: 600px;">
      <span class="section-eyebrow">Questions about your data?</span>
      <h2 class="section-title" style="margin-top: 12px; margin-bottom: 20px;">Contact our team</h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.55); line-height: 1.75; margin-bottom: 36px;">
        To exercise your rights or ask a question about how your data is processed, our team responds within 48 hours.
      </p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a href="/en/contact" class="btn-primary">Send a message &rarr;</a>
        <a href="/en/ai-policy" class="btn-outline">AI policy</a>
      </div>
    </div>
  </section>

</BaseLayout>
