---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumb } from '../../lib/schema';
import content from '../../content/pages/en/ressources-ia.json';

const schema = breadcrumb([{ name: 'AI Resources', href: '/en/ressources-ia' }]);
---

<BaseLayout
  title={content.meta.title}
  description={content.meta.description}
  ogImage={content.meta.ogImage}
  ogImageAlt={content.meta.ogImageAlt}
  schema={schema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 96px 0 112px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.06) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      <div class="hero-inner">

        <!-- Contenu gauche -->
        <div>
          <div class="eyebrow-badge" style="margin-bottom: 28px; display: inline-flex;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
            {content.hero.eyebrow}
          </div>

          <h1 class="hero-title">
            {content.hero.title}
          </h1>

          <p style="font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.75; max-width: 560px; margin-bottom: 36px;">
            {content.hero.description}
          </p>

          <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
            <a href="#ressources" class="btn-primary">{content.hero.ctaPrimary} &rarr;</a>
            <a href="https://www.linkedin.com/newsletters/cercle-ia-7353754146262401025/" target="_blank" rel="noopener noreferrer" class="btn-outline">{content.hero.ctaSecondary}</a>
          </div>
        </div>

        <!-- Carte droite -->
        <div style="padding-top: 36px;">
          <div class="glass-card" style="border-radius: 20px; padding: 36px 32px;">
            <p style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.25); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px;">{content.hero.card.label}</p>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; margin-top: 16px;">
              {content.hero.card.items.map((item) => (
                <li style="display: flex; gap: 10px; align-items: flex-start;">
                  <span style="color: var(--color-accent); font-size: 13px; flex-shrink: 0; margin-top: 1px;">&#9658;</span>
                  <p style="font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.6; margin: 0;">{item}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== GUIDES PRATIQUES ========== -->
  <section id="ressources" style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">{content.guides.eyebrow}</span>
          <h2 class="section-title">{content.guides.title}</h2>
        </div>
        <a href="https://www.linkedin.com/newsletters/cercle-ia-7353754146262401025/" target="_blank" rel="noopener noreferrer" class="btn-primary" style="white-space: nowrap; flex-shrink: 0;">Subscribe for updates &rarr;</a>
      </div>

      <div class="grid-3" style="margin-top: 40px;">
        {content.guides.items.map((g) => (
          <div class="glass-card" style="display: flex; flex-direction: column; gap: 12px;">
            <span class="tag" style="align-self: flex-start;">{g.tag}</span>
            <h3 class="usp-title">{g.title}</h3>
            <p style="font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.65; flex: 1;">{g.desc}</p>
            <a href={g.href} style="font-size: 14px; font-weight: 600; color: var(--color-accent); text-decoration: none; margin-top: 4px; display: block;">{content.guides.ctaLabel} &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== TEMPLATES DE PROMPTS ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">{content.prompts.eyebrow}</span>
          <h2 class="section-title">{content.prompts.title}</h2>
        </div>
        <a href="https://www.linkedin.com/newsletters/cercle-ia-7353754146262401025/" target="_blank" rel="noopener noreferrer" class="btn-primary" style="white-space: nowrap; flex-shrink: 0;">All templates &rarr;</a>
      </div>

      <div class="grid-2" style="margin-top: 40px;">
        {content.prompts.items.map((p) => (
          <div class="glass-card" style="display: flex; flex-direction: column; gap: 12px;">
            <span class="tag-outline" style="align-self: flex-start;">{p.tag}</span>
            <h3 class="usp-title">{p.title}</h3>
            <p style="font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.65; flex: 1;">{p.desc}</p>
            <a href={p.href} style="font-size: 13px; font-weight: 600; color: var(--color-accent); text-decoration: none; margin-top: 12px; display: block;">{content.prompts.ctaLabel} &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== OUTILS RECOMMANDÉS ========== -->
  <section style="background: var(--color-light-1); padding: 96px 0;">
    <div class="container">
      <span class="section-eyebrow">{content.tools.eyebrow}</span>
      <h2 class="section-title" style="color: var(--color-text-on-light);">{content.tools.title}</h2>
      <p style="font-size: 16px; color: var(--color-text-subtle); line-height: 1.7; margin-top: 12px; margin-bottom: 40px;">
        {content.tools.description}
      </p>

      <div class="grid-3">
        {content.tools.items.map((t) => (
          <div class="card-white" style="display: flex; flex-direction: column; gap: 8px;">
            <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; margin-bottom: 4px;">
              <h3 style="font-family: var(--font-display); font-size: 18px; font-weight: 700; color: var(--color-text-on-light); margin: 0;">{t.name}</h3>
              <span style="font-size: 11px; color: var(--color-text-subtle); border: 1px solid rgba(6,24,23,0.15); border-radius: 20px; padding: 2px 10px; white-space: nowrap;">{t.category}</span>
            </div>
            <p style="font-size: 13px; color: var(--color-text-subtle); line-height: 1.65; flex: 1; margin-top: 8px;">{t.desc}</p>
            <p style="font-size: 11px; color: rgba(6,24,23,0.35); margin-top: 12px; font-weight: 500;">{t.pricing}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== NEWSLETTER ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <div class="grid-2" style="gap: 56px; align-items: center;">

        <!-- Gauche -->
        <div>
          <span class="section-eyebrow">{content.newsletter.eyebrow}</span>
          <h2 class="section-title">{content.newsletter.title}</h2>
          <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin-top: 16px; margin-bottom: 32px;">
            Each edition of the newsletter contains at least one new resource: prompt, guide or comparison. Subscribe to stay up to date.
          </p>
          <a href={content.newsletter.ctaHref} target="_blank" rel="noopener noreferrer" class="btn-primary">{content.newsletter.ctaLabel} &rarr;</a>
        </div>

        <!-- Droite -->
        <div>
          <div class="glass-card" style="padding: 40px 36px;">
            <p style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.25); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 16px;">What you will receive</p>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px;">
              {content.newsletter.preview.map((item) => (
                <li style="display: flex; gap: 10px; align-items: flex-start;">
                  <span style="color: var(--color-accent); font-size: 14px; flex-shrink: 0; margin-top: 1px;">&#9658;</span>
                  <p style="font-size: 14px; color: rgba(255,255,255,0.65); line-height: 1.6; margin: 0;">{item}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container" style="text-align: center; max-width: 680px;">
      <span class="section-eyebrow">{content.ctaFinal.eyebrow}</span>
      <h2 class="section-title">{content.ctaFinal.title}</h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin: 20px 0 32px;">
        Resources give you the foundations. Training gives you the method, use cases and support to truly integrate AI into your practice.
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href={content.ctaFinal.ctaPrimaryHref} class="btn-primary">{content.ctaFinal.ctaPrimary} &rarr;</a>
        <a href={content.ctaFinal.ctaSecondaryHref} class="btn-outline">{content.ctaFinal.ctaSecondary}</a>
      </div>
    </div>
  </section>

</BaseLayout>
