---
export const prerender = false;

import { getDraftBySlug, articleImageUrl } from '~/lib/directus';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

const { slug } = Astro.params;
const token = Astro.url.searchParams.get('token');

if (!token || token !== import.meta.env.PREVIEW_SECRET) {
  return new Response('Unauthorized', { status: 401 });
}

const article = await getDraftBySlug(slug, import.meta.env.DIRECTUS_TOKEN ?? '');

if (!article) {
  return new Response('Not found', { status: 404 });
}

const { title, description, pub_date, updated_date, category, tags, image_alt, content } = article;
const imageUrl = articleImageUrl(article);
---

<ArticleLayout
  {title}
  {description}
  pubDate={new Date(pub_date)}
  updatedDate={updated_date ? new Date(updated_date) : undefined}
  {category}
  {tags}
  image={imageUrl}
  imageAlt={image_alt ?? undefined}
  {slug}
>
  <div set:html={content} />
</ArticleLayout>
