---
import BaseLayout from '../layouts/BaseLayout.astro';
import { personSchema, breadcrumb } from '../lib/schema';
import content from '../content/pages/fr/tarik-hennen.json';

const person = personSchema();
const bc = breadcrumb([{ name: 'Tarik Hennen', href: '/tarik-hennen' }]);

const schema = {
  '@context': 'https://schema.org',
  '@graph': [person, bc],
};
---

<BaseLayout
  title={content.meta.title}
  description={content.meta.description}
  ogImage={content.meta.ogImage}
  ogImageAlt={content.meta.ogImageAlt}
  schema={schema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 96px 0 112px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.06) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      <nav aria-label="Fil d'Ariane" style="margin-bottom: 40px; display: flex; align-items: center; gap: 8px; font-size: 13px; flex-wrap: wrap;">
        <a href="/" class="breadcrumb-link">Accueil</a>
        <span style="color: rgba(255,255,255,0.2);" aria-hidden="true">/</span>
        <span style="color: rgba(255,255,255,0.5);">Tarik Hennen</span>
      </nav>

      <div style="display: grid; grid-template-columns: 1fr 340px; gap: 48px; align-items: center;">

        <div>
          <div class="eyebrow-badge" style="margin-bottom: 28px; display: inline-flex;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
            {content.hero.eyebrow}
          </div>

          <h1 class="hero-title" style="font-size: clamp(36px, 4.5vw, 60px) !important; line-height: 1.05; margin-bottom: 20px;">
            {content.hero.title}
          </h1>

          <p style="font-size: 17px; color: rgba(255,255,255,0.5); line-height: 1.8; max-width: 560px; margin-bottom: 36px;">
            {content.hero.description}
          </p>

          <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 48px;">
            <a href={content.hero.ctaPrimaryHref} class="btn-primary">{content.hero.ctaPrimary} &rarr;</a>
            <a href={content.hero.ctaSecondaryHref} target="_blank" rel="noopener noreferrer" class="btn-outline">{content.hero.ctaSecondary}</a>
          </div>

          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.06);">
            {content.hero.stats.map((s) => (
              <div>
                <span class="stat-number">{s.value}</span>
                <p class="stat-label">{s.label}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="hero-photo-col" style="position: relative;">
          <div style="border-radius: var(--radius-xl); overflow: hidden; border: 1px solid rgba(255,255,255,0.08);">
            <img
              src="/images/tarik-hennen-formation.png"
              alt="Tarik Hennen, fondateur et formateur IA — Cercle IA"
              width="802"
              height="1000"
              loading="eager"
              style="width: 100%; height: auto; display: block;"
            />
          </div>
          <div style="position: absolute; bottom: -16px; left: -16px; background: var(--color-dark-2); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-lg); padding: 14px 18px; backdrop-filter: blur(16px);">
            <p style="font-size: 12px; font-weight: 600; color: #ffffff; line-height: 1.3;">Tarik Hennen</p>
            <p style="font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px;">Fondateur, Cercle IA</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== FORMATION ACADÉMIQUE & PARCOURS ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <div class="grid-2" style="gap: 80px; align-items: start;">

        <div>
          <span class="section-eyebrow">{content.academique.eyebrow}</span>
          <h2 class="section-title">{content.academique.title}</h2>
          <div style="width: 36px; height: 2px; background: var(--color-accent); margin-top: 24px; margin-bottom: 28px;"></div>

          <div class="glass-card" style="margin-bottom: 16px;">
            <p style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.25); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 14px;">Diplômes</p>
            <div style="display: flex; flex-direction: column; gap: 14px;">
              {content.academique.diplomes.map((d) => (
                <div>
                  <p style="font-size: 15px; font-weight: 600; color: rgba(255,255,255,0.8); margin-bottom: 3px;">{d.degree}</p>
                  <p style="font-size: 13px; color: rgba(255,255,255,0.4);">{d.institution}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div>
          <span class="section-eyebrow">{content.experience.eyebrow}</span>
          <h2 class="section-title">{content.experience.title}</h2>
          <div style="width: 36px; height: 2px; background: var(--color-accent); margin-top: 24px; margin-bottom: 28px;"></div>

          <div style="display: flex; flex-direction: column; gap: 12px;">
            {content.experience.items.map((exp) => (
              <div class="glass-card" style="padding: 20px 24px;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 6px;">
                  <p style="font-size: 15px; font-weight: 600; color: rgba(255,255,255,0.85); line-height: 1.3;">{exp.role} — {exp.org}</p>
                  {exp.period && <span style="font-size: 11px; color: rgba(255,255,255,0.3); white-space: nowrap; padding-top: 2px;">{exp.period}</span>}
                </div>
                <p style="font-size: 13px; color: rgba(255,255,255,0.4); line-height: 1.7;">{exp.desc}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== ENSEIGNEMENT ========== -->
  <section style="background: var(--color-light-1); padding: 96px 0;">
    <div class="container">
      <div style="margin-bottom: 48px;">
        <span class="section-eyebrow">{content.enseignement.eyebrow}</span>
        <h2 class="section-title" style="color: var(--color-text-on-light); max-width: 560px;">{content.enseignement.title}</h2>
      </div>
      <div class="grid-3" style="gap: 20px; margin-bottom: 64px;">
        {content.enseignement.institutions.map((t) => (
          <div class="card-white">
            <h3 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--color-text-on-light); margin-bottom: 10px;">{t.name}</h3>
            <p style="font-size: 14px; color: var(--color-text-subtle); line-height: 1.75;">{t.desc}</p>
          </div>
        ))}
      </div>

      <div style="margin-bottom: 48px;">
        <span class="section-eyebrow">Recherche</span>
        <h2 class="section-title" style="color: var(--color-text-on-light); max-width: 560px;">{content.enseignement.rechercheTitle}</h2>
      </div>
      <div class="grid-2" style="gap: 20px;">
        {content.enseignement.recherche.map((r) => (
          <div class="card-white">
            <h3 style="font-family: var(--font-display); font-size: 18px; font-weight: 700; color: var(--color-text-on-light); margin-bottom: 10px;">{r.name}</h3>
            <p style="font-size: 14px; color: var(--color-text-subtle); line-height: 1.75;">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CITATION ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container" style="max-width: 860px;">
      <div class="glass-card" style="padding: 40px 48px;">
        <span style="font-family: var(--font-display); font-size: 48px; line-height: 1; color: var(--color-accent); opacity: 0.7; margin-bottom: 16px; display: block;">&ldquo;</span>
        <p style="font-family: var(--font-display); font-size: 21px; font-weight: 700; color: #ffffff; line-height: 1.45; letter-spacing: -0.01em; margin-bottom: 24px; max-width: 680px;">
          {content.citation.quote}
        </p>
        <p style="font-size: 13px; color: rgba(255,255,255,0.3);">{content.citation.name}, {content.citation.role} — {content.citation.org}</p>
      </div>
    </div>
  </section>

  <!-- ========== PUBLICATIONS RÉCENTES ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">
      <div style="margin-bottom: 48px;">
        <span class="section-eyebrow">{content.publications.eyebrow}</span>
        <h2 class="section-title">{content.publications.title}</h2>
      </div>
      <div style="display: flex; flex-direction: column; gap: 2px; margin-bottom: 40px; max-width: 760px;">
        <a href={content.publications.ctaBlogHref} class="glass-card" style="display: flex; justify-content: space-between; align-items: center; gap: 16px; text-decoration: none; transition: opacity 0.15s;">
          <p style="font-size: 15px; font-weight: 500; color: rgba(255,255,255,0.75); line-height: 1.4;">{content.publications.ctaBlog}</p>
          <span style="color: var(--color-accent); flex-shrink: 0;">&rarr;</span>
        </a>
      </div>
      <a href={content.publications.ctaInviteHref} class="btn-primary">{content.publications.ctaInvite} &rarr;</a>
    </div>
  </section>

  <!-- ========== À PROPOS DE CERCLE IA ========== -->
  <section class="grain-bg" style="background-color: var(--color-dark-2); padding: 96px 0;">
    <div class="container" style="max-width: 800px; text-align: center;">
      <span class="section-eyebrow">{content.cercleIA.eyebrow}</span>
      <h2 class="section-title" style="margin-bottom: 16px;">{content.cercleIA.title}</h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin-bottom: 32px; max-width: 600px; margin-left: auto; margin-right: auto;">
        Cercle IA est un organisme de formation spécialisé dans l'usage de l'IA pour les professionnels à responsabilité engagée. Juristes, médecins, dirigeants, consultants — des formations conçues à partir de contraintes réelles, pas de démos.
      </p>
      <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;">
        <a href={content.cercleIA.ctaFormationsHref} class="btn-primary">{content.cercleIA.ctaFormations} &rarr;</a>
        <a href={content.cercleIA.ctaAProposHref} class="btn-outline">{content.cercleIA.ctaAPropos}</a>
      </div>
    </div>
  </section>

</BaseLayout>
