---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumb } from '../lib/schema';

const bc = breadcrumb([{ name: 'Bootcamp IA', href: '/bootcamp' }]);

const problemSolutionRows = [
  {
    problem: 'Vous utilisez ChatGPT ou Copilot, mais les résultats ne sont pas toujours fiables.',
    solutionTitle: 'Prenez l\'avantage concurrentiel',
    solutionDesc: 'Explorez de nouvelles manières de créer de la valeur pour vos clients. Franchissez le cap vers une pratique professionnelle augmentée par l\'IA.',
  },
  {
    problem: 'Vous reformulez, relancez, corrigez. Le gain de temps n\'est pas au rendez-vous.',
    solutionTitle: 'Augmentez vos performances',
    solutionDesc: 'Livrez des résultats supérieurs en moins de temps. Créez des synergies d\'équipe grâce aux outils d\'IA collaborative, sans sacrifier le jugement professionnel.',
  },
  {
    problem: 'Vous ne savez pas ce que vous pouvez confier à l\'IA sans risquer vos données clients.',
    solutionTitle: 'Gagnez en confiance et en maîtrise',
    solutionDesc: 'Acquérez une compréhension solide des fondamentaux de l\'IA générative. Maîtrisez les bonnes pratiques. Gagnez en assurance et en crédibilité face à vos clients et pairs.',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Course',
      name: 'Bootcamp IA Générative',
      description: 'Programme intensif de 3 sessions pour maîtriser l\'IA générative dans votre pratique professionnelle. Prompts, outils, méthodes et confidentialité.',
      url: 'https://lecercle.ai/bootcamp',
      provider: { '@type': 'Organization', name: 'Cercle IA', sameAs: 'https://lecercle.ai' },
      inLanguage: 'fr-BE',
    },
    bc,
    {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: [
        { '@type': 'Question', name: 'Ai-je besoin de compétences techniques en IA ?', acceptedAnswer: { '@type': 'Answer', text: 'Non. Le bootcamp est conçu pour des professionnels sans bagage technique. Tout est expliqué de façon concrète et orientée métier.' } },
        { '@type': 'Question', name: 'Comment se déroulent les sessions masterclass ?', acceptedAnswer: { '@type': 'Answer', text: 'Sessions pratiques en ligne, avec exercices et cas d\'usage métier directement applicables à votre contexte professionnel.' } },
        { '@type': 'Question', name: 'Comment se déroule la session de coaching individuel ?', acceptedAnswer: { '@type': 'Answer', text: 'Une session 1-on-1 avec le formateur pour adapter les apprentissages à votre contexte spécifique : vos outils, vos clients, vos contraintes.' } },
        { '@type': 'Question', name: 'Quel est l\'investissement total ?', acceptedAnswer: { '@type': 'Answer', text: '750 € HTVA pour l\'ensemble du programme — 3 sessions masterclass, coaching individuel, accès aux ressources et 3 mois de Cercle GPT offerts.' } },
      ],
    },
  ],
};
---

<BaseLayout
  title="Bootcamp IA générative — Cercle IA"
  description="3 sessions intensives pour maîtriser l'IA générative dans votre pratique professionnelle. Prompts, outils, méthodes, confidentialité. En ligne. 750 € HTVA."
  ogImage="/og/bootcamp.jpg"
  ogImageAlt="Bootcamp IA Générative — Cercle IA"
  schema={schema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 96px 0 112px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.06) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      <div class="hero-inner">

        <!-- Contenu gauche -->
        <div>
          <div class="eyebrow-badge" style="margin-bottom: 28px; display: inline-flex;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
            Bootcamp Cercle IA
          </div>

          <h1 class="hero-title">
            Maîtrisez l'IA générative<br />
            <span style="color: rgba(255,255,255,0.55);">dans votre métier.</span>
          </h1>

          <p style="font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.75; max-width: 560px; margin-bottom: 36px;">
            Un programme de 3 sessions pour tirer des résultats concrets : comment formuler vos prompts, quels outils IA choisir selon la tâche, et comment travailler avec l'IA sans compromettre la confidentialité.
          </p>

          <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 32px;">
            <a href="#" data-open-modal="waitlist" class="btn-primary">S'inscrire sur la liste d'attente</a>
            <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline">Planifier un appel</a>
          </div>

          <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
            <span style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.2); letter-spacing: 0.08em; text-transform: uppercase; margin-right: 4px; white-space: nowrap;">Pour</span>
            {['Avocats', 'Consultants', 'Managers', 'Professions libérales', 'Dirigeants'].map((p) => (
              <span class="tag-outline" style="font-size: 10px; padding: 3px 10px;">{p}</span>
            ))}
          </div>
        </div>

        <!-- Box session à droite -->
        <div style="padding-top: 36px;">
          <div style="background: rgba(255,255,255,0.05); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.09); border-radius: var(--radius-xl); padding: 36px 32px;">

            <h2 style="font-family: var(--font-display); font-size: 26px; font-weight: 700; color: #ffffff; line-height: 1.2; letter-spacing: -0.015em; margin-bottom: 28px;">Prochaine session</h2>

            <div style="display: flex; flex-direction: column; gap: 20px;">
              {[
                {
                  label: 'Été 2026',
                  icon: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
                },
                {
                  label: '3 modules & 1 session coaching',
                  icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
                },
                {
                  label: 'En ligne',
                  icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
                },
                {
                  label: 'Français',
                  icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
                },
              ].map((item) => (
                <div style="display: flex; align-items: center; gap: 16px;">
                  <div style="width: 40px; height: 40px; border-radius: 50%; background: rgba(247,171,110,0.12); border: 1px solid rgba(247,171,110,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
                  </div>
                  <p style="font-size: 15px; font-weight: 500; color: rgba(255,255,255,0.8); font-family: var(--font-body);">{item.label}</p>
                </div>
              ))}
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== PROBLÈME / SOLUTION ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">

      <!-- Intro -->
      <div style="max-width: 720px; margin-bottom: 56px;">
        <span class="section-eyebrow">Pour qui, et pourquoi</span>
        <h2 class="section-title">Vous utilisez l'IA. Mais pas comme vous le voudriez.</h2>
        <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin-top: 20px;">
          Ce programme est conçu pour les professionnels du conseil — avocats, consultants, professions libérales, dirigeants — qui souhaitent exploiter le potentiel de l'IA pour prendre une longueur d'avance et anticiper la transformation inéluctable de leur métier.
        </p>
      </div>

      <!-- Problème → Solution (grille alignée ligne par ligne) -->
      <div style="background: var(--color-light-1); border-radius: calc(var(--radius-lg) + 4px); padding: 4px; margin-bottom: 40px; box-shadow: 0 4px 32px rgba(0,0,0,0.3);">
      <div style="border: 1px solid rgba(6,24,23,0.1); border-radius: var(--radius-lg); overflow: hidden; display: grid; grid-template-columns: 1fr 1fr;">

        <!-- En-têtes -->
        <div style="padding: 16px 28px; background: rgba(6,24,23,0.04); border-right: 1px solid rgba(6,24,23,0.08); border-bottom: 1px solid rgba(6,24,23,0.08);">
          <p style="font-size: 11px; font-weight: 600; color: rgba(6,24,23,0.4); letter-spacing: 0.1em; text-transform: uppercase;">Le problème</p>
        </div>
        <div style="padding: 16px 28px; background: rgba(247,171,110,0.1); border-bottom: 1px solid rgba(247,171,110,0.15);">
          <p style="font-size: 11px; font-weight: 600; color: var(--color-accent-hover); letter-spacing: 0.1em; text-transform: uppercase;">Ce que vous allez gagner</p>
        </div>

        <!-- Lignes alignées -->
        {problemSolutionRows.map((row, i) => (
          <>
            <div style={`padding: 28px; background: rgba(6,24,23,0.02); border-right: 1px solid rgba(6,24,23,0.08); display: flex; gap: 14px; align-items: flex-start;${i < problemSolutionRows.length - 1 ? ' border-bottom: 1px solid rgba(6,24,23,0.06);' : ''}`}>
              <span style="width: 18px; height: 18px; border-radius: 50%; border: 1px solid rgba(6,24,23,0.2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 3px;">
                <span style="width: 5px; height: 5px; border-radius: 50%; background: rgba(6,24,23,0.3); display: block;"></span>
              </span>
              <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">{row.problem}</p>
            </div>
            <div style={`padding: 28px; background: rgba(247,171,110,0.05); display: flex; gap: 14px; align-items: flex-start;${i < problemSolutionRows.length - 1 ? ' border-bottom: 1px solid rgba(247,171,110,0.1);' : ''}`}>
              <span style="width: 18px; height: 18px; border-radius: 50%; background: rgba(247,171,110,0.25); border: 1px solid rgba(247,171,110,0.5); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 3px;">
                <span style="color: var(--color-accent-hover); font-size: 10px; font-weight: 700; line-height: 1;">✓</span>
              </span>
              <div>
                <p style="font-size: 15px; font-weight: 600; color: var(--color-text-on-light); line-height: 1.4; margin-bottom: 6px;">{row.solutionTitle}</p>
                <p style="font-size: 13px; color: var(--color-text-subtle); line-height: 1.75;">{row.solutionDesc}</p>
              </div>
            </div>
          </>
        ))}

      </div>
      </div>


    </div>
  </section>

  <!-- ========== PROGRAMME ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">

      <div class="section-header">
        <div>
          <span class="section-eyebrow">Ce que comprend le bootcamp</span>
          <h2 class="section-title">Un programme complet,<br />pas un survol.</h2>
        </div>
        <a href="/contact?sujet=programme" class="btn-primary" style="white-space: nowrap; flex-shrink: 0;">Recevoir le programme complet &rarr;</a>
      </div>

      <!-- 4 piliers -->
      <div class="grid-2" style="gap: 20px; margin-bottom: 32px;">

        <!-- 01 Programme -->
        <div class="glass-card" style="display: flex; flex-direction: column; gap: 16px;">
          <span class="usp-number">01</span>
          <h3 class="usp-title">Programme</h3>
          <div style="display: flex; flex-direction: column; gap: 9px;">
            {[
              '3 séances masterclass en ligne',
              'Cas pratiques métiers réels',
              '1 session coaching individuel 1-on-1',
              'Accès communauté d\'experts',
            ].map((item) => (
              <div style="display: flex; gap: 10px; align-items: flex-start;">
                <span style="color: var(--color-accent); font-size: 12px; flex-shrink: 0; margin-top: 2px;">▸</span>
                <p style="font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5;">{item}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- 02 Ressources & outils -->
        <div class="glass-card" style="display: flex; flex-direction: column; gap: 16px;">
          <span class="usp-number">02</span>
          <h3 class="usp-title">Ressources & outils</h3>
          <div style="display: flex; flex-direction: column; gap: 9px;">
            {[
              'Bibliothèque de prompts professionnels prêts à l\'emploi',
              'Guides pour découvrir et maîtriser les outils IA',
              'Module d\'anonymisation de données sensibles',
              'Mises à jour régulières selon l\'actualité IA',
            ].map((item) => (
              <div style="display: flex; gap: 10px; align-items: flex-start;">
                <span style="color: var(--color-accent); font-size: 12px; flex-shrink: 0; margin-top: 2px;">▸</span>
                <p style="font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5;">{item}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- 03 Support continu -->
        <div class="glass-card" style="display: flex; flex-direction: column; gap: 16px;">
          <span class="usp-number">03</span>
          <h3 class="usp-title">Support continu</h3>
          <div style="display: flex; flex-direction: column; gap: 9px;">
            {[
              'Support technique dédié dans l\'espace membre',
              'Communauté d\'experts pour partager les bonnes pratiques',
              'Veille IA ciblée et personnalisée',
            ].map((item) => (
              <div style="display: flex; gap: 10px; align-items: flex-start;">
                <span style="color: var(--color-accent); font-size: 12px; flex-shrink: 0; margin-top: 2px;">▸</span>
                <p style="font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5;">{item}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- 04 Résultats concrets -->
        <div class="glass-card" style="display: flex; flex-direction: column; gap: 16px;">
          <span class="usp-number">04</span>
          <h3 class="usp-title">Résultats concrets</h3>
          <div style="display: flex; flex-direction: column; gap: 9px;">
            {[
              'Identification des opportunités d\'automatisation',
              'Mise en œuvre dans vos missions dès la première semaine',
              'Évaluation et gestion des risques IA',
              'Développement de nouvelles offres augmentées par l\'IA',
            ].map((item) => (
              <div style="display: flex; gap: 10px; align-items: flex-start;">
                <span style="color: var(--color-accent); font-size: 12px; flex-shrink: 0; margin-top: 2px;">▸</span>
                <p style="font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5;">{item}</p>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- Cercle GPT bonus -->
      <div class="glass-card" style="border-color: rgba(247,171,110,0.22); background: rgba(247,171,110,0.04); overflow: hidden;">
        <div style="display: grid; grid-template-columns: 1fr 380px; gap: 40px; align-items: center;">

          <!-- Texte -->
          <div>
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
              <span class="tag">Bonus inclus</span>
            </div>
            <h3 style="font-family: var(--font-display); font-size: 26px; font-weight: 700; color: #ffffff; margin-bottom: 10px; line-height: 1.2;">Cercle GPT — 3 mois offerts</h3>
            <p style="font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.75; margin-bottom: 24px; max-width: 460px;">Accédez aux meilleurs modèles IA depuis une seule interface sécurisée — sans jongler entre les abonnements, sans compromettre la confidentialité de vos données.</p>

            <!-- Stats -->
            <div style="display: flex; gap: 28px; flex-wrap: wrap; margin-bottom: 24px;">
              {[
                { n: '5', l: 'Outils IA' },
                { n: '20+', l: 'Modèles IA' },
                { n: '150+', l: 'Utilisateurs' },
              ].map((s) => (
                <div>
                  <p style="font-family: var(--font-display); font-size: 24px; font-weight: 700; color: #ffffff; line-height: 1;">{s.n}</p>
                  <p style="font-size: 11px; color: rgba(255,255,255,0.35); margin-top: 3px;">{s.l}</p>
                </div>
              ))}
            </div>

            <!-- Logos outils -->
            <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
              {['ChatGPT', 'Claude', 'Gemini', 'Perplexity', 'Mistral'].map((tool) => (
                <span style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; padding: 4px 12px; font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.6);">{tool}</span>
              ))}
            </div>
          </div>

          <!-- Screenshots Cercle GPT -->
          <div style="display: flex; flex-direction: column; gap: 10px;">
            <img
              src="/images/cercle-gpt/landing.png"
              alt="Cercle GPT — page d'accueil : accédez à tous les modèles IA depuis une seule interface"
              width="380"
              height="214"
              loading="lazy"
              style="border-radius: 10px; box-shadow: 0 12px 40px rgba(0,0,0,0.55); border: 1px solid rgba(255,255,255,0.1); width: 100%; height: auto; display: block;"
            />
            <img
              src="/images/cercle-gpt/app.png"
              alt="Cercle GPT — interface de l'application : sélecteur de modèle, zone de chat et bibliothèque de prompts"
              width="380"
              height="214"
              loading="lazy"
              style="border-radius: 10px; box-shadow: 0 12px 40px rgba(0,0,0,0.55); border: 1px solid rgba(255,255,255,0.1); width: 100%; height: auto; display: block;"
            />
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ========== SESSION & INVESTISSEMENT ========== -->
  <section id="inscription" style="background: var(--color-light-1); padding: 96px 0;">
    <div class="container">
      <div class="grid-2" style="gap: 56px; align-items: start;">

        <div>
          <span class="section-eyebrow">Prochaine session</span>
          <h2 class="section-title" style="color: var(--color-text-on-light);">Été 2026.</h2>
          <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.8; margin-top: 16px; margin-bottom: 32px;">
            Les places sont limitées pour garantir la qualité des échanges. Inscrivez-vous sur la liste d'attente pour être notifié en priorité à l'ouverture des inscriptions.
          </p>
          <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <a href="#" data-open-modal="waitlist" class="btn-primary">S'inscrire sur la liste d'attente</a>
            <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline-dark">Planifier un appel</a>
          </div>
        </div>

        <div class="card-white">
          <p style="font-size: 11px; font-weight: 600; color: rgba(6,24,23,0.35); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Investissement</p>
          <p style="font-family: var(--font-display); font-size: 52px; font-weight: 700; color: var(--color-accent); line-height: 1; margin-bottom: 4px;">750 €</p>
          <p style="font-size: 13px; color: rgba(6,24,23,0.35); margin-bottom: 24px;">HTVA · Facturation possible</p>
          <div style="display: flex; flex-direction: column; gap: 10px;">
            {[
              '3 séances masterclass pratiques',
              '1 session de coaching individuel',
              'Bibliothèque de ressources (prompts & templates)',
              'Accès communauté',
              'Cercle GPT — 3 mois offerts',
            ].map((item) => (
              <div style="display: flex; gap: 10px; align-items: center;">
                <span style="color: var(--color-accent); font-weight: 700; font-size: 14px; flex-shrink: 0;">✓</span>
                <p style="font-size: 14px; color: var(--color-text-subtle);">{item}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== TÉMOIGNAGES ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">Ce qu'en disent les participants</span>
          <h2 class="section-title">Concret, sincère,<br />pragmatique et utile.</h2>
        </div>
      </div>
      <div class="grid-3" style="gap: 16px; align-items: start;">
        {[
          {
            pull: 'Highly recommended for anyone willing to get down to the brass tacks of this intriguing technology.',
            body: 'I recently completed five 2-hour AI training sessions. The program offered a detailed overview of key AI tools and provided very concrete, practice-oriented guidance.',
            name: 'Prescillia Algrain',
            role: 'Counsel',
            org: 'Janson Law Firm',
            initials: 'PA',
          },
          {
            pull: 'À refaire sans modération.',
            body: 'J\'ai suivi 3 formations de 2 heures cette année. Merci Tarik & Team !',
            name: 'Edouard Cambier',
            role: 'Co-Owner',
            org: 'Seed Factory',
            initials: 'EC',
          },
          {
            pull: 'Je recommande vivement.',
            body: 'Parmi l\'amas de formations disponibles, en voici une – enfin – concrète, sincère, pragmatique et utile à tous les indépendants (d\'esprit ou de pratique).',
            name: 'Adam Tricha',
            role: 'Avocat',
            org: 'Barreau de Verviers',
            initials: 'AT',
          },
        ].map((t) => (
          <div class="glass-card" style="display: flex; flex-direction: column; padding: 28px 28px 24px;">
            <span style="font-family: var(--font-display); font-size: 48px; line-height: 1; color: var(--color-accent); opacity: 0.7; margin-bottom: 8px; display: block;">&ldquo;</span>
            <p style="font-family: var(--font-display); font-size: 17px; font-weight: 700; color: #ffffff; line-height: 1.4; letter-spacing: -0.01em; margin-bottom: 12px; flex: 1;">{t.pull}</p>
            {t.body && (
              <p style="font-family: var(--font-body); font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.7; margin-bottom: 0;">{t.body}</p>
            )}
            <div style="display: flex; align-items: center; gap: 10px; margin-top: 20px; padding-top: 18px; border-top: 1px solid rgba(255,255,255,0.07);">
              <div class="testimonial-avatar">{t.initials}</div>
              <div>
                <p style="font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.8); line-height: 1.3;">{t.name}</p>
                <p style="font-size: 11px; color: rgba(255,255,255,0.35); margin-top: 2px;">{t.role}, {t.org}</p>
              </div>
