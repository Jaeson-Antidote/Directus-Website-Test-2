---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumb, courseSchema, faqSchema } from '../lib/schema';
import content from '../content/pages/fr/bootcamp.json';

const { meta, schema, hero, problemSolution, programme, session, testimonials, trainer, faq, ctaFinal } = content;

const bc = breadcrumb([{ name: 'Bootcamp IA', href: '/bootcamp' }]);

const course = courseSchema({
  name: schema.course.name,
  description: schema.course.description,
  url: '/bootcamp',
  offers: { price: schema.course.price, priceCurrency: schema.course.priceCurrency },
  courseMode: schema.course.courseMode,
  startDate: schema.course.startDate,
  timeRequired: schema.course.timeRequired,
});

const faqSchema_ = faqSchema(faq.items);

const pageSchema = {
  '@context': 'https://schema.org',
  '@graph': [course, bc, faqSchema_],
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  schema={pageSchema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 96px 0 112px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.06) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      <div class="hero-inner">

        <div>
          <div class="eyebrow-badge" style="margin-bottom: 28px; display: inline-flex;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
            {hero.eyebrow}
          </div>

          <h1 class="hero-title">
            {hero.title}<br />
            <span style="color: rgba(255,255,255,0.55);">{hero.titleMuted}</span>
          </h1>

          <p style="font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.75; max-width: 560px; margin-bottom: 36px;">
            {hero.description}
          </p>

          <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 32px;">
            <a href="#" data-open-modal="waitlist" class="btn-primary">{hero.ctaPrimary}</a>
            <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline">{hero.ctaSecondary}</a>
          </div>

          <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
            <span style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.2); letter-spacing: 0.08em; text-transform: uppercase; margin-right: 4px; white-space: nowrap;">Pour</span>
            {hero.audienceTags.map((p) => (
              <span class="tag-outline" style="font-size: 10px; padding: 3px 10px;">{p}</span>
            ))}
          </div>
        </div>

        <div style="padding-top: 36px;">
          <div style="background: rgba(255,255,255,0.05); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.09); border-radius: var(--radius-xl); padding: 36px 32px;">

            <h2 style="font-family: var(--font-display); font-size: 26px; font-weight: 700; color: #ffffff; line-height: 1.2; letter-spacing: -0.015em; margin-bottom: 28px;">{hero.sessionBox.title}</h2>

            <div style="display: flex; flex-direction: column; gap: 20px;">
              {[
                { label: hero.sessionBox.items[0], icon: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>' },
                { label: hero.sessionBox.items[1], icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },
                { label: hero.sessionBox.items[2], icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>' },
                { label: hero.sessionBox.items[3], icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>' },
              ].map((item) => (
                <div style="display: flex; align-items: center; gap: 16px;">
                  <div style="width: 40px; height: 40px; border-radius: 50%; background: rgba(247,171,110,0.12); border: 1px solid rgba(247,171,110,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
                  </div>
                  <p style="font-size: 15px; font-weight: 500; color: rgba(255,255,255,0.8); font-family: var(--font-body);">{item.label}</p>
                </div>
              ))}
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== PROBLÈME / SOLUTION ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">

      <div style="max-width: 720px; margin-bottom: 56px;">
        <span class="section-eyebrow">{problemSolution.eyebrow}</span>
        <h2 class="section-title">{problemSolution.title}</h2>
        <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin-top: 20px;">
          {problemSolution.intro}
        </p>
      </div>

      <div style="background: var(--color-light-1); border-radius: calc(var(--radius-lg) + 4px); padding: 4px; margin-bottom: 40px; box-shadow: 0 4px 32px rgba(0,0,0,0.3);">
      <div style="border: 1px solid rgba(6,24,23,0.1); border-radius: var(--radius-lg); overflow: hidden; display: grid; grid-template-columns: 1fr 1fr;">

        <div style="padding: 16px 28px; background: rgba(6,24,23,0.04); border-right: 1px solid rgba(6,24,23,0.08); border-bottom: 1px solid rgba(6,24,23,0.08);">
          <p style="font-size: 11px; font-weight: 600; color: rgba(6,24,23,0.4); letter-spacing: 0.1em; text-transform: uppercase;">{problemSolution.headerProblem}</p>
        </div>
        <div style="padding: 16px 28px; background: rgba(247,171,110,0.1); border-bottom: 1px solid rgba(247,171,110,0.15);">
          <p style="font-size: 11px; font-weight: 600; color: var(--color-accent-hover); letter-spacing: 0.1em; text-transform: uppercase;">{problemSolution.headerSolution}</p>
        </div>

        {problemSolution.rows.map((row, i) => (
          <>
            <div style={`padding: 28px; background: rgba(6,24,23,0.02); border-right: 1px solid rgba(6,24,23,0.08); display: flex; gap: 14px; align-items: flex-start;${i < problemSolution.rows.length - 1 ? ' border-bottom: 1px solid rgba(6,24,23,0.06);' : ''}`}>
              <span style="width: 18px; height: 18px; border-radius: 50%; border: 1px solid rgba(6,24,23,0.2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 3px;">
                <span style="width: 5px; height: 5px; border-radius: 50%; background: rgba(6,24,23,0.3); display: block;"></span>
              </span>
              <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.7;">{row.problem}</p>
            </div>
            <div style={`padding: 28px; background: rgba(247,171,110,0.05); display: flex; gap: 14px; align-items: flex-start;${i < problemSolution.rows.length - 1 ? ' border-bottom: 1px solid rgba(247,171,110,0.1);' : ''}`}>
              <span style="width: 18px; height: 18px; border-radius: 50%; background: rgba(247,171,110,0.25); border: 1px solid rgba(247,171,110,0.5); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 3px;">
                <span style="color: var(--color-accent-hover); font-size: 10px; font-weight: 700; line-height: 1;">✓</span>
              </span>
              <div>
                <p style="font-size: 15px; font-weight: 600; color: var(--color-text-on-light); line-height: 1.4; margin-bottom: 6px;">{row.solutionTitle}</p>
                <p style="font-size: 13px; color: var(--color-text-subtle); line-height: 1.75;">{row.solutionDesc}</p>
              </div>
            </div>
          </>
        ))}

      </div>
      </div>

    </div>
  </section>

  <!-- ========== PROGRAMME ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">

      <div class="section-header">
        <div>
          <span class="section-eyebrow">{programme.eyebrow}</span>
          <h2 class="section-title">{programme.title}<br />{programme.titleLine2}</h2>
        </div>
        <a href="#" data-open-modal="programme" class="btn-primary" style="white-space: nowrap; flex-shrink: 0;">{programme.ctaLabel} &rarr;</a>
      </div>

      <div class="grid-2" style="gap: 20px; margin-bottom: 32px;">
        {programme.pillars.map((pillar) => (
          <div class="glass-card" style="display: flex; flex-direction: column; gap: 16px;">
            <span class="usp-number">{pillar.number}</span>
            <h3 class="usp-title">{pillar.title}</h3>
            <div style="display: flex; flex-direction: column; gap: 9px;">
              {pillar.items.map((item) => (
                <div style="display: flex; gap: 10px; align-items: flex-start;">
                  <span style="color: var(--color-accent); font-size: 12px; flex-shrink: 0; margin-top: 2px;">▸</span>
                  <p style="font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5;">{item}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="glass-card" style="border-color: rgba(247,171,110,0.22); background: rgba(247,171,110,0.04); overflow: hidden;">
        <div style="display: grid; grid-template-columns: 1fr 380px; gap: 40px; align-items: center;">

          <div>
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
              <span class="tag">{programme.bonus.tag}</span>
            </div>
            <h3 style="font-family: var(--font-display); font-size: 26px; font-weight: 700; color: #ffffff; margin-bottom: 10px; line-height: 1.2;">{programme.bonus.title}</h3>
            <p style="font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.75; margin-bottom: 24px; max-width: 460px;">{programme.bonus.description}</p>

            <div style="display: flex; gap: 28px; flex-wrap: wrap; margin-bottom: 24px;">
              {programme.bonus.stats.map((s) => (
                <div>
                  <p style="font-family: var(--font-display); font-size: 24px; font-weight: 700; color: #ffffff; line-height: 1;">{s.value}</p>
                  <p style="font-size: 11px; color: rgba(255,255,255,0.35); margin-top: 3px;">{s.label}</p>
                </div>
              ))}
            </div>

            <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
              {programme.bonus.tools.map((tool) => (
                <span style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; padding: 4px 12px; font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.6);">{tool}</span>
              ))}
            </div>
          </div>

          <div style="display: flex; flex-direction: column; gap: 10px;">
            <img
              src="/images/cercle-gpt/landing.png"
              alt="Cercle GPT — page d'accueil : accédez à tous les modèles IA depuis une seule interface"
              width="380"
              height="214"
              loading="lazy"
              style="border-radius: 10px; box-shadow: 0 12px 40px rgba(0,0,0,0.55); border: 1px solid rgba(255,255,255,0.1); width: 100%; height: auto; display: block;"
            />
            <img
              src="/images/cercle-gpt/app.png"
              alt="Cercle GPT — interface de l'application : sélecteur de modèle, zone de chat et bibliothèque de prompts"
              width="380"
              height="214"
              loading="lazy"
              style="border-radius: 10px; box-shadow: 0 12px 40px rgba(0,0,0,0.55); border: 1px solid rgba(255,255,255,0.1); width: 100%; height: auto; display: block;"
            />
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ========== SESSION & INVESTISSEMENT ========== -->
  <section id="inscription" style="background: var(--color-light-1); padding: 96px 0;">
    <div class="container">
      <div class="grid-2" style="gap: 56px; align-items: start;">

        <div>
          <span class="section-eyebrow">{session.eyebrow}</span>
          <h2 class="section-title" style="color: var(--color-text-on-light);">{session.title}</h2>
          <p style="font-size: 15px; color: var(--color-text-subtle); line-height: 1.8; margin-top: 16px; margin-bottom: 32px;">
            {session.description}
          </p>
          <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <a href="#" data-open-modal="waitlist" class="btn-primary">{session.ctaPrimary}</a>
            <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline-dark">{session.ctaSecondary}</a>
          </div>
        </div>

        <div class="card-white">
          <p style="font-size: 11px; font-weight: 600; color: rgba(6,24,23,0.35); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">{session.investment.label}</p>
          <p style="font-family: var(--font-display); font-size: 52px; font-weight: 700; color: var(--color-accent); line-height: 1; margin-bottom: 4px;">{session.investment.price}</p>
          <p style="font-size: 13px; color: rgba(6,24,23,0.35); margin-bottom: 24px;">{session.investment.subtitle}</p>
          <div style="display: flex; flex-direction: column; gap: 10px;">
            {session.investment.includes.map((item) => (
              <div style="display: flex; gap: 10px; align-items: center;">
                <span style="color: var(--color-accent); font-weight: 700; font-size: 14px; flex-shrink: 0;">✓</span>
                <p style="font-size: 14px; color: var(--color-text-subtle);">{item}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== TÉMOIGNAGES ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">{testimonials.eyebrow}</span>
          <h2 class="section-title">{testimonials.title}<br />{testimonials.titleLine2}</h2>
        </div>
      </div>
      <div class="grid-3" style="gap: 16px; align-items: start;">
        {testimonials.items.map((t) => (
          <div class="glass-card" style="display: flex; flex-direction: column; padding: 28px 28px 24px;">
            <span style="font-family: var(--font-display); font-size: 48px; line-height: 1; color: var(--color-accent); opacity: 0.7; margin-bottom: 8px; display: block;">&ldquo;</span>
            <p style="font-family: var(--font-display); font-size: 17px; font-weight: 700; color: #ffffff; line-height: 1.4; letter-spacing: -0.01em; margin-bottom: 12px; flex: 1;">{t.pull}</p>
            {t.body && (
              <p style="font-family: var(--font-body); font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.7; margin-bottom: 0;">{t.body}</p>
            )}
            <div style="display: flex; align-items: center; gap: 10px; margin-top: 20px; padding-top: 18px; border-top: 1px solid rgba(255,255,255,0.07);">
              <div class="testimonial-avatar">{t.initials}</div>
              <div>
                <p style="font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.8); line-height: 1.3;">{t.name}</p>
                <p style="font-size: 11px; color: rgba(255,255,255,0.35); margin-top: 2px;">{t.role}, {t.org}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== FORMATEUR ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <div class="grid-2" style="gap: 80px; align-items: start;">
        <div>
          <span class="section-eyebrow">{trainer.eyebrow}</span>
          <h2 style="font-family: var(--font-display); font-size: clamp(40px, 5vw, 64px); font-weight: 700; color: #ffffff; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 24px; margin-top: 4px;">{trainer.name}</h2>
          <div style="width: 36px; height: 2px; background: var(--color-accent); margin-bottom: 24px;"></div>
          <p style="font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.8; margin-bottom: 16px; max-width: 420px;">{trainer.bio}</p>
          <p style="font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.8; max-width: 420px; margin-bottom: 32px; font-style: italic;">"{trainer.quote}"</p>
          <a href={trainer.ctaHref} class="btn-text-link">{trainer.ctaLabel} &rarr;</a>
        </div>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          {trainer.stats.map((s) => (
            <div class="glass-card" style="padding: 20px 24px; display: flex; align-items: center; gap: 20px;">
              <span class="stat-number" style="flex-shrink: 0;">{s.number}</span>
              <p class="stat-label" style="margin-top: 0;">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">
      <div style="max-width: 760px; margin: 0 auto;">
        <span class="section-eyebrow">{faq.eyebrow}</span>
        <h2 class="section-title" style="margin-bottom: 48px;">{faq.title}<br />{faq.titleLine2}</h2>
        <div style="display: flex; flex-direction: column; gap: 16px;">
          {faq.items.map((item) => (
            <div class="glass-card">
              <h3 style="font-family: var(--font-display); font-size: 17px; font-weight: 700; color: #ffffff; line-height: 1.4; margin-bottom: 10px;">{item.question}</h3>
              <p style="font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.75;">{item.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section class="grain-bg" style="background-color: var(--color-dark-2); padding: 96px 0;">
    <div class="container" style="text-align: center; max-width: 680px;">
      <div class="eyebrow-badge" style="margin-bottom: 28px; display: inline-flex;">
        <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
        {ctaFinal.badge}
      </div>
      <h2 style="font-family: var(--font-display); font-size: clamp(28px, 4vw, 44px); font-weight: 500; color: #ffffff; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 16px;">
        {ctaFinal.title}
      </h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.4); line-height: 1.7; margin-bottom: 36px;">
        {ctaFinal.description}
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href="#" data-open-modal="waitlist" class="btn-primary">{ctaFinal.ctaPrimary}</a>
        <a href="https://bookme.name/tarikhennen/lite/rdv-le-cercle-ia" class="btn-outline">{ctaFinal.ctaSecondary}</a>
      </div>
    </div>
  </section>

</BaseLayout>
