---
import BaseLayout from '../layouts/BaseLayout.astro';
import { personSchema, breadcrumb } from '../lib/schema';

const bc = breadcrumb([{ name: 'À propos', href: '/a-propos' }]);
const person = personSchema();

const schema = {
  '@context': 'https://schema.org',
  '@graph': [person, bc],
};

const testimonials = [
  {
    pull: 'Si vous souhaitez réellement dépasser les poncifs que l\'on entend sans cesse sur l\'IA, c\'est la formation qu\'il vous faut.',
    name: 'Laurent Peretti',
    role: '',
    org: '',
    initials: 'LP',
  },
  {
    pull: 'Very concrete, practice-oriented guidance. This comment was not generated by AI.',
    body: 'I recently completed five 2-hour AI training sessions. Highly recommended for anyone willing to get down to the brass tacks of this intriguing technology.',
    name: 'Prescillia Algrain',
    role: 'Counsel',
    org: 'Janson Law Firm',
    initials: 'PA',
  },
  {
    pull: 'Tarik est un excellent pédagogue, très concret, qui sait s\'adapter à son audience.',
    name: 'Vincent Laborderie',
    role: 'Lecturer in European Affairs',
    org: 'UCLouvain',
    initials: 'VL',
  },
  {
    pull: 'Sa connaissance fine des forces, des limites et des usages est déterminante pour faire progresser notre équipe internationale.',
    name: 'Marc D. David',
    role: 'Professeur titulaire',
    org: 'Université de Sherbrooke',
    initials: 'MD',
  },
];

const approche = [
  { num: '01', title: 'Identifier ce qui prend du temps', desc: 'Repérer les tâches qui absorbent de l\'énergie sans créer de valeur, et distinguer celles où l\'IA peut prendre le relais de façon fiable.' },
  { num: '02', title: 'Formuler des instructions précises', desc: 'Apprendre à écrire des instructions qui donnent des résultats utilisables, pas des résultats qu\'il faut entièrement réécrire.' },
  { num: '03', title: 'Vérifier ce qui sort', desc: 'Reconnaître quand un outil se trompe sans le signaler. Savoir évaluer un résultat avant de s\'en servir.' },
  { num: '04', title: 'Construire une méthode durable', desc: 'Repartir avec une pratique qu\'on peut faire évoluer seul. Pas une liste de fonctionnalités, une posture de jugement.' },
];
---

<BaseLayout
  title="À propos — Cercle IA"
  description="Cercle IA forme les professionnels à utiliser l'IA avec discernement, méthode et éthique. Fondé par Tarik Hennen, praticien IA depuis 2021 dans des contextes à responsabilité."
  ogImage="/og/a-propos.jpg"
  ogImageAlt="À propos — Cercle IA"
  schema={schema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 96px 0 112px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.06) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 380px; gap: 48px; align-items: center;">

        <!-- Texte gauche -->
        <div>
          <div class="eyebrow-badge" style="margin-bottom: 28px; display: inline-flex;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
            Formations IA pour professionnels · Depuis 2024
          </div>

          <h1 class="hero-title" style="font-size: clamp(28px, 3.2vw, 44px) !important; line-height: 1.2;">
            Vous savez que l'IA peut changer votre façon de travailler.
            <span style="color: rgba(255,255,255,0.55);">Vous ne savez pas encore si vous pouvez lui faire confiance.</span>
          </h1>

          <p style="font-size: 17px; color: rgba(255,255,255,0.5); line-height: 1.8; max-width: 560px; margin-bottom: 16px;">
            Le doute d'un juriste, d'un médecin ou d'un dirigeant face à un outil qu'il ne contrôle pas complètement n'est pas un frein. C'est une compétence professionnelle qui fonctionne exactement comme elle devrait.
          </p>

          <p style="font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.8; max-width: 560px; margin-bottom: 36px; font-style: italic;">
            Bonne nouvelle : c'est le bon point de départ.
          </p>

          <div style="margin-bottom: 48px;">
            <a href="/formations" class="btn-primary">Découvrir les formations</a>
          </div>

          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.06);">
            <div>
              <span class="stat-number">250+</span>
              <p class="stat-label">Professionnels formés</p>
            </div>
            <div>
              <span class="stat-number">2021</span>
              <p class="stat-label">Début de pratique</p>
            </div>
            <div>
              <span class="stat-number">3</span>
              <p class="stat-label">Formats disponibles</p>
            </div>
          </div>
        </div>

        <!-- Photo droite -->
        <div class="hero-photo-col" style="position: relative;">
          <div style="border-radius: var(--radius-xl); overflow: hidden; border: 1px solid rgba(255,255,255,0.08);">
            <img
              src="/images/tarik-hennen-formation.png"
              alt="Tarik Hennen, formateur IA — Cercle IA"
              width="802"
              height="1000"
              loading="eager"
              style="width: 100%; height: auto; display: block;"
            />
          </div>
          <div style="position: absolute; bottom: -16px; left: -16px; background: var(--color-dark-2); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-lg); padding: 14px 18px; backdrop-filter: blur(16px);">
            <p style="font-size: 12px; font-weight: 600; color: #ffffff; line-height: 1.3;">Tarik Hennen</p>
            <p style="font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px;">Fondateur, Cercle IA</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== LE PROBLÈME ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <div class="grid-2" style="gap: 80px; align-items: start;">

        <div>
          <span class="section-eyebrow">Le problème du doute</span>
          <h2 class="section-title">Vous n'êtes pas le public des démos.</h2>
          <div style="width: 36px; height: 2px; background: var(--color-accent); margin-top: 24px; margin-bottom: 24px;"></div>
          <p style="font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.85; margin-bottom: 20px; max-width: 440px;">
            Vous avez probablement déjà assisté à une démonstration impressionnante. Trente secondes, un résultat spectaculaire, une salle qui s'anime. Et le lundi suivant, la même question : mais dans mon travail à moi, avec mes contraintes à moi, qu'est-ce que j'en fais vraiment ?
          </p>
          <p style="font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.85; max-width: 440px;">
            Cette question n'est pas un manque de curiosité. C'est du discernement. Et c'est exactement là que nous commençons.
          </p>
        </div>

        <div style="padding-top: 48px;">
          <p style="font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.85; margin-bottom: 24px; max-width: 440px;">
            Le problème n'est pas le scepticisme. C'est de rester là, sans méthode, pendant que d'autres construisent une pratique solide.
          </p>
          <p style="font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.85; max-width: 440px; font-weight: 500;">
            Cercle IA existe pour transformer ce doute en jugement opérationnel.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== POUR QUI ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">
      <div style="margin-bottom: 48px;">
        <span class="section-eyebrow">Des professionnels dont les erreurs ont un coût</span>
        <h2 class="section-title" style="max-width: 560px;">Des professionnels dont les erreurs ont un coût.</h2>
      </div>
      <div class="grid-3" style="gap: 20px;">
        {[
          {
            title: 'Juristes et avocats',
            desc: 'Secret professionnel, confidentialité des données clients, qualité des sources. Des contraintes qui ne sont pas optionnelles.',
          },
          {
            title: 'Responsables RH',
            desc: 'Données personnelles, RGPD, processus de décision. L\'IA dans les RH n\'est pas neutre et demande un cadre clair.',
          },
          {
            title: 'Dirigeants & consultants',
            desc: 'Temps limité, décisions à fort enjeu. Ce qu\'il faut déléguer, ce qu\'il faut continuer à piloter, et comment évaluer ce qui sort.',
          },
        ].map((item) => (
          <div class="glass-card">
            <h3 style="font-family: var(--font-display); font-size: 18px; font-weight: 700; color: #ffffff; line-height: 1.3; margin-bottom: 12px;">{item.title}</h3>
            <p style="font-size: 14px; color: rgba(255,255,255,0.4); line-height: 1.75;">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== NOTRE APPROCHE ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <div style="margin-bottom: 56px; max-width: 640px;">
        <span class="section-eyebrow">Notre approche</span>
        <h2 class="section-title">Le point de départ n'est pas l'outil. C'est le travail.</h2>
      </div>
      <div class="grid-2" style="gap: 20px;">
        {approche.map((step) => (
          <div class="glass-card" style="display: flex; gap: 20px; align-items: start;">
            <span style="font-family: var(--font-display); font-size: 13px; font-weight: 700; color: var(--color-accent); letter-spacing: 0.04em; flex-shrink: 0; padding-top: 2px;">{step.num}</span>
            <div>
              <h3 style="font-family: var(--font-display); font-size: 17px; font-weight: 700; color: #ffffff; line-height: 1.3; margin-bottom: 10px;">{step.title}</h3>
              <p style="font-size: 14px; color: rgba(255,255,255,0.4); line-height: 1.75;">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== FORMATIONS ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">

      <div style="margin-bottom: 56px;">
        <span class="section-eyebrow">Les formations</span>
        <h2 class="section-title">Un seul principe : partir de votre réalité.</h2>
      </div>

      <div class="grid-2" style="gap: 48px; align-items: stretch;">

        <!-- Sessions ouvertes -->
        <div style="display: flex; flex-direction: column;">
          <p style="font-size: 11px; font-weight: 700; color: var(--color-accent); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px;">Sessions ouvertes</p>
          <h3 style="font-family: var(--font-display); font-size: 20px; font-weight: 700; color: #ffffff; line-height: 1.3; margin-bottom: 12px;">Rejoindre une formation existante</h3>
          <p style="font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.75; margin-bottom: 28px;">Des sessions conçues pour des professionnels aux contraintes similaires. Vous intégrez un groupe, vous repartez avec une méthode.</p>

          <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 28px; flex: 1;">
            <div class="glass-card" style="display: flex; flex-direction: column; flex: 1;">
              <h4 style="font-family: var(--font-display); font-size: 16px; font-weight: 700; color: #ffffff; line-height: 1.3; margin-bottom: 10px;">Bootcamp IA</h4>
              <p style="font-size: 13px; color: rgba(255,255,255,0.4); line-height: 1.7; flex: 1;">Plusieurs sessions intensives. Un travail en profondeur sur vos cas d'usage, avec le temps d'expérimenter et de corriger. Pour ceux qui veulent une autonomie réelle, pas une initiation.</p>
            </div>
            <div class="glass-card" style="display: flex; flex-direction: column; flex: 1;">
              <h4 style="font-family: var(--font-display); font-size: 16px; font-weight: 700; color: #ffffff; line-height: 1.3; margin-bottom: 10px;">Formations métiers</h4>
              <p style="font-size: 13px; color: rgba(255,255,255,0.4); line-height: 1.7; flex: 1;">Conçues pour des contextes précis : avocats, médecins, équipes RH, directions. Les contraintes du métier ne sont pas évoquées en introduction — elles structurent chaque exercice.</p>
            </div>
          </div>

          <a href="/formations" style="font-size: 14px; font-weight: 600; color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px;">Voir les prochaines sessions</a>
        </div>

        <!-- Sur mesure -->
        <div style="display: flex; flex-direction: column;">
          <p style="font-size: 11px; font-weight: 700; color: var(--color-accent); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px;">Sur mesure</p>
          <h3 style="font-family: var(--font-display); font-size: 20px; font-weight: 700; color: #ffffff; line-height: 1.3; margin-bottom: 12px;">Un accompagnement construit pour vous</h3>
          <p style="font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.75; margin-bottom: 28px;">Quand un programme standard ne correspond pas à votre situation. Conçu à partir de vos cas d'usage réels, de vos outils, de vos contraintes.</p>

          <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 28px; flex: 1;">
            <div class="glass-card" style="display: flex; flex-direction: column; flex: 1;">
              <h4 style="font-family: var(--font-display); font-size: 16px; font-weight: 700; color: #ffffff; line-height: 1.3; margin-bottom: 10px;">Formation entreprise</h4>
              <p style="font-size: 13px; color: rgba(255,255,255,0.4); line-height: 1.7; flex: 1;">Construite pour une équipe ou une organisation. Pas un programme standard repackagé avec votre logo en couverture — une formation conçue à partir de vos processus réels.</p>
            </div>
            <div class="glass-card" style="display: flex; flex-direction: column; flex: 1;">
              <h4 style="font-family: var(--font-display); font-size: 16px; font-weight: 700; color: #ffffff; line-height: 1.3; margin-bottom: 10px;">Coaching individuel</h4>
              <p style="font-size: 13px; color: rgba(255,255,255,0.4); line-height: 1.7; flex: 1;">Un accompagnement 1-to-1 centré sur votre pratique, votre métier, vos questions. Le rythme et le contenu s'adaptent à votre progression.</p>
            </div>
          </div>

          <a href="/contact" style="font-size: 14px; font-weight: 600; color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px;">Discutons de votre situation</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== TÉMOIGNAGES ========== -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">Ce que disent les participants</span>
          <h2 class="section-title">Concret, sincère,<br />pragmatique et utile.</h2>
        </div>
      </div>
      <div class="grid-2" style="gap: 16px; align-items: start;">
        {testimonials.map((t) => (
          <div class="glass-card" style="display: flex; flex-direction: column; padding: 28px 28px 24px;">
            <span style="font-family: var(--font-display); font-size: 48px; line-height: 1; color: var(--color-accent); opacity: 0.7; margin-bottom: 8px; display: block;">&ldquo;</span>
            <p style="font-family: var(--font-display); font-size: 17px; font-weight: 700; color: #ffffff; line-height: 1.4; letter-spacing: -0.01em; margin-bottom: 12px; flex: 1;">{t.pull}</p>
            {t.body && (
              <p style="font-family: var(--font-body); font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.7; margin-bottom: 0;">{t.body}</p>
            )}
            <div style="display: flex; align-items: center; gap: 10px; margin-top: 20px; padding-top: 18px; border-top: 1px solid rgba(255,255,255,0.07);">
              <div class="testimonial-avatar">{t.initials}</div>
              <div>
                <p style="font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.8); line-height: 1.3;">{t.name}</p>
                {(t.role || t.org) && (
                  <p style="font-size: 11px; color: rgba(255,255,255,0.35); margin-top: 2px;">{t.role}{t.role && t.org ? ', ' : ''}{t.org}</p>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== FORMATEUR ========== -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">
      <div class="grid-2" style="gap: 80px; align-items: start;">

        <div>
          <span class="section-eyebrow">Le formateur</span>
          <h2 style="font-family: var(--font-display); font-size: clamp(36px, 4.5vw, 56px); font-weight: 700; color: #ffffff; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 8px; margin-top: 4px;">Tarik Hennen.</h2>
          <p style="font-size: 13px; color: rgba(255,255,255,0.35); margin-bottom: 24px;">Ancien juriste · Fondateur de Cercle IA · Fondateur d'Antidote Digital</p>
          <div style="width: 36px; height: 2px; background: var(--color-accent); margin-bottom: 28px;"></div>

          <p style="font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.85; margin-bottom: 20px; max-width: 480px;">
            Tarik Hennen n'a pas fondé Cercle IA parce que l'IA l'enthousiasmait. Il l'a fondé parce qu'il utilisait ces outils depuis 2021, dans des contextes où l'erreur coûte, et qu'il ne trouvait aucune formation conçue pour des professionnels avec de vraies responsabilités engagées.
          </p>

          <p style="font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.85; margin-bottom: 20px; max-width: 480px;">
            Ce parcours produit un point de vue précis : celui de quelqu'un qui a travaillé sous contrainte réelle, avec des données sensibles, dans des équipes où les résultats se mesurent chaque semaine. Pas depuis la tribune de l'observateur enthousiaste.
          </p>

          <p style="font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.85; margin-bottom: 32px; max-width: 480px;">
            Il enseigne à l'IHECS, à l'EPHEC et à l'UCLouvain. Il collabore avec des chercheurs de l'Université de Sherbrooke et de l'Université de Lille dans le cadre d'un observatoire international sur les transformations des pratiques professionnelles.
          </p>

          <div style="padding: 20px 24px; background: var(--glass-bg); border-left: 2px solid var(--color-accent); border-radius: 0 var(--radius-lg) var(--radius-lg) 0; margin-bottom: 32px; max-width: 480px;">
            <p style="font-size: 14px; color: rgba(255,255,255,0.55); line-height: 1.7; font-style: italic;">"Sa connaissance fine des forces, des limites et des usages des différentes plateformes est déterminante pour faire progresser notre équipe internationale."</p>
            <p style="font-size: 12px; color: rgba(255,255,255,0.3); margin-top: 10px;">Marc D. David, Professeur titulaire — Université de Sherbrooke</p>
          </div>

          <a href="/contact" class="btn-text-link">Planifier un appel avec Tarik &rarr;</a>
        </div>

        <div>
          <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px;">
            {[
              { number: '2021', label: 'Praticien IA depuis' },
              { number: '250+', label: 'Professionnels formés' },
              { number: '15 ans', label: 'D\'expérience terrain' },
            ].map((s) => (
              <div class="glass-card" style="padding: 20px 24px; display: flex; align-items: center; gap: 20px;">
                <span class="stat-number" style="flex-shrink: 0;">{s.number}</span>
                <p class="stat-label" style="margin-top: 0;">{s.label}</p>
              </div>
            ))}
          </div>

          <div class="glass-card">
            <p style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.25); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;">Formation</p>
            <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px;">
              <p style="font-size: 14px; color: rgba(255,255,255,0.55);">DEA, Université de Liège</p>
              <p style="font-size: 14px; color: rgba(255,255,255,0.55);">LL.M., King's College London</p>
            </div>
            <div style="height: 1px; background: rgba(255,255,255,0.07); margin-bottom: 20px;"></div>
            <p style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.25); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;">Expérience</p>
            <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px;">
              <p style="font-size: 14px; color: rgba(255,255,255,0.55);">Avocat chez Stibbe</p>
              <p style="font-size: 14px; color: rgba(255,255,255,0.55);">Avocat chez Squire Patton Boggs</p>
            </div>
            <div style="height: 1px; background: rgba(255,255,255,0.07); margin-bottom: 20px;"></div>
            <p style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.25); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;">Enseignements</p>
            <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px;">
              {['IHECS', 'EPHEC', 'UCLouvain'].map((inst) => (
                <p style="font-size: 14px; color: rgba(255,255,255,0.55);">{inst}</p>
              ))}
            </div>
            <div style="height: 1px; background: rgba(255,255,255,0.07); margin-bottom: 20px;"></div>
            <p style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.25); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;">Recherche</p>
            <div style="display: flex; flex-direction: column; gap: 8px;">
              <p style="font-size: 14px; color: rgba(255,255,255,0.55);">Université de Sherbrooke</p>
              <p style="font-size: 14px; color: rgba(255,255,255,0.55);">Université de Lille</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section class="grain-bg" style="background-color: var(--color-dark-2); padding: 96px 0;">
    <div class="container" style="max-width: 800px;">

      <p style="font-size: 16px; color: rgba(255,255,255,0.45); line-height: 1.85; margin-bottom: 56px; max-width: 640px;">
        Ce n'est pas le bon endroit si vous cherchez un certificat généraliste ou une case à cocher. C'est le bon endroit si vous voulez comprendre vraiment.
      </p>

      <div class="grid-2" style="gap: 32px; align-items: stretch; margin-bottom: 48px;">
        <div class="glass-card" style="display: flex; flex-direction: column;">
          <span class="section-eyebrow" style="margin-bottom: 16px;">Ce que vous cherchez</span>
          <p style="font-size: 15px; color: rgba(255,255,255,0.55); line-height: 1.8; flex: 1;">Savoir ce que vous pouvez déléguer à l'IA dans votre métier, comment le faire sans risque, et comment juger par vous-même ce qui fonctionne vraiment.</p>
        </div>
        <div class="glass-card" style="display: flex; flex-direction: column;">
