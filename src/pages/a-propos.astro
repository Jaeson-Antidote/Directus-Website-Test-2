---
import BaseLayout from '../layouts/BaseLayout.astro';
import { personSchema, breadcrumb, faqSchema } from '../lib/schema';
import content from '../content/pages/fr/a-propos.json';

const bc = breadcrumb([{ name: 'À propos', href: '/a-propos' }]);
const person = personSchema();

const faq = faqSchema(
  content.faq.items.map((item) => ({ question: item.question, answer: item.answer }))
);

const schema = {
  '@context': 'https://schema.org',
  '@graph': [person, bc, faq],
};
---

<BaseLayout
  title={content.meta.title}
  description={content.meta.description}
  ogImage={content.meta.ogImage}
  ogImageAlt={content.meta.ogImageAlt}
  schema={schema}
>

  <!-- HERO -->
  <section class="hero-gradient grain-bg" style="padding: 96px 0 112px; position: relative; overflow: hidden;">
    <div class="container">
      <div style="max-width: 800px;">
        <div class="eyebrow-badge" style="margin-bottom: 28px; display: inline-flex;">
          <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
          {content.hero.eyebrow}
        </div>

        <h1 class="hero-title" style="max-width: 720px;">
          {content.hero.title}
        </h1>

        <p style="font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.75; max-width: 560px; margin-bottom: 16px;">
          {content.hero.description}
        </p>
        <p style="font-size: 17px; color: rgba(255,255,255,0.4); line-height: 1.75; max-width: 560px; font-style: italic; margin-bottom: 36px;">
          {content.hero.italic}
        </p>

        <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 48px;">
          <a href="/formations" class="btn-primary">{content.hero.ctaPrimary} &rarr;</a>
        </div>

        <div style="display: flex; gap: 48px; flex-wrap: wrap;">
          {content.hero.stats.map((s) => (
            <div>
              <div style="font-family: var(--font-display); font-size: 36px; font-weight: 700; color: var(--color-accent); line-height: 1;">{s.value}</div>
              <div style="font-size: 13px; color: rgba(255,255,255,0.4); margin-top: 6px;">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION: Pour qui -->
  <section style="background: var(--color-light-1); padding: 96px 0;">
    <div class="container">
      <div style="max-width: 720px; margin-bottom: 56px;">
        <span class="section-eyebrow">{content.pourQui.eyebrow}</span>
        <h2 class="section-title" style="color: var(--color-text-on-light);">{content.pourQui.title}</h2>
      </div>
      <div class="grid-3" style="gap: 20px;">
        {content.pourQui.cards.map((card) => (
          <div class="card-white">
            <h3 style="font-family: var(--font-display); font-size: 20px; font-weight: 700; color: var(--color-text-on-light); margin-bottom: 12px;">{card.title}</h3>
            <p style="font-size: 14px; color: var(--color-text-subtle); line-height: 1.7;">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION: Notre approche -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container">
      <div style="max-width: 720px; margin-bottom: 56px;">
        <span class="section-eyebrow">{content.approche.eyebrow}</span>
        <h2 class="section-title">{content.approche.title}</h2>
      </div>
      <div class="grid-2" style="gap: 20px;">
        {content.approche.items.map((item) => (
          <div class="glass-card" style="display: flex; flex-direction: column; gap: 14px;">
            <span class="usp-number">{item.num}</span>
            <h3 class="usp-title">{item.title}</h3>
            <p style="font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.75;">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION: Témoignages -->
  <section style="background: var(--color-dark-2); padding: 96px 0;">
    <div class="container">
      <div style="max-width: 720px; margin-bottom: 56px;">
        <span class="section-eyebrow">{content.testimonials.eyebrow}</span>
        <h2 class="section-title">{content.testimonials.title}</h2>
      </div>
      <div class="grid-2" style="gap: 20px;">
        {content.testimonials.items.map((t) => (
          <div class="glass-card" style="display: flex; flex-direction: column; gap: 16px;">
            <p style="font-size: 16px; font-weight: 600; color: #ffffff; line-height: 1.5; font-style: italic;">"{t.pull}"</p>
            {t.body && <p style="font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.7;">{t.body}</p>}
            <div style="display: flex; gap: 12px; align-items: center; margin-top: auto; padding-top: 8px; border-top: 1px solid rgba(255,255,255,0.07);">
              <div style="width: 36px; height: 36px; border-radius: 50%; background: rgba(247,171,110,0.15); border: 1px solid rgba(247,171,110,0.3); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; color: var(--color-accent); flex-shrink: 0;">{t.initials}</div>
              <div>
                <div style="font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.8);">{t.name}</div>
                {(t.role || t.org) && <div style="font-size: 12px; color: rgba(255,255,255,0.4);">{t.role}{t.role && t.org ? ', ' : ''}{t.org}</div>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section style="background: var(--color-dark-1); padding: 96px 0;">
    <div class="container" style="text-align: center; max-width: 680px;">
      <span class="section-eyebrow">{content.ctaFinal.eyebrow}</span>
      <h2 class="section-title">{content.ctaFinal.title}</h2>
      <div style="margin-top: 32px;">
        <a href={content.ctaFinal.ctaPrimaryHref} class="btn-primary">{content.ctaFinal.ctaPrimary} &rarr;</a>
      </div>
    </div>
  </section>

</BaseLayout>
