---
import BaseLayout from '../layouts/BaseLayout.astro';
import { personSchema, breadcrumb, faqSchema } from '../lib/schema';
import { getPageAbout, getTestimonials, getFaqs } from '../lib/directus';
import AboutContent from '../components/pages/AboutContent.astro';

const bc = breadcrumb([{ name: 'À propos', href: '/a-propos' }]);
const person = personSchema();

const content = await getPageAbout();
if (!content) throw new Error('page_about introuvable dans Directus — vérifiez DIRECTUS_URL');

const testimonials = await getTestimonials('about');
const faqs = await getFaqs('about');

const faq = faqSchema(faqs.map((item) => ({ question: item.question, answer: item.answer })));

const schema = {
  '@context': 'https://schema.org',
  '@graph': [person, bc, faq],
};
---

<BaseLayout
  title={content.seo_title}
  description={content.seo_description}
  ogImage="/og/a-propos.jpg"
  ogImageAlt={content.og_image_alt}
  schema={schema}
>
  <AboutContent {content} {testimonials} />
</BaseLayout>
