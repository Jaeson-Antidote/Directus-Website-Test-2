---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumb, articleItemListSchema } from '../../lib/schema';
import { getArticles, articleImageUrl } from '~/lib/directus';

const bc = breadcrumb([{ name: 'Blog', href: '/blog' }]);

const allArticles = await getArticles();

const itemList = articleItemListSchema({
  name: 'Blog IA pour professionnels — Cercle IA',
  description: "Analyses, guides et ressources pratiques sur l'IA professionnelle.",
  items: allArticles.map((a) => ({ url: `/blog/${a.slug}` })),
});

const schema = {
  '@context': 'https://schema.org',
  '@graph': [bc, itemList],
};
---

<BaseLayout
  title="Blog IA pour professionnels — Cercle IA"
  description="Analyses, guides et ressources pratiques sur l'intelligence artificielle pour les professionnels. Par Cercle IA."
  ogImage="/og/blog.jpg"
  ogImageAlt="Blog IA — Analyses et ressources — Cercle IA"
  schema={schema}
>

  <!-- ========== HERO ========== -->
  <section class="hero-gradient grain-bg" style="padding: 72px 0 64px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; right: -80px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(247,171,110,0.06) 0%, transparent 70%); pointer-events: none;" aria-hidden="true"></div>

    <div class="container">
      <div style="max-width: 680px;">
        <div class="eyebrow-badge" style="margin-bottom: 24px; display: inline-flex;">
          <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; display: inline-block;"></span>
          Blog Cercle IA
        </div>

        <h1 class="hero-title">
          Analyses et ressources<br />
          <span style="color: rgba(255,255,255,0.55);">sur l'IA professionnelle.</span>
        </h1>

        <p style="font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.75; max-width: 560px; margin: 0;">
          Décryptages, guides pratiques et retours d'expérience pour les professionnels qui veulent comprendre l'IA avant de l'adopter.
        </p>
      </div>
    </div>
  </section>

  <!-- ========== ARTICLES ========== -->
  <section style="background: var(--color-dark-1); padding: 56px 0 88px;">
    <div class="container">

      {allArticles.length > 0 ? (
        <div class="blog-grid">
          {allArticles.map((article) => {
            const displayDate = article.updated_date ?? article.pub_date;
            const dateLabel = article.updated_date ? 'Mis à jour ' : '';
            const date = dateLabel + new Intl.DateTimeFormat('fr-BE', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(displayDate));
            const imageUrl = articleImageUrl(article);
            return (
              <a href={`/blog/${article.slug}`} class="blog-card" style="text-decoration: none; display: flex; flex-direction: column;">
                {imageUrl ? (
                  <div class="blog-card-img">
                    <img
                      src={imageUrl}
                      alt={article.image_alt ?? article.title}
                      width={748}
                      height={420}
                      loading="lazy"
                      style="width: 100%; height: 100%; object-fit: cover; display: block;"
                    />
                  </div>
                ) : (
                  <div class="blog-card-img blog-card-img--placeholder" aria-hidden="true"></div>
                )}

                <div class="blog-card-body">
                  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap;">
                    {article.category && (
                      <span class="tag" style="font-size: 10px; padding: 3px 10px;">{article.category}</span>
                    )}
                    <span style="font-size: 12px; color: rgba(255,255,255,0.3);">{date}</span>
                  </div>

                  <h2 style="font-family: var(--font-display); font-size: 19px; font-weight: 700; color: #ffffff; line-height: 1.35; margin-bottom: 16px; flex: 1;">{article.title}</h2>

                  <div style="display: flex; justify-content: flex-end;">
                    <span style="font-size: 13px; font-weight: 600; color: var(--color-accent); white-space: nowrap;">Lire &rarr;</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="glass-card" style="max-width: 560px; margin: 0 auto; padding: 48px 40px; text-align: center;">
          <div style="width: 56px; height: 56px; border-radius: 50%; background: rgba(247,171,110,0.12); border: 1px solid rgba(247,171,110,0.3); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </div>
          <h3 style="font-family: var(--font-display); font-size: 24px; font-weight: 700; color: #ffffff; margin-bottom: 12px;">Les premiers articles arrivent</h3>
          <p style="font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.75; margin-bottom: 28px;">
            Le contenu est en cours de migration.
          </p>
        </div>
      )}

    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section style="background: var(--color-dark-1); padding: 80px 0; border-top: 1px solid rgba(255,255,255,0.05);">
    <div class="container" style="text-align: center; max-width: 680px;">
      <span class="section-eyebrow">Cercle IA</span>
      <h2 class="section-title">Vous avez une question ?</h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.85; margin: 20px 0 32px;">
        Contactez-nous directement — nous répondons à toutes les demandes.
      </p>
      <a href="/contact" class="btn-primary">Nous contacter &rarr;</a>
    </div>
  </section>

</BaseLayout>
