# URL de votre instance Directus (sans slash final)
DIRECTUS_URL=https://cms.tondomaine.com

# Token lecture seule pour le build (Directus > Settings > Access Tokens)
DIRECTUS_TOKEN=your-readonly-token-here

# Secret pour valider les URLs de preview (valeur arbitraire, gardez-la secrète)
PREVIEW_SECRET=your-preview-secret-here
